<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:VideoArchiveManager.App.Helpers.Converters">
    <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
    <conv:NullToVisibilityConverter x:Key="NullToVisibilityInverted"
                                    WhenNull="Visible"
                                    WhenNotNull="Collapsed" />
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityInverted" Invert="True" />
    <conv:InverseBoolConverter x:Key="InverseBool" />
    <conv:WidthToAspectHeightConverter x:Key="WidthTo16x9Height" Ratio="0.5625" />
    <conv:CountToVisibilityConverter x:Key="EmptyToVisibility" />
    <conv:CountToVisibilityConverter x:Key="NotEmptyToVisibility" ShowWhenZero="False" />
    <!-- true → star, false → Auto. Used by the sidebar rail's outer Grid
         so an expanded panel grabs proportional rail height while a
         collapsed one shrinks to header-only Auto height. -->
    <conv:BoolToGridLengthConverter x:Key="BoolToStarOrAuto" />
</ResourceDictionary>
