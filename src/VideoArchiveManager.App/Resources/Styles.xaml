<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.modernwpf.com/2019">
    <Thickness x:Key="CardMargin">6</Thickness>

    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Opacity" Value="0.8" />
        <Setter Property="Margin" Value="0,10,0,4" />
    </Style>

    <Style x:Key="VideoCardBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Margin" Value="{StaticResource CardMargin}" />
        <Setter Property="Padding" Value="6" />
    </Style>

    <Style x:Key="TagChipBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight2Brush}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="Margin" Value="2" />
    </Style>
</ResourceDictionary>
