<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls">

    <!--
        Default template for the EmptyState templated control.

        Layout: 48px Fluent glyph + 16px headline + 13px subtext (max width)
        + optional primary CTA. Centered both axes.

        Typically dropped into a Grid behind a content host that's hidden
        while the source collection is empty (driven by CountToVisibility).
    -->

    <Style TargetType="{x:Type helpers:EmptyState}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground.Primary}" />
        <Setter Property="Padding" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type helpers:EmptyState}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="360">
                            <TextBlock Text="{TemplateBinding Glyph}"
                                       FontFamily="{StaticResource App.Icon.FontFamily}"
                                       FontSize="48"
                                       Foreground="{DynamicResource App.Foreground.Tertiary}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,16"
                                       TextOptions.TextRenderingMode="ClearType" />
                            <TextBlock Text="{TemplateBinding Headline}"
                                       Style="{StaticResource App.Type.H2}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{TemplateBinding Subtext}"
                                       Style="{StaticResource App.Type.BodyMuted}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                            <Button Margin="0,20,0,0"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource App.Button.Primary}"
                                    Content="{TemplateBinding CtaText}"
                                    Command="{TemplateBinding CtaCommand}"
                                    CommandParameter="{TemplateBinding CtaCommandParameter}"
                                    helpers:Theme.Icon="{TemplateBinding CtaIcon}"
                                    Visibility="{Binding HasCta, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
