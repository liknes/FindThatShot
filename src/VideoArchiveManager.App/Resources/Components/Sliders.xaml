<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Slim accent-tinted scrollbars + redesigned player seek slider.

        Scrollbars are styled implicitly (no x:Key on the outer Style) so
        every ScrollViewer in the app picks them up automatically — sidebar,
        catalog, editor pane, dialog scrollers. ModernWpfUI's defaults are
        replaced wholesale; thumb is 8px wide with rounded ends and shows
        accent on hover.

        The player seek slider has a thicker (4px) track with an accent
        fill on the played portion and a glowing 14px thumb. Applied
        explicitly via Style="{StaticResource App.SeekSlider}" so other
        sliders elsewhere (e.g. NumberBox internals) keep their defaults.
    -->

    <SolidColorBrush x:Key="App.ScrollBar.Track" Color="Transparent" />

    <Style x:Key="App.ScrollBar.Thumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="{DynamicResource App.Border.Strong}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Pad"
                            CornerRadius="4"
                            Background="{TemplateBinding Background}"
                            Margin="2" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Pad" Property="Background" Value="{DynamicResource App.Accent}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Pad" Property="Background" Value="{DynamicResource App.Accent.Hover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="App.ScrollBar.RepeatBtn" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Two templates (vertical / horizontal). The implicit ScrollBar Style
        below switches Template via a trigger on Orientation. Switching the
        Template property is allowed, switching the Style property of the
        templated element is NOT (WPF "Style is not allowed to affect the
        Style property of the object to which it applies"). That distinction
        is why these are standalone ControlTemplate resources rather than
        being wrapped in keyed Styles that the implicit dispatcher then
        assigned to Style.
    -->
    <ControlTemplate x:Key="App.ScrollBar.VerticalTemplate" TargetType="ScrollBar">
        <Grid Background="{TemplateBinding Background}">
            <Track Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource App.ScrollBar.RepeatBtn}"
                                  Command="ScrollBar.PageUpCommand" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource App.ScrollBar.Thumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource App.ScrollBar.RepeatBtn}"
                                  Command="ScrollBar.PageDownCommand" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="App.ScrollBar.HorizontalTemplate" TargetType="ScrollBar">
        <Grid Background="{TemplateBinding Background}">
            <Track Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource App.ScrollBar.RepeatBtn}"
                                  Command="ScrollBar.PageLeftCommand" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource App.ScrollBar.Thumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource App.ScrollBar.RepeatBtn}"
                                  Command="ScrollBar.PageRightCommand" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <!-- Implicit dispatcher: vertical by default, swaps to horizontal template
         when Orientation flips. ModernWpfUI's default scrollbar template is
         replaced wholesale across the whole app. -->
    <Style TargetType="ScrollBar">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="MinWidth" Value="12" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Template" Value="{StaticResource App.ScrollBar.VerticalTemplate}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Template" Value="{StaticResource App.ScrollBar.HorizontalTemplate}" />
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="12" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="12" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Player seek slider.

         Track: 4px high, App.Background.Highest fill, accent on the played
                portion (via Track.DecreaseRepeatButton sized to current value).
         Thumb: 14px circular knob, accent-amber, glow on drag. -->

    <Style x:Key="App.SeekSlider.Thumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <Ellipse x:Name="Glow"
                                 Fill="{DynamicResource App.Accent}"
                                 Opacity="0"
                                 Margin="-6" />
                        <Ellipse x:Name="Knob"
                                 Fill="{DynamicResource App.Accent}"
                                 Stroke="{DynamicResource App.Accent}"
                                 StrokeThickness="2" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Glow" Property="Opacity" Value="0.25" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Glow" Property="Opacity" Value="0.45" />
                            <Setter TargetName="Knob" Property="Fill" Value="{DynamicResource App.Accent.Hover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="App.SeekSlider" TargetType="Slider">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <!-- Taller than the visible 4px track on purpose: the extra height is
             an invisible click target (both repeat buttons fill it), so you
             don't have to land precisely on the line to seek. -->
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource App.Accent}" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsMoveToPointEnabled" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <!-- Transparent backdrop across the whole control so the
                         entire band is a hit target, not just the track parts. -->
                    <Grid Background="Transparent">
                        <Border CornerRadius="2"
                                Height="4"
                                VerticalAlignment="Center"
                                Background="{DynamicResource App.Background.Highest}" />
                        <Track x:Name="PART_Track"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge"
                                              Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <!-- Transparent full-height backdrop makes the WHOLE
                                                 vertical band click-to-seek, not just the 4px
                                                 line; the accent bar stays a slim 4px visual. -->
                                            <Grid Background="Transparent">
                                                <Border CornerRadius="2"
                                                        Height="4"
                                                        VerticalAlignment="Center"
                                                        Background="{DynamicResource App.Accent}" />
                                            </Grid>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge"
                                              Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource App.SeekSlider.Thumb}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
