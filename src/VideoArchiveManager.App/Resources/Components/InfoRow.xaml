<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls">

    <!--
        Default template for InfoRow.

        Layout:
            [ Label (140 wide, 11px tertiary) | Value (primary, wraps) | CopyBtn (hover-only) ]
            [                                  | SubValue (10px tertiary, optional)            ]

        The copy button is templated as PART_CopyButton so InfoRow's code-behind
        can wire its Click handler in OnApplyTemplate. Visibility flips on row
        hover via a ControlTemplate.Trigger (no DataTrigger needed), and stays
        hidden when there's no value to copy thanks to the DataTrigger on
        Value=null/empty.
    -->

    <Style TargetType="{x:Type helpers:InfoRow}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0,3" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type helpers:InfoRow}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{TemplateBinding Label}"
                                       Foreground="{DynamicResource App.Foreground.Tertiary}"
                                       FontSize="11"
                                       VerticalAlignment="Top"
                                       Margin="0,2,12,0" />

                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       x:Name="PART_ValueText"
                                       Text="{TemplateBinding Value}"
                                       Foreground="{DynamicResource App.Foreground.Primary}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top" />

                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       x:Name="PART_SubValueText"
                                       Text="{TemplateBinding SubValue}"
                                       Foreground="{DynamicResource App.Foreground.Tertiary}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,1,0,0" />

                            <Button Grid.Row="0" Grid.Column="2"
                                    x:Name="PART_CopyButton"
                                    Style="{StaticResource App.Button.Ghost}"
                                    helpers:Theme.Icon="{StaticResource Icon.Copy}"
                                    helpers:Theme.IconSize="12"
                                    Width="22" Height="22"
                                    Margin="8,0,0,0"
                                    Padding="0"
                                    VerticalAlignment="Top"
                                    ToolTip="Copy value"
                                    Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_CopyButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMono" Value="True">
                            <Setter TargetName="PART_ValueText" Property="FontFamily"
                                    Value="{StaticResource App.FontFamily.Mono}" />
                        </Trigger>
                        <Trigger Property="SubValue" Value="{x:Null}">
                            <Setter TargetName="PART_SubValueText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Value" Value="{x:Null}">
                            <Setter TargetName="PART_CopyButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Value" Value="">
                            <Setter TargetName="PART_CopyButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
