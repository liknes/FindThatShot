<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Vertical drag handle between the sidebar rail and the catalog grid.

        Design contract:
            * Sits in its own 5px column between LeftSidebarColumn and
              VideoListColumn in MainWindow.xaml.
            * Visually quiet at rest (a single 1px App.Border.Subtle hairline,
              centred in the 5px gutter). Brightens to App.Accent.Subtle on
              hover and App.Accent on drag so the user gets unambiguous
              feedback that the surface is interactive.
            * Cursor flips to size-west-east when the pointer is over the
              splitter — even on the wider hit-test area, not just the 1px
              line.

        We override the default WPF GridSplitter template wholesale because
        the default chrome is a thick gray slab that reads as native Win32
        and breaks the cinematic dark + warm-amber visual language used
        elsewhere in the app.
    -->
    <Style x:Key="App.GridSplitter" TargetType="GridSplitter">
        <Setter Property="Width" Value="5" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ResizeBehavior" Value="PreviousAndNext" />
        <Setter Property="ResizeDirection" Value="Columns" />
        <Setter Property="Cursor" Value="SizeWE" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ShowsPreview" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridSplitter">
                    <Grid Background="{TemplateBinding Background}">
                        <!-- Thin centred line. 1px wide, full height. The
                             surrounding Grid stays transparent so the 5px
                             column gives the user a comfortable hit area
                             without painting a 5px-wide band. -->
                        <Border x:Name="Line"
                                Width="1"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource App.Border.Subtle}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Line" Property="Background" Value="{DynamicResource App.Accent.Subtle}" />
                            <Setter TargetName="Line" Property="Width" Value="3" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Line" Property="Background" Value="{DynamicResource App.Accent}" />
                            <Setter TargetName="Line" Property="Width" Value="3" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
