<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Tag chip pill.

        Replaces the old TagChipBorder (light SystemAccentColorLight2 fill with
        black text). The new pill is dark-on-dark with accent-amber text, a
        subtle 1px border, and a Segoe Fluent Icons Cancel glyph. Compose in a
        DataTemplate as:

            <Border Style="{StaticResource App.TagChip}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource App.TagChip.Text}" />
                    <Button Style="{StaticResource App.Button.ChipClose}"
                            helpers:Theme.Icon="{StaticResource Icon.Cancel}"
                            Margin="6,0,0,0"
                            Command="..."
                            CommandParameter="{Binding}" />
                </StackPanel>
            </Border>

        Height is fixed at 24 so chips line up on a single visual baseline
        when wrapped in a WrapPanel.
    -->

    <Style x:Key="App.TagChip" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource App.Radius.Chip}" />
        <Setter Property="Background" Value="{DynamicResource App.Background.Highest}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,2" />
        <Setter Property="Margin" Value="2,2,4,2" />
        <Setter Property="Height" Value="{StaticResource App.Height.Chip}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource App.Accent.Subtle}" />
                <Setter Property="Background" Value="{DynamicResource App.Background.Hover}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="App.TagChip.Text" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource App.FontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource App.Accent}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Variant: read-only chip used in card metadata where there's no Remove
         action. Slightly muted — secondary foreground instead of accent. -->
    <Style x:Key="App.TagChip.ReadOnly" TargetType="Border" BasedOn="{StaticResource App.TagChip}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource App.Border.Subtle}" />
                <Setter Property="Background" Value="{DynamicResource App.Background.Highest}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
