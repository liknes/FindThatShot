<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Catalog video card.

        Restyles ListBoxItem itself so the rounded card chrome (background,
        border, hover lift, accent selection) lives on the container instead
        of an inner Border in the DataTemplate. That lets the IsSelected /
        IsMouseOver / IsKeyboardFocused triggers wire directly into the
        chrome without needing AncestorType lookups in the data template.

        Hover: subtle accent border + shadow lift.
        Selected: 2px accent border + slightly elevated background +
                  small accent-amber inner glow.
        Keyboard focus: a soft accent halo so review-session keyboard
                  navigation doesn't lose its place.
    -->

    <Style x:Key="App.VideoCard.ItemStyle" TargetType="ListBoxItem">
        <Setter Property="Margin" Value="6" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{DynamicResource App.Background.Elevated}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Card"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource App.Radius.Card}"
                            Padding="6"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource App.Accent.Subtle}" />
                            <Setter TargetName="Card" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black"
                                                      BlurRadius="14"
                                                      ShadowDepth="2"
                                                      Direction="270"
                                                      Opacity="0.45" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource App.Accent}" />
                            <Setter TargetName="Card" Property="Background" Value="{DynamicResource App.Background.Highest}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Card" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{StaticResource App.Accent.Color}"
                                                      BlurRadius="16"
                                                      ShadowDepth="0"
                                                      Opacity="0.4" />
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Inner thumbnail tile: fixed 16:9 black backdrop with a subtle
         rounded clip so the source image's edges don't crash into the
         card edge. -->
    <Style x:Key="App.VideoCard.Thumbnail" TargetType="Border">
        <Setter Property="Background" Value="#FF050507" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

</ResourceDictionary>
