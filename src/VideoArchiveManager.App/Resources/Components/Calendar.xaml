<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Themed Calendar popup used by the From/To DatePickers in the menu row.

        The default WPF Calendar template renders blue date numbers, a red
        Sunday column, a yellow "today" highlight, and bulky 40px day buttons —
        the opposite of the cinematic dark + warm-amber accent we use
        everywhere else. ModernWpfUI ships a Calendar style but the
        DatePicker.CalendarStyle hookup didn't pull it in cleanly, so this
        file replaces CalendarDayButton + CalendarButton wholesale with
        templates that mirror App.ListBoxItem / App.TreeViewItem chrome:
        4px-radius hover pill, App.Background.Hover on hover, App.Accent
        background on selection, App.Accent.OnAccent foreground for high
        contrast against the accent fill, App.Accent border ring (no fill)
        for "today" so the indicator survives even when that day is also
        selected.

        Calendar itself only needs Background / BorderBrush / Foreground
        overrides plus the CalendarDayButtonStyle / CalendarButtonStyle
        property bindings — Calendar exposes both as first-class
        DependencyProperties so we don't need an implicit-style hack to
        force the inner cells to adopt our template. Application sites opt
        in via DatePicker.CalendarStyle="{StaticResource App.Calendar}";
        leaving the property unset keeps a control on whatever default it
        had (this style does NOT target Calendar implicitly).

        Sizing tokens are deliberately compact (24x24 day cells, 40x32
        month/year cells) so the popup proportions match the 13px text
        inputs sitting directly above it in the menu row.
    -->

    <!-- Day-of-month cell (the 7x6 grid of numbered days). -->
    <Style x:Key="App.CalendarDayButton" TargetType="CalendarDayButton">
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="{DynamicResource App.FontFamily}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground.Primary}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarDayButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="Cp"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <!-- Triggers fire in declaration order; later ones override
                         earlier ones on the same property. The order here is
                         deliberate: inactive (other-month) dimming comes first
                         so a selected previous-month day still flips to the
                         high-contrast accent foreground; today's accent
                         border comes before hover/selection backgrounds so
                         all three can coexist visually. -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource App.Foreground.Tertiary}" />
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource App.Accent}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.Background.Hover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource App.Accent.OnAccent}" />
                        </Trigger>
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter TargetName="Cp" Property="Opacity" Value="0.3" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Month / year / decade selector cell (3x4 grid revealed by clicking
         the header — e.g. "Jan", "Feb", "2024", "2020-2029"). Slightly
         taller than the day cell because the labels are word-shaped rather
         than 1-2 digit numbers, and HasSelectedDays acts as the
         "this bucket contains the current selection" affordance via the
         accent border ring. -->
    <Style x:Key="App.CalendarButton" TargetType="CalendarButton">
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="{DynamicResource App.FontFamily}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground.Primary}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource App.Foreground.Tertiary}" />
                        </Trigger>
                        <Trigger Property="HasSelectedDays" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource App.Accent}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.Background.Hover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The Calendar itself only needs surface chrome + the cell-style
         hookups. The outer Border in the default WPF Calendar template
         TemplateBinds to Background / BorderBrush / BorderThickness /
         Padding, so setting these on the Style propagates correctly. The
         month / year header button and the M-T-W-T-F-S-S day-name row
         inherit Foreground / FontFamily via TextElement, so they pick up
         our type ramp without needing a CalendarItem template rewrite. -->
    <Style x:Key="App.Calendar" TargetType="Calendar">
        <Setter Property="Background" Value="{DynamicResource App.Background.Elevated}" />
        <Setter Property="BorderBrush" Value="{DynamicResource App.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="FontFamily" Value="{DynamicResource App.FontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground.Primary}" />
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource App.CalendarDayButton}" />
        <Setter Property="CalendarButtonStyle" Value="{StaticResource App.CalendarButton}" />
    </Style>

</ResourceDictionary>
