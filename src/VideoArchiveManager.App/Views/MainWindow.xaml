<Window x:Class="VideoArchiveManager.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:VideoArchiveManager.App.ViewModels"
        xmlns:enums="clr-namespace:VideoArchiveManager.Core.Models.Enums;assembly=VideoArchiveManager.Core"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Video Archive Manager"
        Width="1400" Height="880"
        MinWidth="1024" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ui:WindowHelper.UseModernWindowStyle="True"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <ObjectDataProvider x:Key="StatusValues" MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enums:VideoStatus" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding AddRootFolderCommand}" />
        <KeyBinding Key="F5" Command="{Binding ScanCommand}" />
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="B" Modifiers="Control" Command="{Binding OpenBulkEditCommand}" />
        <KeyBinding Key="OemComma" Modifiers="Control" Command="{Binding OpenSettingsCommand}" />
        <KeyBinding Key="L" Modifiers="Control+Shift" Command="{Binding ClearFiltersCommand}" />
        <KeyBinding Key="F" Modifiers="Control" Command="{x:Static ApplicationCommands.Find}" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Find" Executed="FocusSearch_Executed" />
    </Window.CommandBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: single chrome row. Menu (left) + search/actions/filters (right).
             Uses DockPanel + WrapPanel so it stays one line at normal widths and
             wraps gracefully if the window gets very narrow. -->
        <Border Grid.Row="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <Menu DockPanel.Dock="Left"
                      Background="Transparent"
                      VerticalAlignment="Center"
                      Padding="4,2">
                    <MenuItem Header="_File">
                        <MenuItem Header="_Add folder…"
                                  Command="{Binding AddRootFolderCommand}"
                                  InputGestureText="Ctrl+O" />
                        <MenuItem Header="_Remove selected folder…"
                                  Command="{Binding RemoveRootFolderCommand}"
                                  CommandParameter="{Binding SelectedRootFolder}"
                                  ToolTip="Remove the selected root folder and any catalog entries imported from it. Source video files will NOT be touched." />
                        <Separator />
                        <MenuItem Header="_Settings…"
                                  Command="{Binding OpenSettingsCommand}"
                                  InputGestureText="Ctrl+," />
                        <Separator />
                        <MenuItem Header="E_xit" Click="ExitMenu_Click" InputGestureText="Alt+F4" />
                    </MenuItem>
                    <MenuItem Header="_Catalog">
                        <MenuItem Header="_Scan"
                                  Command="{Binding ScanCommand}"
                                  IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                                  InputGestureText="F5" />
                        <MenuItem Header="_Cancel scan"
                                  Command="{Binding CancelScanCommand}"
                                  IsEnabled="{Binding IsScanning}" />
                        <MenuItem Header="_Refresh"
                                  Command="{Binding RefreshCommand}"
                                  InputGestureText="Ctrl+R" />
                        <Separator />
                        <MenuItem Header="_Bulk edit selection…"
                                  Command="{Binding OpenBulkEditCommand}"
                                  InputGestureText="Ctrl+B" />
                        <Separator />
                        <MenuItem Header="Fill missing _locations from GPS…"
                                  Command="{Binding FillMissingLocationsCommand}"
                                  IsEnabled="{Binding IsGeocodingLocations, Converter={StaticResource InverseBool}}"
                                  ToolTip="For any video that has GPS coordinates but no location, look up a place name from OpenStreetMap and fill it in. Existing locations are not changed." />
                        <MenuItem Header="Ca_ncel location lookup"
                                  Command="{Binding CancelFillMissingLocationsCommand}"
                                  IsEnabled="{Binding IsGeocodingLocations}" />
                        <Separator />
                        <MenuItem Header="Remove _offline videos…"
                                  Command="{Binding RemoveOfflineVideosCommand}"
                                  ToolTip="Remove catalog entries whose source file is no longer on disk. Source video files will NOT be touched." />
                        <MenuItem Header="Remove _selected from catalog…"
                                  Command="{Binding RemoveSelectedVideosCommand}"
                                  InputGestureText="Del" />
                    </MenuItem>
                    <MenuItem Header="_View">
                        <MenuItem Header="Show only _available files"
                                  IsCheckable="True"
                                  IsChecked="{Binding ShowOnlyAvailable}" />
                        <Separator />
                        <MenuItem Header="Focus _search"
                                  Click="FocusSearchMenu_Click"
                                  InputGestureText="Ctrl+F" />
                        <MenuItem Header="_Clear all filters"
                                  Command="{Binding ClearFiltersCommand}"
                                  InputGestureText="Ctrl+Shift+L" />
                    </MenuItem>
                    <MenuItem Header="_Help">
                        <MenuItem Header="Check for _updates…"
                                  Command="{Binding CheckForUpdatesCommand}"
                                  IsEnabled="{Binding IsCheckingForUpdates, Converter={StaticResource InverseBool}}"
                                  ToolTip="Look for a newer version on GitHub Releases and install it. Only works when running from an installed build (Setup.exe)." />
                        <Separator />
                        <MenuItem Header="_About Video Archive Manager…" Click="About_Click" />
                    </MenuItem>
                </Menu>

                <WrapPanel Orientation="Horizontal"
                           VerticalAlignment="Center"
                           Margin="12,4,12,4">
                    <TextBox x:Name="SearchBox"
                             Width="260"
                             Margin="0,2,0,2"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ui:ControlHelper.PlaceholderText="Search filename, folder, tags, notes, camera..."
                             VerticalAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="Search"
                            Margin="6,2,0,2"
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource AccentButtonStyle}" />
                    <Separator Margin="10,4" />
                    <Button Content="Scan"
                            Margin="0,2,0,2"
                            Command="{Binding ScanCommand}"
                            IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                            Style="{StaticResource AccentButtonStyle}"
                            ToolTip="Scan all root folders for new or changed videos (F5)" />
                    <Button Content="Cancel scan"
                            Margin="6,2,0,2"
                            Command="{Binding CancelScanCommand}"
                            Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}" />
                    <Separator Margin="10,4" />
                    <!--
                        HIDDEN: Status filter. The ViewModel property StatusFilter
                        is still wired up; uncomment to bring it back.
                    <ComboBox Width="150" Margin="0,2,0,2"
                              ItemsSource="{Binding AvailableStatuses}"
                              SelectedItem="{Binding StatusFilter}"
                              ui:ControlHelper.PlaceholderText="Status" />
                    -->
                    <ComboBox Width="140"
                              Margin="0,2,0,2"
                              ItemsSource="{Binding Cameras}"
                              SelectedItem="{Binding CameraFilter}"
                              ui:ControlHelper.PlaceholderText="Camera"
                              IsEditable="True" />
                    <!--
                        HIDDEN: Tag dropdown. The left sidebar's Tags list serves
                        this purpose and scales better. Uncomment to restore.
                    <ComboBox Width="120" Margin="6,2,0,2"
                              ItemsSource="{Binding AllTags}"
                              SelectedItem="{Binding SelectedTagFilter}"
                              DisplayMemberPath="Name"
                              ui:ControlHelper.PlaceholderText="Tag" />
                    -->
                    <!--
                        HIDDEN: Min rating filter (rating is usually managed in
                        DaVinci / Lightroom / Bridge). Uncomment to restore.
                    <StackPanel Orientation="Horizontal" Margin="10,2,0,2">
                        <TextBlock Text="Min ★" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <ui:NumberBox Width="80" Minimum="0" Maximum="5"
                                      Value="{Binding MinRatingFilter}" />
                    </StackPanel>
                    -->
                    <DatePicker Margin="6,2,0,2"
                                SelectedDate="{Binding DateFrom}"
                                ui:ControlHelper.PlaceholderText="From" />
                    <DatePicker Margin="6,2,0,2"
                                SelectedDate="{Binding DateTo}"
                                ui:ControlHelper.PlaceholderText="To" />
                    <Button Margin="10,2,0,2"
                            Content="Start review session"
                            Command="{Binding StartReviewSessionCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            ToolTip="Clear all filters and show only unreviewed clips (no status set or no tags). Selects the first clip so you can start reviewing right away." />
                    <Button Margin="6,2,0,2"
                            Content="Clear filters"
                            Command="{Binding ClearFiltersCommand}"
                            ToolTip="Reset search box, all filters, and date range (Ctrl+Shift+L)" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- Row 1 hosts two layouts at once:
               * Normal mode: Col 0 (sidebar) + Col 1 (video list) + Col 3 (editor) are visible,
                 Col 2 (player) has Width=0.
               * Review mode (Detail.IsPlayerVisible): Col 0/1 collapse to Width=0, Col 2 grows
                 to fill the leftover space, Col 3 (editor) narrows slightly.
             The width swap is done in MainWindow.xaml.cs when IsPlayerVisible changes; the
             VideoView control therefore lives in a stable place in the visual tree and is
             never reparented (which keeps LibVLC's HwndHost happy). -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftSidebarColumn" Width="260" MinWidth="200" />
                <ColumnDefinition x:Name="VideoListColumn" Width="*" />
                <ColumnDefinition x:Name="PlayerColumn" Width="0" />
                <ColumnDefinition x:Name="EditorColumn" Width="460" MinWidth="420" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="10"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Root folders" Style="{StaticResource SectionHeader}" />
                        <ListBox ItemsSource="{Binding RootFolders}"
                                 SelectedItem="{Binding SelectedRootFolder}"
                                 Height="180">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Path}" Opacity="0.7" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Content="Remove selected…"
                                Margin="0,4,0,0"
                                ToolTip="Remove the selected root folder and any catalog entries imported from it. Source video files will NOT be touched."
                                Command="{Binding RemoveRootFolderCommand}"
                                CommandParameter="{Binding SelectedRootFolder}" />

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Tags"
                                       Style="{StaticResource SectionHeader}" />
                            <Button Grid.Column="1"
                                    Content="Clear"
                                    Padding="6,0"
                                    FontSize="11"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    ToolTip="Remove all selected tag filters."
                                    Command="{Binding ClearTagFiltersCommand}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding SelectedTagFilters}"
                                      Margin="0,0,0,4">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource TagChipBorder}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Foreground="Black" />
                                            <Button Content="x"
                                                    Margin="6,0,0,0"
                                                    Padding="2,0"
                                                    FontSize="10"
                                                    Foreground="Black"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    ToolTip="Remove this tag filter."
                                                    Command="{Binding DataContext.RemoveTagFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBox Text="{Binding TagFilterSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ui:ControlHelper.PlaceholderText="Type to filter tags…"
                                 Margin="0,0,0,4" />

                        <ListBox x:Name="TagFilterList"
                                 ItemsSource="{Binding FilteredTags}"
                                 Height="180"
                                 DisplayMemberPath="Name"
                                 SelectionChanged="TagFilterList_OnSelectionChanged"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 ToolTip="Click a tag to add it as a filter. Multiple tags are combined with AND (videos must have every selected tag)." />

                        <TextBlock Text="Cameras" Style="{StaticResource SectionHeader}" />
                        <ListBox ItemsSource="{Binding Cameras}"
                                 SelectedItem="{Binding CameraFilter}"
                                 Height="120" />

                        <CheckBox Content="Show only available files"
                                  IsChecked="{Binding ShowOnlyAvailable}"
                                  Margin="0,12,0,0" />

                        <CheckBox Content="Show only unreviewed"
                                  IsChecked="{Binding OnlyUnreviewed}"
                                  Margin="0,4,0,0"
                                  ToolTip="Limit the catalog to clips that look untouched: still marked Unreviewed OR have no tags yet. Same signal used by the &quot;Start review session&quot; button." />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <ListBox Grid.Column="1"
                     x:Name="VideoListBox"
                     ItemsSource="{Binding Videos}"
                     SelectedItem="{Binding SelectedVideo}"
                     SelectionMode="Extended"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.IsDeferredScrollingEnabled="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     SelectionChanged="VideoList_OnSelectionChanged"
                     HorizontalContentAlignment="Stretch">
                <ListBox.InputBindings>
                    <KeyBinding Key="Delete"
                                Command="{Binding RemoveSelectedVideosCommand}" />
                </ListBox.InputBindings>
                <ListBox.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Remove from database…"
                                  InputGestureText="Del"
                                  Command="{Binding RemoveSelectedVideosCommand}" />
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource VideoCardBorder}" Width="240">
                            <StackPanel>
                                <Grid Background="Black" Height="135">
                                    <Image Source="{Binding Thumbnail}"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch" />
                                    <Border VerticalAlignment="Bottom"
                                            HorizontalAlignment="Right"
                                            Background="#A0000000"
                                            Padding="4,2"
                                            CornerRadius="3"
                                            Margin="4">
                                        <TextBlock Text="{Binding DurationText}"
                                                   Foreground="White" FontSize="11" />
                                    </Border>
                                    <Border Background="#C0000000"
                                            Padding="6,3"
                                            CornerRadius="3"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding FileExists, Converter={StaticResource BoolToVisibilityInverted}}">
                                        <TextBlock Text="Offline"
                                                   Foreground="White"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding FileName}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,6,0,0" />
                                <TextBlock Text="{Binding Resolution}"
                                           Opacity="0.7"
                                           FontSize="11" />
                                <TextBlock Text="{Binding Camera}"
                                           Opacity="0.7"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Status}" FontSize="11" />
                                    <TextBlock Text="  ★ " FontSize="11" Margin="6,0,0,0" />
                                    <TextBlock Text="{Binding Rating}" FontSize="11" />
                                </StackPanel>
                                <TextBlock Text="{Binding TagSummary}"
                                           Opacity="0.6"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Player column (review mode). Width=0 normally; expanded by code-behind
                 to fill space when Detail.IsPlayerVisible flips to true. The vlc:VideoView
                 stays parented here at all times so the LibVLC HwndHost is never
                 destroyed and re-created. -->
            <Border Grid.Column="2"
                    Background="Black"
                    DataContext="{Binding Detail}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <vlc:VideoView x:Name="VideoPlayer" Grid.Row="0" />

                    <!-- Player toolbar. Visible only in review mode (IsPlayerVisible),
                         but we also hide it via column width=0 in normal mode so this
                         binding is mostly belt-and-braces. -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                            Padding="10,8"
                            Visibility="{Binding IsPlayerVisible, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Seek bar row -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="PlayerCurrentTimeText" Grid.Column="0"
                                           Text="00:00" FontFamily="Consolas"
                                           VerticalAlignment="Center" Width="60"
                                           TextAlignment="Right" />
                                <Slider x:Name="PlayerSeekSlider" Grid.Column="1"
                                        Margin="10,0,10,0"
                                        Minimum="0" Maximum="1000"
                                        SmallChange="5" LargeChange="50"
                                        IsMoveToPointEnabled="True"
                                        VerticalAlignment="Center"
                                        Thumb.DragStarted="PlayerSeekSlider_DragStarted"
                                        Thumb.DragCompleted="PlayerSeekSlider_DragCompleted"
                                        PreviewMouseLeftButtonUp="PlayerSeekSlider_PreviewMouseLeftButtonUp" />
                                <TextBlock x:Name="PlayerDurationText" Grid.Column="2"
                                           Text="00:00" FontFamily="Consolas"
                                           VerticalAlignment="Center" Width="60"
                                           TextAlignment="Left" />
                            </Grid>

                            <!-- Buttons row -->
                            <WrapPanel Grid.Row="1" HorizontalAlignment="Center" ItemHeight="36">
                                <Button x:Name="PlayPauseButton"
                                        Content="Pause"
                                        Width="100"
                                        Margin="0,2,0,2"
                                        Click="PlayerPlayPause_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        ToolTip="Toggle play / pause (Space)" />
                                <Button Content="Stop" Width="80" Margin="6,2,0,2"
                                        Click="PlayerStop_Click"
                                        ToolTip="Stop playback (resets position)" />
                                <Button Content="-5s" Width="60" Margin="6,2,0,2"
                                        Click="PlayerSkipBack_Click"
                                        ToolTip="Skip back 5 seconds" />
                                <Button Content="+5s" Width="60" Margin="6,2,0,2"
                                        Click="PlayerSkipForward_Click"
                                        ToolTip="Skip forward 5 seconds" />
                                <Button Content="Close player" Width="120" Margin="12,2,0,2"
                                        Command="{Binding ClosePlayerCommand}"
                                        ToolTip="Close the player and return to the catalog" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="3"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <TextBlock Text="Select a video to view details"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.6"
                               Visibility="{Binding Detail.Current, Converter={StaticResource NullToVisibilityInverted}}" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding Detail.Current, Converter={StaticResource NullToVisibility}}">
                        <StackPanel Margin="12" DataContext="{Binding Detail}">
                            <!-- Thumbnail only in normal mode; in review mode the video
                                 is showing in its own column so we hide this. -->
                            <Image Source="{Binding LargeThumbnail}" MaxHeight="220"
                                   Stretch="Uniform" Margin="0,0,0,8"
                                   Visibility="{Binding IsPlayerVisible, Converter={StaticResource BoolToVisibilityInverted}}" />

                            <TextBlock Text="{Binding Current.FileName}" FontWeight="SemiBold"
                                       TextWrapping="Wrap" FontSize="14" />
                            <TextBlock Text="{Binding Current.FilePath}" Opacity="0.7"
                                       TextWrapping="Wrap" FontSize="11" Margin="0,2,0,8" />

                            <WrapPanel ItemHeight="36">
                                <Button Content="Open location" Margin="0,2,0,2"
                                        Command="{Binding OpenFileLocationCommand}" />
                                <Button Content="Copy path" Margin="6,2,0,2"
                                        Command="{Binding CopyFilePathCommand}" />
                                <Button Content="Play in app" Margin="6,2,0,2"
                                        Command="{Binding PlayInAppCommand}"
                                        IsEnabled="{Binding CanPlayInApp}"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Visibility="{Binding IsPlayerVisible, Converter={StaticResource BoolToVisibilityInverted}}" />
                                <Button Content="Play externally" Margin="6,2,0,2"
                                        Command="{Binding PlayCommand}" />
                            </WrapPanel>
                            <TextBlock Text="{Binding PlayerUnavailableMessage}"
                                       Foreground="Orange"
                                       TextWrapping="Wrap"
                                       FontSize="11"
                                       Margin="0,4,0,0"
                                       Visibility="{Binding CanPlayInApp, Converter={StaticResource BoolToVisibilityInverted}}" />

                            <TextBlock Text="Metadata" Style="{StaticResource SectionHeader}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition /><RowDefinition /><RowDefinition />
                                    <RowDefinition /><RowDefinition /><RowDefinition />
                                    <RowDefinition /><RowDefinition />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Duration" Opacity="0.7" Margin="0,2,8,2" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Current.DurationText}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Resolution" Opacity="0.7" Margin="0,2,8,2" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Current.Resolution}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Camera" Opacity="0.7" Margin="0,2,8,2" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Current.Camera}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Codec" Opacity="0.7" Margin="0,2,8,2" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Current.Codec}" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Size" Opacity="0.7" Margin="0,2,8,2" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Current.FileSizeText}" />
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Folder" Opacity="0.7" Margin="0,2,8,2" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Current.FolderPath}" TextWrapping="Wrap" />

                                <!-- Location row: only shown if LocationText is set (from folder parsing
                                     today, or from reverse-geocoded GPS once that's wired up). -->
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Location" Opacity="0.7" Margin="0,2,8,2"
                                           Visibility="{Binding Current.HasLocation, Converter={StaticResource BoolToVisibility}}" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Current.LocationText}" TextWrapping="Wrap"
                                           Visibility="{Binding Current.HasLocation, Converter={StaticResource BoolToVisibility}}" />

                                <!-- GPS row: only shown if coords were extracted from the file. -->
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="GPS" Opacity="0.7" Margin="0,2,8,2"
                                           Visibility="{Binding Current.HasGps, Converter={StaticResource BoolToVisibility}}" />
                                <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal"
                                            Visibility="{Binding Current.HasGps, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{Binding Current.GpsText}" />
                                    <TextBlock Margin="8,0,0,0">
                                        <Hyperlink NavigateUri="{Binding Current.GpsMapUrl}"
                                                   RequestNavigate="Hyperlink_RequestNavigate">
                                            Open in map
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Tags" Style="{StaticResource SectionHeader}" />
                            <ItemsControl ItemsSource="{Binding Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TagChipBorder}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" Foreground="Black" />
                                                <Button Content="x"
                                                        Margin="6,0,0,0"
                                                        Padding="2,0"
                                                        FontSize="10"
                                                        Foreground="Black"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBox Width="140"
                                         Text="{Binding NewTagName, UpdateSourceTrigger=PropertyChanged}"
                                         ui:ControlHelper.PlaceholderText="New tag">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding AddTagCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <ComboBox Width="110" Margin="6,0,0,0"
                                          ItemsSource="{Binding AvailableTagTypes}"
                                          SelectedItem="{Binding NewTagType}" />
                                <Button Content="Add" Margin="6,0,0,0"
                                        Command="{Binding AddTagCommand}" />
                            </StackPanel>

                            <TextBlock Text="Status" Style="{StaticResource SectionHeader}" />
                            <ComboBox ItemsSource="{Binding AvailableStatuses}"
                                      SelectedItem="{Binding Status}" />

                            <TextBlock Text="Rating" Style="{StaticResource SectionHeader}" />
                            <ComboBox ItemsSource="{Binding RatingValues}"
                                      SelectedItem="{Binding Rating}" />

                            <TextBlock Text="Notes" Style="{StaticResource SectionHeader}" />
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="80" />

                            <Button Content="Save"
                                    Command="{Binding SaveCommand}"
                                    HorizontalAlignment="Right"
                                    Margin="0,10,0,0"
                                    Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="10,6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Text="{Binding ScanElapsedText}"
                           Margin="8,0"
                           VerticalAlignment="Center"
                           Opacity="0.75"
                           Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}" />
                <ProgressBar Grid.Column="2" Width="80" Height="14" Margin="0,0,8,0"
                             IsIndeterminate="True"
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}" />
                <ProgressBar Grid.Column="3" Width="240" Height="14"
                             Maximum="{Binding ProgressMaximum}"
                             Value="{Binding ProgressValue}"
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}" />
                <Border Grid.Column="4"
                        Margin="12,0,0,0"
                        Padding="6,2"
                        CornerRadius="3"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        ToolTip="Shows whether sidecar JSON files are being written next to videos. Toggle in Settings → Sidecar files.">
                    <TextBlock Text="{Binding SidecarStatusText}"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Opacity="0.8" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
