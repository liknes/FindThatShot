<Window x:Class="VideoArchiveManager.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:VideoArchiveManager.App.ViewModels"
        xmlns:controls="clr-namespace:VideoArchiveManager.App.Helpers.Controls"
        xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls"
        xmlns:enums="clr-namespace:VideoArchiveManager.Core.Models.Enums;assembly=VideoArchiveManager.Core"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:ffme="clr-namespace:Unosquare.FFME;assembly=ffme.win"
        xmlns:loc="clr-namespace:VideoArchiveManager.App.Localization"
        Title="Find That Shot"
        Width="1400" Height="880"
        MinWidth="1024" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        ui:TitleBar.IsIconVisible="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        Activated="Window_ActivationChanged"
        Deactivated="Window_ActivationChanged">
    <Window.Resources>
        <ObjectDataProvider x:Key="StatusValues" MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enums:VideoStatus" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding AddRootFolderCommand}" />
        <KeyBinding Key="F5" Command="{Binding ScanCommand}" />
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="B" Modifiers="Control" Command="{Binding OpenBulkEditCommand}" />
        <KeyBinding Key="OemComma" Modifiers="Control" Command="{Binding OpenSettingsCommand}" />
        <KeyBinding Key="L" Modifiers="Control+Shift" Command="{Binding ClearFiltersCommand}" />
        <KeyBinding Key="R" Modifiers="Control+Shift" Command="{Binding StartReviewSessionCommand}" />
        <KeyBinding Key="F" Modifiers="Control" Command="{x:Static ApplicationCommands.Find}" />
        <!-- Windows convention: Alt+Enter opens "Properties" / "Get info" for
             the current selection. We mirror that here so the clip-info
             popup is reachable without a right-click hunt. -->
        <KeyBinding Key="Enter" Modifiers="Alt" Command="{Binding Detail.ShowInfoCommand}" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Find" Executed="FocusSearch_Executed" />
    </Window.CommandBindings>

    <Grid Background="{DynamicResource App.Background.Base}"
          TextElement.Foreground="{DynamicResource App.Foreground.Primary}"
          TextElement.FontFamily="{DynamicResource App.FontFamily}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: single chrome row. Menu (left) + search/actions/filters (right).
             Uses DockPanel + WrapPanel so it stays one line at normal widths and
             wraps gracefully if the window gets very narrow.
             In review mode the bottom 1px separator is collapsed so it can't draw
             a pale chrome line on top of the cinematic black backdrop. -->
        <Border Grid.Row="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Detail.IsPlayerVisible}" Value="True">
                            <Setter Property="BorderThickness" Value="0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel LastChildFill="True">
                <Menu DockPanel.Dock="Left"
                      Background="Transparent"
                      VerticalAlignment="Center"
                      Margin="8,0,0,0"
                      Padding="4,2">
                    <MenuItem Header="{loc:Tr Main_Menu_File}">
                        <MenuItem Header="{loc:Tr Main_Menu_AddFolder}"
                                  Command="{Binding AddRootFolderCommand}"
                                  InputGestureText="Ctrl+O" />
                        <MenuItem Header="{loc:Tr Main_Menu_RemoveSelectedFolder}"
                                  Command="{Binding RemoveRootFolderCommand}"
                                  CommandParameter="{Binding SelectedRootFolder}"
                                  ToolTip="{loc:Tr Main_Menu_RemoveSelectedFolder_Tip}" />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Menu_Settings}"
                                  Command="{Binding OpenSettingsCommand}"
                                  InputGestureText="Ctrl+," />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Menu_Exit}" Click="ExitMenu_Click" InputGestureText="Alt+F4" />
                    </MenuItem>
                    <MenuItem Header="{loc:Tr Main_Menu_Catalog}">
                        <MenuItem Header="{loc:Tr Main_Menu_Scan}"
                                  Command="{Binding ScanCommand}"
                                  IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                                  InputGestureText="F5" />
                        <MenuItem Header="{loc:Tr Main_Menu_CancelScan}"
                                  Command="{Binding CancelScanCommand}"
                                  IsEnabled="{Binding IsScanning}" />
                        <MenuItem Header="{loc:Tr Main_Menu_Refresh}"
                                  Command="{Binding RefreshCommand}"
                                  InputGestureText="Ctrl+R" />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Menu_Stats}"
                                  Click="CatalogStats_Click"
                                  ToolTip="{loc:Tr Main_Menu_Stats_Tip}" />
                        <MenuItem Header="{loc:Tr Main_Menu_Duplicates}"
                                  Click="Duplicates_Click"
                                  ToolTip="{loc:Tr Main_Menu_Duplicates_Tip}" />
                        <MenuItem Header="{loc:Tr Main_Menu_Moments}"
                                  Click="Moments_Click"
                                  ToolTip="{loc:Tr Main_Menu_Moments_Tip}" />
                        <MenuItem Header="{loc:Tr Main_Menu_Map}"
                                  Click="Map_Click"
                                  ToolTip="{loc:Tr Main_Menu_Map_Tip}" />
                        <MenuItem Header="{loc:Tr Main_Menu_Calendar}"
                                  Click="Calendar_Click"
                                  ToolTip="{loc:Tr Main_Menu_Calendar_Tip}" />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Menu_GenerateAi}"
                                  Click="GenerateAiTags_Click"
                                  Visibility="{Binding IsAiEnabled, Converter={StaticResource BoolToVisibility}}"
                                  ToolTip="{loc:Tr Main_Menu_GenerateAi_Tip}" />
                        <MenuItem Header="{loc:Tr Main_Menu_RescoreAi}"
                                  Click="ReprocessAiTags_Click"
                                  Visibility="{Binding IsAiEnabled, Converter={StaticResource BoolToVisibility}}"
                                  ToolTip="{loc:Tr Main_Menu_RescoreAi_Tip}" />
                        <MenuItem Header="{loc:Tr Main_Menu_ReviewAi}"
                                  Click="AiReview_Click"
                                  Visibility="{Binding IsAiEnabled, Converter={StaticResource BoolToVisibility}}"
                                  ToolTip="{loc:Tr Main_Menu_ReviewAi_Tip}" />
                        <Separator Visibility="{Binding IsAiEnabled, Converter={StaticResource BoolToVisibility}}" />
                        <MenuItem Header="{loc:Tr Main_Menu_BulkEdit}"
                                  Command="{Binding OpenBulkEditCommand}"
                                  InputGestureText="Ctrl+B" />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Menu_FillLocations}"
                                  Command="{Binding FillMissingLocationsCommand}"
                                  IsEnabled="{Binding IsGeocodingLocations, Converter={StaticResource InverseBool}}"
                                  ToolTip="{loc:Tr Main_Menu_FillLocations_Tip}" />
                        <MenuItem Header="{loc:Tr Main_Menu_CancelLocation}"
                                  Command="{Binding CancelFillMissingLocationsCommand}"
                                  IsEnabled="{Binding IsGeocodingLocations}" />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Menu_RemoveOffline}"
                                  Command="{Binding RemoveOfflineVideosCommand}"
                                  ToolTip="{loc:Tr Main_Menu_RemoveOffline_Tip}" />
                        <MenuItem Header="{loc:Tr Main_Menu_RemoveSelected}"
                                  Command="{Binding RemoveSelectedVideosCommand}"
                                  InputGestureText="Del" />
                    </MenuItem>
                    <MenuItem Header="{loc:Tr Main_Menu_View}">
                        <MenuItem Header="{loc:Tr Main_Menu_ShowAvailable}"
                                  IsCheckable="True"
                                  IsChecked="{Binding ShowOnlyAvailable}" />
                        <MenuItem Header="{loc:Tr Main_Menu_ShowUnreviewed}"
                                  IsCheckable="True"
                                  IsChecked="{Binding OnlyUnreviewed}"
                                  ToolTip="{loc:Tr Main_Menu_ShowUnreviewed_Tip}" />
                        <MenuItem Header="{loc:Tr Main_Menu_MainSubject}"
                                  IsCheckable="True"
                                  IsChecked="{Binding MainSubjectOnly}"
                                  ToolTip="{loc:Tr Main_Menu_MainSubject_Tip}" />
                        <MenuItem Header="{loc:Tr Main_Menu_SemanticSearch}"
                                  IsCheckable="True"
                                  IsChecked="{Binding UseSemanticSearch}"
                                  Visibility="{Binding IsAiEnabled, Converter={StaticResource BoolToVisibility}}"
                                  ToolTip="{loc:Tr Main_Menu_SemanticSearch_Tip}" />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Menu_StartReview}"
                                  Command="{Binding StartReviewSessionCommand}"
                                  InputGestureText="Ctrl+Shift+R"
                                  ToolTip="{loc:Tr Main_Menu_StartReview_Tip}" />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Menu_FocusSearch}"
                                  Click="FocusSearchMenu_Click"
                                  InputGestureText="Ctrl+F" />
                        <MenuItem Header="{loc:Tr Main_Menu_ClearFilters}"
                                  Command="{Binding ClearFiltersCommand}"
                                  InputGestureText="Ctrl+Shift+L" />
                    </MenuItem>
                    <MenuItem Header="{loc:Tr Main_Menu_Help}">
                        <MenuItem Header="{loc:Tr Main_Menu_CheckUpdates}"
                                  Command="{Binding CheckForUpdatesCommand}"
                                  IsEnabled="{Binding IsCheckingForUpdates, Converter={StaticResource InverseBool}}"
                                  ToolTip="{loc:Tr Main_Menu_CheckUpdates_Tip}" />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Menu_Diagnostics}"
                                  Click="Diagnostics_Click"
                                  ToolTip="{loc:Tr Main_Menu_Diagnostics_Tip}" />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Menu_ReportBug}"
                                  Click="ReportBug_Click"
                                  ToolTip="{loc:Tr Main_Menu_ReportBug_Tip}" />
                        <MenuItem Header="{loc:Tr Main_Menu_Feedback}"
                                  Click="SendFeedback_Click"
                                  ToolTip="{loc:Tr Main_Menu_Feedback_Tip}" />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Menu_About}" Click="About_Click" />
                    </MenuItem>
                </Menu>

                <!-- Top row is now "find" only: a single search box. The catalog
                     ACTIONS (Scan, Start review session) live in the Catalog / View
                     menus (and F5 / Ctrl+Shift+R), and the FILTERS (camera, date
                     range, clear) live in the left sidebar — keeping this row
                     uncluttered. The camera filter is the sidebar CAMERAS panel,
                     so the old top-bar camera combo was redundant and dropped. -->
                <WrapPanel Orientation="Horizontal"
                           VerticalAlignment="Center"
                           Margin="12,4,12,4">
                    <!-- The placeholder text and an accent border switch with the
                         AI search mode so the box itself announces whether it's
                         doing literal keyword matching or natural-language
                         (CLIP) matching. Based on the ModernWPF default TextBox
                         style so we keep its chrome; the DataTriggers only
                         override the placeholder + border. -->
                    <TextBox x:Name="SearchBox"
                             Width="360"
                             Margin="0,2,0,2"
                             FontSize="13"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="ui:ControlHelper.PlaceholderText"
                                        Value="{loc:Tr Main_Search_Placeholder}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UseSemanticSearch}" Value="True">
                                        <Setter Property="ui:ControlHelper.PlaceholderText"
                                                Value="{loc:Tr Main_Search_Placeholder_Ai}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource App.Accent}" />
                                        <Setter Property="BorderThickness" Value="1.5" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- Inline AI-search toggle. Mirrors View → "Search by
                         description (AI)" (same UseSemanticSearch binding, so the
                         two stay in sync) but sits right beside the box so the
                         mode is discoverable. Only shown when AI is enabled and
                         the model is installed (IsAiEnabled). Filled amber when
                         on, outlined when off. -->
                    <ToggleButton x:Name="SemanticToggle"
                                  Margin="8,2,0,2"
                                  Padding="11,0"
                                  MinWidth="0"
                                  Cursor="Hand"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding UseSemanticSearch}"
                                  Visibility="{Binding IsAiEnabled, Converter={StaticResource BoolToVisibility}}"
                                  ToolTip="{loc:Tr Main_Search_AiToggle_Tip}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="Bd"
                                        Height="28"
                                        CornerRadius="4"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource App.Accent}"
                                        Background="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock x:Name="Glyph"
                                                   Text="&#xE945;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource App.Accent}" />
                                        <TextBlock x:Name="Label"
                                                   Text="{loc:Tr Main_Search_AiToggle_Label}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource App.Accent}" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.Accent}" />
                                        <Setter TargetName="Glyph" Property="Foreground" Value="{DynamicResource App.Accent.OnAccent}" />
                                        <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource App.Accent.OnAccent}" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource App.Accent.Hover}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- Row 1 hosts two layouts at once:
               * Normal mode: Col 0 (sidebar) + Col 1 (video list) + Col 3 (editor) are visible,
                 Col 2 (player) has Width=0.
               * Review mode (Detail.IsPlayerVisible): Col 0/1 collapse to Width=0, Col 2 grows
                 to fill the leftover space, Col 3 (editor) narrows slightly.
             The width swap is done in MainWindow.xaml.cs when IsPlayerVisible changes; the
             ffme:MediaElement is a real WPF visual so column-width changes are cheap and don't
             interact with any Win32 child window (unlike the previous LibVLCSharp VideoView). -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftSidebarColumn" Width="260" MinWidth="200" MaxWidth="600" />
                <!-- 5px drag handle between the sidebar and the catalog
                     grid. Sized to give a comfortable hit-target while
                     painting only a subtle 1px hairline at rest (see
                     App.GridSplitter in Resources/Components/GridSplitter.xaml).
                     Width is collapsed to 0 in review mode (handled in
                     ApplyReviewModeLayout in code-behind) so the splitter
                     doesn't leave a dead gutter floating between the
                     player and the editor. -->
                <ColumnDefinition x:Name="LeftSplitterColumn" Width="5" />
                <ColumnDefinition x:Name="VideoListColumn" Width="*" />
                <ColumnDefinition x:Name="PlayerColumn" Width="0" />
                <ColumnDefinition x:Name="EditorColumn" Width="460" MinWidth="420" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="10"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,0,1,0">
                <!-- Sidebar rail layout (Lightroom-style proportional split).
                     Each panel (FOLDERS / TAGS / CAMERAS) gets its own
                     star-sized row whose Height is bound through
                     BoolToStarOrAuto: true → 1*, false → Auto. So:
                       * All three expanded → each panel gets 1/3 of rail.
                       * Two collapsed → the one expanded takes all the
                         leftover space (the user's specific request:
                         "if I minimize Tags + Cameras, Folders should
                         maximize"). 
                       * All three collapsed → just headers stack at the
                         top, rest of the rail sits empty.
                     The two general view-mode toggles (Show only available
                     files / Show only unreviewed) live in the View menu
                     rather than the rail, to keep this surface purely the
                     FOLDERS / TAGS / CAMERAS filter stack.
                     There's no outer ScrollViewer here on purpose —
                     star sizing inside a ScrollViewer is meaningless
                     (the ScrollViewer offers infinite vertical space, so
                     * has nothing to share). Each panel relies on its
                     inner control (TreeView / ListBox) for content
                     scrolling once the panel itself is sized. -->
            <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{Binding IsFoldersPanelExpanded, Converter={StaticResource BoolToStarOrAuto}}" />
                        <RowDefinition Height="{Binding IsTagsPanelExpanded, Converter={StaticResource BoolToStarOrAuto}}" />
                        <RowDefinition Height="{Binding IsCamerasPanelExpanded, Converter={StaticResource BoolToStarOrAuto}}" />
                        <!-- DATE: Auto, not star — its content is just two pickers,
                             so it sizes to fit and lets the list panels above keep
                             the leftover height. -->
                        <RowDefinition Height="Auto" />
                        <!-- SAVED SEARCHES: Auto — a short, capped list sitting
                             below the filter panels it captures, just above the
                             Clear filters action. -->
                        <RowDefinition Height="Auto" />
                        <!-- Clear filters action, pinned at the rail bottom. -->
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                        <!-- SAVED SEARCHES expander (Smart Collections).
                             Header label + a "save current filters" action in
                             Expander.Tag. The body lists every saved search as a
                             clickable row that re-applies its criteria and re-runs
                             the catalog search live. Rename / delete sit inline on
                             each row. Collapse state persists via
                             AppSettings.SidebarSavedSearchesExpanded. -->
                        <Expander Grid.Row="4"
                                  Style="{StaticResource App.Expander}"
                                  IsExpanded="{Binding IsSavedSearchesPanelExpanded, Mode=TwoWay}">
                            <Expander.Header>
                                <TextBlock Text="{loc:Tr Main_Saved_Header}"
                                           Style="{StaticResource App.Type.Section}"
                                           Margin="0" />
                            </Expander.Header>
                            <Expander.Tag>
                                <Button Content="{loc:Tr Main_Saved_Save}"
                                        Style="{StaticResource App.Button.Ghost}"
                                        helpers:Theme.Icon="{StaticResource Icon.Save}"
                                        Height="24"
                                        FontSize="11"
                                        Padding="6,0"
                                        VerticalAlignment="Center"
                                        ToolTip="{loc:Tr Main_Saved_Save_Tip}"
                                        Command="{Binding SaveCurrentSearchCommand}" />
                            </Expander.Tag>
                            <Grid>
                                <!-- Empty state: shown until the user saves their
                                     first search. -->
                                <TextBlock Text="{loc:Tr Main_Saved_Empty}"
                                           Style="{StaticResource App.Type.BodyMuted}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,4"
                                           Visibility="{Binding SavedSearches.Count, Converter={StaticResource EmptyToVisibility}}" />

                                <!-- Capped, scrollable list so a long roster of
                                     saved searches never crowds out the filter
                                     panels below. -->
                                <ScrollViewer MaxHeight="220"
                                              VerticalScrollBarVisibility="Auto"
                                              Visibility="{Binding SavedSearches.Count, Converter={StaticResource NotEmptyToVisibility}}">
                                    <ItemsControl ItemsSource="{Binding SavedSearches}"
                                                  Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                                                    <!-- Apply row. Clicking re-applies the
                                                         saved criteria and re-runs the search.
                                                         Left padding (20) lines the funnel glyph
                                                         up with the folder-tree icons below
                                                         (2px border pad + 16px chevron column +
                                                         2px header margin) so the two panels read
                                                         as one consistent list. -->
                                                    <Button Grid.Column="0"
                                                            Style="{StaticResource App.Button.Ghost}"
                                                            HorizontalContentAlignment="Left"
                                                            Padding="20,3,6,3"
                                                            ToolTip="{Binding Name}"
                                                            Command="{Binding DataContext.ApplySavedSearchCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock FontFamily="{StaticResource App.Icon.FontFamily}"
                                                                       FontSize="12"
                                                                       Margin="0,0,8,0"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource App.Accent}"
                                                                       Text="{StaticResource Icon.Filter}" />
                                                            <TextBlock Text="{Binding Name}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                </StackPanel>
                                                    </Button>

                                                    <Button Grid.Column="1"
                                                            Style="{StaticResource App.Button.Ghost}"
                                                            helpers:Theme.Icon="{StaticResource Icon.Edit}"
                                                            Height="24"
                                                            Padding="6,0"
                                                            VerticalAlignment="Center"
                                                            ToolTip="{loc:Tr Main_Saved_Rename_Tip}"
                                                            Command="{Binding DataContext.RenameSavedSearchCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" />

                                                    <Button Grid.Column="2"
                                                            Style="{StaticResource App.Button.Ghost}"
                                                            helpers:Theme.Icon="{StaticResource Icon.Trash}"
                                                            Height="24"
                                                            Padding="6,0"
                                                            VerticalAlignment="Center"
                                                            ToolTip="{loc:Tr Main_Saved_Delete_Tip}"
                                                            Command="{Binding DataContext.DeleteSavedSearchCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" />
            </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Expander>
                        <!-- FOLDERS expander.
                             The section label sits in Expander.Header and the
                             trailing "Add folder" (+) affordance lives in
                             Expander.Tag, which the App.Expander template
                             routes to a content presenter outside the toggle
                             hit-area (so clicking + doesn't accidentally
                             collapse the section). When the expander is
                             collapsed the body — empty state + folder tree —
                             is hidden, freeing rail height for whichever
                             other panel the user is working with.
                             IsExpanded is TwoWay-bound to MainViewModel so
                             collapse state persists across launches via
                             AppSettings.SidebarFoldersExpanded. -->
                        <Expander Grid.Row="0"
                                  Style="{StaticResource App.Expander}"
                                  Margin="0"
                                  AllowDrop="True"
                                  DragEnter="FoldersPanel_OnDragEnter"
                                  DragOver="FoldersPanel_OnDragOver"
                                  DragLeave="FoldersPanel_OnDragLeave"
                                  Drop="FoldersPanel_OnDrop"
                                  IsExpanded="{Binding IsFoldersPanelExpanded, Mode=TwoWay}">
                            <Expander.Header>
                                <TextBlock Text="{loc:Tr Main_Folders_Header}"
                                           Style="{StaticResource App.Type.Section}"
                                           Margin="0" />
                            </Expander.Header>
                            <Expander.Tag>
                                <Button Style="{StaticResource App.Button.Ghost}"
                                        helpers:Theme.Icon="{StaticResource Icon.Add}"
                                        Height="24"
                                        FontSize="11"
                                        Padding="6,0"
                                        VerticalAlignment="Center"
                                        ToolTip="{loc:Tr Main_Folders_Add_Tip}"
                                        Command="{Binding AddRootFolderCommand}"
                                        Visibility="{Binding RootFolders.Count, Converter={StaticResource NotEmptyToVisibility}}" />
                            </Expander.Tag>
                            <!-- Body laid out as a Grid (Auto + *) so the TreeView
                                 stretches to fill the rail row when FOLDERS is
                                 the only expanded panel. The empty state at row 0
                                 only renders in the zero-folders edge case (its
                                 own Visibility binding) and otherwise contributes
                                 0 height — letting the tree have the full slot. -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Drag-and-drop affordance. Hidden until a folder
                                     drag enters the FOLDERS panel (toggled from the
                                     code-behind DragEnter/DragLeave handlers), then
                                     overlays the whole body with a dashed amber drop
                                     zone — the Lightroom/Bridge "drop a folder here to
                                     add it" cue. IsHitTestVisible is false so it never
                                     swallows the drop event from the panel beneath it. -->
                                <Border x:Name="FolderDropOverlay"
                                        Grid.Row="0"
                                        Grid.RowSpan="2"
                                        Panel.ZIndex="10"
                                        Visibility="Collapsed"
                                        IsHitTestVisible="False"
                                        Background="{DynamicResource App.Accent.Subtle}"
                                        BorderBrush="{DynamicResource App.Accent}"
                                        BorderThickness="1.5"
                                        CornerRadius="6"
                                        Margin="0,2"
                                        MinHeight="64">
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock FontFamily="{StaticResource App.Icon.FontFamily}"
                                                   FontSize="20"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource App.Accent}"
                                                   Text="{StaticResource Icon.Add}" />
                                        <TextBlock Text="{loc:Tr Main_Folders_Drop}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource App.Accent}" />
                                    </StackPanel>
        </Border>

                                <!-- First-run empty state: shown when no root folders are
                                     configured. Headline + subtext + a primary CTA that
                                     triggers the same Add folder picker as Ctrl+O / the
                                     File menu. Replaces the tree while empty. -->
                                <Border Grid.Row="0"
                                        Padding="0,4,0,8"
                                        Visibility="{Binding RootFolders.Count, Converter={StaticResource EmptyToVisibility}}">
                                    <helpers:EmptyState Glyph="{StaticResource Icon.Folder}"
                                                        Headline="{loc:Tr Main_Folders_Empty_Headline}"
                                                        Subtext="{loc:Tr Main_Folders_Empty_Subtext}"
                                                        CtaText="{loc:Tr Main_Folders_Empty_Cta}"
                                                        CtaIcon="{StaticResource Icon.Add}"
                                                        CtaCommand="{Binding AddRootFolderCommand}"
                                                        Padding="0" />
                                </Border>

                                <!-- Lightroom-style folder tree.
                                     ItemsSource is the hierarchical FolderTree built in
                                     MainViewModel.RebuildFolderTreeAsync. Selection /
                                     expansion are TwoWay-bound to FolderNode through
                                     App.TreeViewItem in Resources/Components/FolderTree.xaml.
                                     SelectedItemChanged (handled in code-behind) mirrors
                                     the TreeView's read-only SelectedItem onto the
                                     SelectedFolderNode property on the VM, which then
                                     flows into the catalog filter.
                                     No MaxHeight here: the parent Grid row's *
                                     sizing controls overall height. The TreeView's
                                     own ScrollViewer takes over once content
                                     exceeds the granted height. -->
                                <TreeView x:Name="FolderTreeView"
                                          Grid.Row="1"
                                          ItemsSource="{Binding FolderTree}"
                                          Style="{StaticResource App.TreeView}"
                                          Margin="0,4,0,0"
                                          VerticalAlignment="Stretch"
                                          SelectedItemChanged="FolderTreeView_OnSelectedItemChanged"
                                          Visibility="{Binding RootFolders.Count, Converter={StaticResource NotEmptyToVisibility}}">
                            <TreeView.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <!-- Visible only for nodes that map to a
                                         registered RootFolder entity. CanRemoveSelectedFolder
                                         on the VM gates Remove + the menu's enabled state
                                         so right-clicking an intermediate folder does
                                         nothing dangerous. -->
                                    <MenuItem Header="{loc:Tr Main_Folders_Ctx_Remove}"
                                              InputGestureText=""
                                              Command="{Binding RemoveRootFolderCommand}"
                                              CommandParameter="{Binding SelectedRootFolder}"
                                              IsEnabled="{Binding CanRemoveSelectedFolder}"
                                              ToolTip="{loc:Tr Main_Folders_Ctx_Remove_Tip}" />
                                    <Separator />
                                    <MenuItem Header="{loc:Tr Main_Folders_Ctx_Add}"
                                              InputGestureText="Ctrl+O"
                                              Command="{Binding AddRootFolderCommand}" />
                                </ContextMenu>
                            </TreeView.ContextMenu>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <Grid>
            <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
                                        <!-- Folder glyph. Drives use a "device"-ish
                                             open folder; registered roots and
                                             subfolders use the standard folder
                                             glyph. The visual distinction signals
                                             "you can right-click here to manage"
                                             vs "this is just a navigable folder". -->
                                        <TextBlock Grid.Column="0"
                                                   FontFamily="{StaticResource App.Icon.FontFamily}"
                                                   FontSize="13"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"
                                                   TextOptions.TextRenderingMode="ClearType">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{StaticResource Icon.Folder}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource App.Foreground.Secondary}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDriveRoot}" Value="True">
                                                            <Setter Property="Text" Value="{StaticResource Icon.FolderOpen}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource App.Accent}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRegisteredRoot}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource App.Accent}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource App.Foreground.Primary}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Normal" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDriveRoot}" Value="True">
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRegisteredRoot}" Value="True">
                                                            <Setter Property="FontWeight" Value="Medium" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Recursive video count. Mono so the
                                             numbers right-align cleanly when several
                                             folders stack with three-/four-digit
                                             totals. Hidden when 0 so empty
                                             subtrees stay quiet. -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding VideoCount}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"
                                                   FontFamily="{StaticResource App.FontFamily.Mono}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource App.Foreground.Tertiary}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VideoCount}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </Grid>
                        </Expander>

                        <!-- TAGS expander. Same chrome family as FOLDERS:
                             section label in the header, "Clear" ghost
                             button in Expander.Tag (so it stays clickable
                             without toggling the section).
                             The chip strip + filter input + picker list
                             live in the body and disappear together when
                             the user collapses the section. The chips
                             ARE active filter state, so collapsing the
                             panel doesn't drop the filters; reopening
                             reveals them unchanged. -->
                        <Expander Grid.Row="1"
                                  Style="{StaticResource App.Expander}"
                                  IsExpanded="{Binding IsTagsPanelExpanded, Mode=TwoWay}">
                            <Expander.Header>
                                <TextBlock Text="{loc:Tr Main_Tags_Header}"
                                           Style="{StaticResource App.Type.Section}"
                                           Margin="0" />
                            </Expander.Header>
                            <Expander.Tag>
                                <Button Content="{loc:Tr Main_Filter_Clear}"
                                        Style="{StaticResource App.Button.Ghost}"
                                        Height="24"
                                        FontSize="11"
                                        Padding="8,0"
                                        VerticalAlignment="Center"
                                        ToolTip="{loc:Tr Main_Tags_Clear_Tip}"
                                        Command="{Binding ClearTagFiltersCommand}" />
                            </Expander.Tag>
                            <!-- Body Grid: chips (Auto) + filter input (Auto)
                                 + picker list (*). The list takes whatever
                                 height is left over so when TAGS is the only
                                 expanded panel, the picker fills the rail. -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <ItemsControl Grid.Row="0"
                                              ItemsSource="{Binding SelectedTagFilters}"
                                              Margin="0,0,0,4">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                            <Border Style="{StaticResource App.TagChip}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               Style="{StaticResource App.TagChip.Text}" />
                                                    <Button Style="{StaticResource App.Button.ChipClose}"
                                                            helpers:Theme.Icon="{StaticResource Icon.Cancel}"
                                                            Margin="6,0,-2,0"
                                                            ToolTip="{loc:Tr Main_Tags_RemoveChip_Tip}"
                                                            Command="{Binding DataContext.RemoveTagFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" />
                                    </StackPanel>
                                            </Border>
                                </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBox Grid.Row="1"
                                         Text="{Binding TagFilterSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ui:ControlHelper.PlaceholderText="{loc:Tr Main_Tags_FilterPlaceholder}"
                                         Margin="0,0,0,4" />

                                <!-- MinHeight ensures the picker stays usable
                                     even when TAGS is sharing rail space
                                     with two other expanded panels on a
                                     short window. The list's own
                                     ScrollViewer takes over once content
                                     exceeds the granted height. -->
                                <ListBox x:Name="TagFilterList"
                                         Grid.Row="2"
                                         ItemsSource="{Binding FilteredTags}"
                                         MinHeight="120"
                                         DisplayMemberPath="Name"
                                         Style="{StaticResource App.ListBox}"
                                         VerticalAlignment="Stretch"
                                         SelectionChanged="TagFilterList_OnSelectionChanged"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         ToolTip="{loc:Tr Main_Tags_List_Tip}" />
                            </Grid>
                        </Expander>

                        <!-- CAMERAS expander. Last sidebar panel; matches
                             the FOLDERS / TAGS chrome. -->
                        <Expander Grid.Row="2"
                                  Style="{StaticResource App.Expander}"
                                  IsExpanded="{Binding IsCamerasPanelExpanded, Mode=TwoWay}">
                            <Expander.Header>
                                <TextBlock Text="{loc:Tr Main_Cameras_Header}"
                                           Style="{StaticResource App.Type.Section}"
                                           Margin="0" />
                            </Expander.Header>
                            <Expander.Tag>
                                <Button Content="{loc:Tr Main_Filter_Clear}"
                                        Style="{StaticResource App.Button.Ghost}"
                                        Height="24"
                                        FontSize="11"
                                        Padding="8,0"
                                        VerticalAlignment="Center"
                                        ToolTip="{loc:Tr Main_Cameras_Clear_Tip}"
                                        Command="{Binding ClearCameraFilterCommand}" />
                            </Expander.Tag>
                            <!-- MinHeight keeps the camera picker usable in
                                 the 3-panel-expanded layout; VerticalAlignment
                                 Stretch lets it fill the row when it's the
                                 only expanded panel. -->
                        <ListBox ItemsSource="{Binding Cameras}"
                                 SelectedItem="{Binding CameraFilter}"
                                     Style="{StaticResource App.ListBox}"
                                     MinHeight="100"
                                     VerticalAlignment="Stretch" />
                        </Expander>

                        <!-- DATE expander. The From / To date-range filter moved
                             here from the top toolbar — dates are a refining
                             filter and belong with the other sidebar filters.
                             Content is two stacked pickers, so this row is Auto
                             (sizes to fit) rather than star. -->
                        <Expander Grid.Row="3"
                                  Style="{StaticResource App.Expander}"
                                  IsExpanded="{Binding IsDatePanelExpanded, Mode=TwoWay}">
                            <Expander.Header>
                                <TextBlock Text="{loc:Tr Main_Date_Header}"
                                           Style="{StaticResource App.Type.Section}"
                                           Margin="0" />
                            </Expander.Header>
                            <!-- Clear ghost button mirrors TAGS / CAMERAS so every
                                 sidebar panel header carries a 24px trailing control
                                 and the panels keep an even vertical rhythm. Disabled
                                 (greyed) until a From / To date is set. -->
                            <Expander.Tag>
                                <Button Content="{loc:Tr Main_Filter_Clear}"
                                        Style="{StaticResource App.Button.Ghost}"
                                        Height="24"
                                        FontSize="11"
                                        Padding="8,0"
                                        VerticalAlignment="Center"
                                        ToolTip="{loc:Tr Main_Date_Clear_Tip}"
                                        Command="{Binding ClearDateFilterCommand}" />
                            </Expander.Tag>
                            <StackPanel>
                                <DatePicker Margin="0,0,0,6"
                                            FontSize="13"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            CalendarStyle="{StaticResource App.Calendar}"
                                            SelectedDate="{Binding DateFrom}"
                                            ui:ControlHelper.PlaceholderText="{loc:Tr Main_Date_From}" />
                                <DatePicker FontSize="13"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            CalendarStyle="{StaticResource App.Calendar}"
                                            SelectedDate="{Binding DateTo}"
                                            ui:ControlHelper.PlaceholderText="{loc:Tr Main_Date_To}" />
                    </StackPanel>
                        </Expander>

                        <!-- Clear filters: resets the search box, folder/tag/camera
                             selection, and the date range. Pinned at the rail
                             bottom beneath the filter stack it resets. Mirrors
                             View → Clear all filters (Ctrl+Shift+L). -->
                        <Button Grid.Row="5"
                                Content="{loc:Tr Main_ClearFilters}"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Stretch"
                                Command="{Binding ClearFiltersCommand}"
                                Style="{StaticResource App.Button.Ghost}"
                                helpers:Theme.Icon="{StaticResource Icon.Filter}"
                                ToolTip="{loc:Tr Main_ClearFilters_Tip}" />
                    </Grid>
            </Border>

            <!-- Drag handle between the sidebar and the catalog grid.
                 Width persistence: Thumb.DragCompleted in code-behind
                 reads the post-drag column width and writes it back to
                 settings via MainViewModel.PersistSidebarWidthAsync. -->
            <GridSplitter x:Name="LeftSplitter"
                          Grid.Column="1"
                          Style="{StaticResource App.GridSplitter}"
                          Thumb.DragCompleted="LeftSplitter_OnDragCompleted" />

            <!-- Zero-results overlay: shows when Videos is empty (initial scan
                 not run yet, or filters returning nothing). Sits in the same
                 grid cell as the catalog so it overlays the empty area
                 without affecting the layout.
                 Panel.ZIndex="1" lifts the overlay above the ListBox so its
                 "Clear filters" CTA actually receives clicks — the ListBox
                 has Background="Transparent" which is hit-test visible in
                 WPF, and being later in document order it would otherwise
                 swallow clicks aimed at the empty-state button. -->
            <helpers:EmptyState Grid.Column="2"
                                Panel.ZIndex="1"
                                Glyph="{StaticResource Icon.Search}"
                                Headline="{loc:Tr Main_NoClips_Headline}"
                                Subtext="{loc:Tr Main_NoClips_Subtext}"
                                CtaText="{loc:Tr Main_ClearFilters}"
                                CtaIcon="{StaticResource Icon.Filter}"
                                CtaCommand="{Binding ClearFiltersCommand}"
                                Visibility="{Binding Videos.Count, Converter={StaticResource EmptyToVisibility}}" />

            <ListBox Grid.Column="2"
                     x:Name="VideoListBox"
                     ItemsSource="{Binding Videos}"
                     SelectedItem="{Binding SelectedVideo}"
                     SelectionMode="Extended"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="6"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.IsDeferredScrollingEnabled="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     SelectionChanged="VideoList_OnSelectionChanged"
                     HorizontalContentAlignment="Stretch"
                     ItemContainerStyle="{StaticResource App.VideoCard.ItemStyle}">
                <ListBox.InputBindings>
                    <KeyBinding Key="Delete"
                                Command="{Binding RemoveSelectedVideosCommand}" />
                </ListBox.InputBindings>
                <ListBox.ContextMenu>
                    <!-- Context menu DataContext is the ListBox's DataContext (MainViewModel),
                         so we can reach Detail.OpenFileLocationCommand directly. The Open
                         and Remove commands both operate on the current selection — make
                         sure the right-clicked clip is actually selected first. -->
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="{loc:Tr Main_Ctx_ShowInfo}"
                                  InputGestureText="Alt+Enter"
                                  Command="{Binding Detail.ShowInfoCommand}"
                                  ToolTip="{loc:Tr Main_Ctx_ShowInfo_Tip}" />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Ctx_PlayExternal}"
                                  Command="{Binding Detail.PlayCommand}"
                                  ToolTip="{loc:Tr Main_Ctx_PlayExternal_Tip}" />
                        <MenuItem Header="{loc:Tr Main_Ctx_OpenLocation}"
                                  Command="{Binding Detail.OpenFileLocationCommand}"
                                  ToolTip="{loc:Tr Main_Ctx_OpenLocation_Tip}" />
                        <Separator />
                        <MenuItem Header="{loc:Tr Main_Ctx_RemoveDb}"
                                  InputGestureText="Del"
                                  Command="{Binding RemoveSelectedVideosCommand}" />
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemsPanel>
                    <!-- Custom adaptive panel: derives the column count from the
                         available width and MinItemWidth, then gives every cell in
                         a row the same width so cards exactly fill the catalog
                         column at any window size (no leftover gutter on the right). -->
                    <ItemsPanelTemplate>
                        <controls:AdaptiveWrapPanel MinItemWidth="240" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- Width is no longer fixed: AdaptiveWrapPanel sizes each
                             card to availableWidth / columnCount. The thumbnail
                             box keeps a true 16:9 shape by binding its Height to
                             its own ActualWidth via WidthTo16x9Height. -->
                            <StackPanel>
                            <!-- Double-clicking the thumbnail mirrors the sidebar
                                 "Play in app" button — see Thumbnail_OnMouseLeftButtonDown. -->
                            <Border Style="{StaticResource App.VideoCard.Thumbnail}"
                                    MouseLeftButtonDown="Thumbnail_OnMouseLeftButtonDown"
                                    MouseMove="Thumbnail_OnMouseMove"
                                    MouseLeave="Thumbnail_OnMouseLeave">
                                <Grid Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}, Converter={StaticResource WidthTo16x9Height}}">
                                    <Image Source="{Binding Thumbnail}"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch" />
                                    <!-- Hover-scrub overlay: when the pointer sweeps the card,
                                         the code-behind sets ScrubFrame to the frame under the
                                         cursor. Null (not scrubbing) collapses it so the static
                                         thumbnail shows. IsHitTestVisible=False so it never
                                         interferes with the Border's mouse tracking. -->
                                    <Image Source="{Binding ScrubFrame}"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           IsHitTestVisible="False"
                                           Visibility="{Binding ScrubFrame, Converter={StaticResource NullToVisibility}}" />
                                    <!-- Subtle gradient at the bottom keeps the duration
                                         badge legible over light frames without a
                                         hard solid black bar. -->
                                    <Border VerticalAlignment="Bottom"
                                            Height="40"
                                            IsHitTestVisible="False">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0" />
                                                <GradientStop Color="#A0000000" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border VerticalAlignment="Bottom"
                                            HorizontalAlignment="Right"
                                            Background="#A0000000"
                                            Padding="6,2"
                                            CornerRadius="3"
                                            Margin="6">
                                        <TextBlock Text="{Binding DurationText}"
                                                   Foreground="White"
                                                   FontFamily="{StaticResource App.FontFamily.Mono}"
                                                   FontSize="11" />
                                    </Border>
                                    <!-- Tag indicator: a small tag glyph in the bottom-left
                                         marks clips that carry tags, so a tagged-vs-untagged
                                         scan is possible at a glance. Hidden when the clip has
                                         no tags; the tooltip lists them. -->
                                    <Border VerticalAlignment="Bottom"
                                            HorizontalAlignment="Left"
                                            Background="#A0000000"
                                            Padding="6,3"
                                            CornerRadius="3"
                                            Margin="6"
                                            ToolTip="{Binding TagSummary}"
                                            Visibility="{Binding HasTags, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="&#xE8EC;"
                                                   FontFamily="{StaticResource App.Icon.FontFamily}"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#C0000000"
                                            Padding="8,4"
                                            CornerRadius="4"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding FileExists, Converter={StaticResource BoolToVisibilityInverted}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="{StaticResource App.Icon.FontFamily}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource App.Warning}"
                                                       Text="&#xE783;"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0" />
                                        <TextBlock Text="{loc:Tr Main_Offline}"
                                                   Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="11"
                                                       VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                                </Grid>
                            </Border>
                            <!-- Card is intentionally just the thumbnail + duration
                                 badge: a clean visual grid with no text. Filename,
                                 resolution, camera, tags, status and rating all live
                                 in the editor pane / clip-info popup (Alt+Enter) and
                                 are managed externally (DaVinci, Lightroom, Bridge). -->
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Player column (review mode). Width=0 normally; expanded by code-behind
                 to fill space when Detail.IsPlayerVisible flips to true.
                 ffme:MediaElement is a real WPF visual (renders decoded frames
                 to a WriteableBitmap) so it has no HwndHost / class-brush /
                 DXGI-leak issues that the previous LibVLCSharp VideoView did.
                 Stretch="Uniform" + Background="Black" handles the letterbox
                 strip natively in WPF — no AspectRatioPanel needed.
                 Opacity is animated 0→1 over 240ms when IsPlayerVisible
                 flips to true (see Style.Triggers below) so the column
                 reveal feels cinematic rather than abrupt. The column
                 width swap itself is still instantaneous (animating
                 GridLength would require a custom AnimationTimeline; the
                 cross-fade gives 90% of the perceived smoothness without
                 that cost). -->
            <Border Grid.Column="3"
                    Background="Black"
                    DataContext="{Binding Detail}"
                    Opacity="0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPlayerVisible}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.24">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid x:Name="PlayerArea">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ffme:MediaElement x:Name="VideoPlayer"
                                       Grid.Row="0"
                                       Stretch="Uniform"
                                       Background="Black"
                                       LoadedBehavior="Manual"
                                       UnloadedBehavior="Manual"
                                       ScrubbingEnabled="True"
                                       VerticalSyncEnabled="True" />

                    <!-- EXPERIMENTAL GPU player. Collapsed by default; code-behind
                         makes it Visible (and hides the FFME element above) when
                         App.UseMpvPlayer is true (libmpv present in tools/mpv/).
                         mpv renders GPU video into this child window and clears to
                         black, so 4K60 plays at real-time with black letterbox bars
                         instead of FFME's CPU-bound slow motion. -->
                    <controls:MpvVideoView x:Name="MpvPlayer"
                                           Grid.Row="0"
                                           Visibility="Collapsed" />

                    <!-- Floating close (X) anchored to the video's top-right
                         corner. Reviewers instinctively reach for the corner to
                         dismiss the player, so the affordance lives there.

                         It is hosted in a Popup (its own top-level HWND) rather
                         than as an in-grid overlay so it is GUARANTEED to render
                         above the picture on BOTH engines — the default FFME
                         WriteableBitmap path AND the experimental mpv child-window
                         (airspace) path, where in-grid WPF content is hidden.

                         The zero-size CloseAnchor pins the Popup to the corner;
                         the Popup's IsOpen is driven from code-behind so it only
                         shows while the player is visible AND the window is active
                         (so it never floats over other apps when you alt-tab). -->
                    <Border x:Name="CloseAnchor"
                            Grid.Row="0"
                            Width="0" Height="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,14,14,0" />
                    <Popup x:Name="ClosePlayerPopup"
                           PlacementTarget="{Binding ElementName=CloseAnchor}"
                           Placement="Left"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           StaysOpen="True">
                        <Button Width="34" Height="34"
                                Cursor="Hand"
                                Command="{Binding ClosePlayerCommand}"
                                ToolTip="{loc:Tr Main_Player_Close_Tip}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg"
                                            CornerRadius="17"
                                            Background="#99000000">
                                        <TextBlock Text="{StaticResource Icon.Close}"
                                                   FontFamily="{StaticResource App.Icon.FontFamily}"
                                                   FontSize="15"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#E6E15050" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Popup>

                    <!-- Marker capture overlay. Hosted in a Popup (its own HWND) for
                         the same reason as the close button: it must composite ABOVE
                         the video on BOTH the FFME WriteableBitmap path AND the
                         experimental mpv child-window (airspace) path, where in-grid
                         WPF content is hidden. Floats at the top-centre of the frame
                         (custom placement callback in code-behind) so the reviewer's
                         eyes — already on the picture — can't miss it. Code-behind
                         pulses it while an in-point is armed and flashes a green
                         confirmation when a moment / marker is saved, so an O press
                         is unmistakably registered. IsHitTestVisible=False keeps it
                         click-through. -->
                    <Popup x:Name="MarkerOverlayPopup"
                           PlacementTarget="{Binding ElementName=PlayerArea}"
                           Placement="Custom"
                           AllowsTransparency="True"
                           Focusable="False"
                           StaysOpen="True">
                        <Border x:Name="MarkerOverlayPill"
                                CornerRadius="10"
                                Padding="20,12"
                                Background="#D9000000"
                                BorderThickness="2"
                                BorderBrush="{DynamicResource App.Accent}"
                                RenderTransformOrigin="0.5,0.5"
                                IsHitTestVisible="False">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="MarkerOverlayScale" ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="MarkerOverlayGlyph"
                                           Text="&#x25CF;"
                                           FontSize="24"
                                           Margin="0,0,14,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource App.Accent}" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="MarkerOverlayTitle"
                                               Text="IN POINT SET"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="White" />
                                    <TextBlock x:Name="MarkerOverlaySubtitle"
                                               Text="00:00"
                                               FontSize="13"
                                               FontFamily="Consolas"
                                               Foreground="#E6FFFFFF" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- DJI telemetry strip. Sits in its OWN row directly under
                         the picture (NOT painted over the video) on purpose:
                         the mpv player draws into a Win32 child window whose
                         HWND composites above all WPF content in its rectangle
                         (the same "airspace" rule that keeps the map's chrome
                         below the map, see the LocationMapView note above), so a
                         readout overlaid on the frame would be invisible on the
                         GPU path. Bound fields come from VideoDetailViewModel,
                         refreshed every player tick via UpdateTelemetryForPosition;
                         each chip hides itself when its value is null so the strip
                         adapts to whatever the clip's SRT actually carries.
                         IsTelemetryStripVisible gates the whole row (player open
                         + telemetry present + user toggle on). -->
                    <Border Grid.Row="1"
                            Background="#0FFFFFFF"
                            BorderBrush="{DynamicResource App.Border.Subtle}"
                            BorderThickness="0,1,0,0"
                            Padding="12,7"
                            Visibility="{Binding IsTelemetryStripVisible, Converter={StaticResource BoolToVisibility}}">
                        <WrapPanel Orientation="Horizontal">
                            <WrapPanel.Resources>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Orientation" Value="Horizontal" />
                                    <Setter Property="Margin" Value="0,2,20,2" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                                <Style x:Key="TelemetryLabel" TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource App.Foreground.Secondary}" />
                                    <Setter Property="FontSize" Value="10" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Margin" Value="0,0,6,0" />
                                </Style>
                                <Style x:Key="TelemetryValue" TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontFamily" Value="Consolas" />
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </WrapPanel.Resources>

                            <StackPanel Visibility="{Binding TelemetryIso, Converter={StaticResource NullToVisibility}}">
                                <TextBlock Text="{loc:Tr Main_Tel_Iso}" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding TelemetryIso}" Style="{StaticResource TelemetryValue}" />
                            </StackPanel>
                            <StackPanel Visibility="{Binding TelemetryShutter, Converter={StaticResource NullToVisibility}}">
                                <TextBlock Text="{loc:Tr Main_Tel_Shutter}" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding TelemetryShutter}" Style="{StaticResource TelemetryValue}" />
                            </StackPanel>
                            <StackPanel Visibility="{Binding TelemetryAperture, Converter={StaticResource NullToVisibility}}">
                                <TextBlock Text="{loc:Tr Main_Tel_Aperture}" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding TelemetryAperture}" Style="{StaticResource TelemetryValue}" />
                            </StackPanel>
                            <StackPanel Visibility="{Binding TelemetryFocalLength, Converter={StaticResource NullToVisibility}}">
                                <TextBlock Text="{loc:Tr Main_Tel_Focal}" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding TelemetryFocalLength}" Style="{StaticResource TelemetryValue}" />
                            </StackPanel>
                            <StackPanel Visibility="{Binding TelemetryAltitude, Converter={StaticResource NullToVisibility}}">
                                <TextBlock Text="{loc:Tr Main_Tel_Alt}" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding TelemetryAltitude}" Style="{StaticResource TelemetryValue}" />
                            </StackPanel>
                            <StackPanel Visibility="{Binding TelemetryGps, Converter={StaticResource NullToVisibility}}">
                                <TextBlock Text="{loc:Tr Main_Tel_Gps}" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding TelemetryGps}" Style="{StaticResource TelemetryValue}" />
                            </StackPanel>
                        </WrapPanel>
                    </Border>

                    <!-- Player toolbar. Visible only in review mode (IsPlayerVisible),
                         but we also hide it via column width=0 in normal mode so this
                         binding is mostly belt-and-braces.
                         Black background matches the player column so the transport row
                         visually flows into the video frame instead of dropping a bright
                         chrome panel under the picture; time-readout text is explicitly
                         white so it stays legible on the dark backdrop. -->
                    <Border Grid.Row="2"
                            Background="Black"
                            Padding="12,8"
                            Visibility="{Binding IsPlayerVisible, Converter={StaticResource BoolToVisibility}}">
                            <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Seek bar row: current time first, full-width
                                 slider in the middle, duration last. The time
                                 columns are auto-width and the slider takes the
                                 rest, so the row spans the full panel width with
                                 the readouts flanking the bar at each end. -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="PlayerCurrentTimeText" Grid.Column="0"
                                           Text="00:00" FontFamily="Consolas"
                                           Foreground="White"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right" />
                                <Slider x:Name="PlayerSeekSlider" Grid.Column="1"
                                        Margin="10,0,10,0"
                                        Minimum="0" Maximum="1000"
                                        SmallChange="5" LargeChange="50"
                                        IsMoveToPointEnabled="True"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource App.SeekSlider}"
                                        Thumb.DragStarted="PlayerSeekSlider_DragStarted"
                                        Thumb.DragCompleted="PlayerSeekSlider_DragCompleted"
                                        PreviewMouseLeftButtonDown="PlayerSeekSlider_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="PlayerSeekSlider_PreviewMouseLeftButtonUp" />
                                <TextBlock x:Name="PlayerDurationText" Grid.Column="2"
                                           Text="00:00" FontFamily="Consolas"
                                           Foreground="White"
                                           VerticalAlignment="Center"
                                           TextAlignment="Left" />
                            </Grid>

                            <!-- Buttons row. Outer Grid lets the PROXY chip float at
                                 the left while the transport WrapPanel stays centered
                                 within the full toolbar width — same visual rhythm
                                 regardless of whether a proxy is active. The chip is
                                 visibility-bound to Detail.IsPlayingProxy so it's
                                 entirely absent for non-proxy playback (no layout
                                 reservation) and pops in only when a substitution
                                 actually happened. -->
                            <Grid Grid.Row="1">
                                <!-- Source badge. The PROXY chip (amber) and the
                                     ORIGINAL chip (green) share the left slot and
                                     are mutually exclusive on IsPlayingProxy, so
                                     there's always a chip telling the reviewer at a
                                     glance whether they're watching a transcoded
                                     proxy or the full-resolution source file. -->
                                <Border HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource App.Accent.Subtle}"
                                        BorderBrush="{DynamicResource App.Accent}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="6,2"
                                        Visibility="{Binding IsPlayingProxy, Converter={StaticResource BoolToVisibility}}"
                                        ToolTip="{Binding ActiveProxyPath, StringFormat='Playing proxy: {0}'}">
                                    <TextBlock Text="{loc:Tr Main_Player_ProxyBadge}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource App.Accent}" />
                                </Border>
                                <Border HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="#1F3DDC84"
                                        BorderBrush="#3DDC84"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="6,2"
                                        Visibility="{Binding IsPlayingProxy, Converter={StaticResource BoolToVisibilityInverted}}"
                                        ToolTip="{loc:Tr Main_Player_Original_Tip}">
                                    <TextBlock Text="{loc:Tr Main_Player_OriginalBadge}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#3DDC84" />
                                </Border>
                                <WrapPanel HorizontalAlignment="Center" ItemHeight="40">
                                    <Button Margin="0,4,0,4"
                                            Command="{Binding DataContext.PlayPreviousCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Style="{StaticResource App.Button.IconOnly}"
                                            helpers:Theme.Icon="{StaticResource Icon.Previous}"
                                            ToolTip="{loc:Tr Main_Player_PrevClip_Tip}" />
                                    <Button Margin="6,4,0,4"
                                            Click="PlayerSkipBack_Click"
                                            Style="{StaticResource App.Button.IconOnly}"
                                            helpers:Theme.Icon="{StaticResource Icon.SkipBack}"
                                            ToolTip="{loc:Tr Main_Player_SkipBack_Tip}" />
                                    <Button x:Name="PlayPauseButton"
                                            Content="{loc:Tr Main_Player_Pause}"
                                            MinWidth="110"
                                            Margin="6,4,0,4"
                                            Click="PlayerPlayPause_Click"
                                            Style="{StaticResource App.Button.Primary}"
                                            helpers:Theme.Icon="{StaticResource Icon.Pause}"
                                            ToolTip="{loc:Tr Main_Player_PlayPause_Tip}" />
                                    <Button Margin="6,4,0,4"
                                            Click="PlayerSkipForward_Click"
                                            Style="{StaticResource App.Button.IconOnly}"
                                            helpers:Theme.Icon="{StaticResource Icon.SkipForward}"
                                            ToolTip="{loc:Tr Main_Player_SkipForward_Tip}" />
                                    <Button Margin="6,4,0,4"
                                            Command="{Binding DataContext.PlayNextCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Style="{StaticResource App.Button.IconOnly}"
                                            helpers:Theme.Icon="{StaticResource Icon.Next}"
                                            ToolTip="{loc:Tr Main_Player_NextClip_Tip}" />
                                    <Button Content="{loc:Tr Main_Player_Stop}" MinWidth="80" Margin="6,4,0,4"
                                            Click="PlayerStop_Click"
                                            Style="{StaticResource App.Button.Secondary}"
                                            helpers:Theme.Icon="{StaticResource Icon.Stop}"
                                            ToolTip="{loc:Tr Main_Player_Stop_Tip}" />
                                    <!-- Moment capture: stamp the in / out points of a
                                         shot at the current playback position. Same
                                         action as the I / O keys; kept on the bar so the
                                         gesture is discoverable without the shortcut. -->
                                    <Button Content="{loc:Tr Main_Player_MarkIn}" MinWidth="78" Margin="16,4,0,4"
                                            Click="PlayerMarkIn_Click"
                                            Style="{StaticResource App.Button.Secondary}"
                                            ToolTip="{loc:Tr Main_Player_MarkIn_Tip}" />
                                    <Button Content="{loc:Tr Main_Player_MarkOut}" MinWidth="84" Margin="6,4,0,4"
                                            Click="PlayerMarkOut_Click"
                                            Style="{StaticResource App.Button.Secondary}"
                                            ToolTip="{loc:Tr Main_Player_MarkOut_Tip}" />
                                </WrapPanel>
                            </Grid>

                            <!-- Marker workflow status: "In point 00:01:12 — press O
                                 to set the out point", "Moment added 00:01:12 → 00:01:20",
                                 etc. Collapses when there's nothing to say. -->
                            <TextBlock Grid.Row="2"
                                       Margin="0,6,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{DynamicResource App.Accent}"
                                       Text="{Binding MomentMarkStatus}"
                                       Visibility="{Binding MomentMarkStatus, Converter={StaticResource NullToVisibility}}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Editor column. The left 1px separator visually divides the
                 catalog grid from the editor in normal mode, but draws an
                 unwanted pale line down the right edge of the in-app player
                 in review mode, so it's collapsed while IsPlayerVisible. -->
            <Border Grid.Column="4"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderThickness" Value="1,0,0,0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Detail.IsPlayerVisible}" Value="True">
                                <Setter Property="BorderThickness" Value="0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <helpers:EmptyState Glyph="{StaticResource Icon.Movie}"
                                        Headline="{loc:Tr Main_NoClipSelected_Headline}"
                                        Subtext="{loc:Tr Main_NoClipSelected_Subtext}"
                                        Visibility="{Binding Detail.Current, Converter={StaticResource NullToVisibilityInverted}}" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding Detail.Current, Converter={StaticResource NullToVisibility}}">
                        <StackPanel Margin="16" DataContext="{Binding Detail}">

                            <!-- ===== MAP panel ===== -->
                            <Expander Margin="0"
                                      Style="{StaticResource App.Expander}"
                                      Visibility="{Binding IsMapVisible, Converter={StaticResource BoolToVisibility}}"
                                      IsExpanded="{Binding DataContext.IsDetailMapPanelExpanded, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                <Expander.Header>
                                    <TextBlock Text="{loc:Tr Main_Editor_Map_Header}" Style="{StaticResource App.Type.Section}" Margin="0" />
                                </Expander.Header>
                                <StackPanel>
                            <!-- Location preview. Always rendered (the control itself
                                 handles the "no GPS" state by falling back to a
                                 grayscaled regional view) so the sidebar layout stays
                                 stable across clips with and without coordinates.
                                 Hidden in review mode because the in-app player owns
                                 its own column and the sidebar focuses on tags /
                                 notes / status in that mode. See LocationMapView
                                 for the WebView2 / Leaflet lifecycle.

                                 The map's affordances (Set / Edit / Clear / Copy /
                                 pick-mode TextBox + Save + Cancel) intentionally
                                 live in the sibling Grid *below* this Border, not
                                 overlaid on top: WebView2's hosted Chromium HWND
                                 paints above all WPF content in its rectangle, so
                                 WPF buttons drawn over the map would be invisible
                                 / unclickable (the classic WPF "airspace" issue).
                                 Pick mode itself still hits the map directly —
                                 the embedded JS click handler posts coords back
                                 over the WebMessage bridge, so the map remains
                                 the primary input surface even though the
                                 chrome around it is plain WPF. -->
                            <Border Margin="0,0,0,8"
                                    Height="180"
                                    CornerRadius="4"
                                    ClipToBounds="True"
                                    Background="#1E1E1E"
                                    BorderBrush="{DynamicResource App.Border.Subtle}"
                                    BorderThickness="1"
                                    Visibility="{Binding IsMapVisible, Converter={StaticResource BoolToVisibility}}">
                                <controls:LocationMapView x:Name="LocationMap"
                                                          Latitude="{Binding Current.GpsLatitude}"
                                                          Longitude="{Binding Current.GpsLongitude}"
                                                          FlightPath="{Binding FlightPath}"
                                                          DronePosition="{Binding DronePosition}"
                                                          IsPickingMode="{Binding IsPickingLocation}"
                                                          LocationPicked="LocationMap_OnLocationPicked" />
                            </Border>

                            <!-- Location actions row, three mutually exclusive states
                                 stacked into the same logical slot via nested
                                 Visibility Borders (same pattern as elsewhere in
                                 the editor). Hidden in review mode for symmetry
                                 with the map above. -->
                            <Grid Margin="0,0,0,16"
                                  Visibility="{Binding IsPlayerVisible, Converter={StaticResource BoolToVisibilityInverted}}">

                                <!-- State A: no GPS, not picking → primary CTA. -->
                                <Border Visibility="{Binding Current.HasGps, Converter={StaticResource BoolToVisibilityInverted}}">
                                    <Border Visibility="{Binding IsPickingLocation, Converter={StaticResource BoolToVisibilityInverted}}">
                                        <Button Content="{loc:Tr Main_Editor_Loc_Set}"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding BeginPickLocationCommand}"
                                                Style="{StaticResource App.Button.Primary}"
                                                helpers:Theme.Icon="{StaticResource Icon.Add}"
                                                ToolTip="{loc:Tr Main_Editor_Loc_Set_Tip}" />
                                    </Border>
                                </Border>

                                <!-- State B: GPS exists, not picking → inline action row. -->
                                <Border Visibility="{Binding Current.HasGps, Converter={StaticResource BoolToVisibility}}">
                                    <Border Visibility="{Binding IsPickingLocation, Converter={StaticResource BoolToVisibilityInverted}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="{loc:Tr Main_Editor_Loc_Edit}"
                                                    Command="{Binding BeginPickLocationCommand}"
                                                    Style="{StaticResource App.Button.Secondary}"
                                                    helpers:Theme.Icon="{StaticResource Icon.Edit}"
                                                    ToolTip="{loc:Tr Main_Editor_Loc_Edit_Tip}" />
                                            <Button Content="{loc:Tr Main_Filter_Clear}"
                                                    Margin="6,0,0,0"
                                                    Command="{Binding ClearLocationCommand}"
                                                    Style="{StaticResource App.Button.Ghost}"
                                                    helpers:Theme.Icon="{StaticResource Icon.Trash}"
                                                    ToolTip="{loc:Tr Main_Editor_Loc_Clear_Tip}" />
                                            <Button Content="{loc:Tr Main_Editor_Loc_Copy}"
                                                    Margin="6,0,0,0"
                                                    Command="{Binding CopyLocationCommand}"
                                                    Style="{StaticResource App.Button.Ghost}"
                                                    helpers:Theme.Icon="{StaticResource Icon.Copy}"
                                                    ToolTip="{loc:Tr Main_Editor_Loc_Copy_Tip}" />
                                        </StackPanel>
                                    </Border>
                                </Border>

                                <!-- State C: picking → TextBox + Save + Cancel. -->
                                <Border Visibility="{Binding IsPickingLocation, Converter={StaticResource BoolToVisibility}}">
                                    <Grid>
                                <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                        <TextBox Grid.Row="0"
                                                 Text="{Binding PendingCoordsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalContentAlignment="Center"
                                                 FontFamily="{StaticResource App.FontFamily.Mono}"
                                                 FontSize="12"
                                                 ToolTip="{loc:Tr Main_Editor_Loc_Pick_Tip}"
                                                 ui:ControlHelper.PlaceholderText="{loc:Tr Main_Editor_Loc_Pick_Placeholder}" />
                                        <StackPanel Grid.Row="1"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,6,0,0">
                                            <Button Content="{loc:Tr Common_Cancel}"
                                                    Command="{Binding CancelPickLocationCommand}"
                                                    Style="{StaticResource App.Button.Ghost}"
                                                    helpers:Theme.Icon="{StaticResource Icon.Cancel}" />
                                            <Button Content="{loc:Tr Common_Save}"
                                                    Margin="6,0,0,0"
                                                    Command="{Binding SaveLocationCommand}"
                                                    Style="{StaticResource App.Button.Primary}"
                                                    helpers:Theme.Icon="{StaticResource Icon.Save}"
                                                    ToolTip="{loc:Tr Main_Editor_Loc_Save_Tip}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                                </StackPanel>
                            </Expander>

                            <!-- ===== TAGS panel =====
                                 In-app playback is on double-click of a catalog
                                 thumbnail, and the catalog right-click menu carries
                                 *Play externally* / *Open file location*; the old
                                 sidebar action row was removed, so this panel is a
                                 pure tag editor. -->
                            <Expander Style="{StaticResource App.Expander}"
                                      IsExpanded="{Binding DataContext.IsDetailTagsPanelExpanded, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                <Expander.Header>
                                    <TextBlock Text="{loc:Tr Main_Tags_Header}" Style="{StaticResource App.Type.Section}" Margin="0" />
                                </Expander.Header>
                                <StackPanel>
                            <ItemsControl ItemsSource="{Binding Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource App.TagChip}"
                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                ToolTip="{loc:Tr Main_Editor_Tag_Prominence_Tip}">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="{loc:Tr Main_Editor_Tag_Background}"
                                                              IsCheckable="True"
                                                              IsChecked="{Binding PlacementTarget.DataContext.IsBackground, RelativeSource={RelativeSource AncestorType=ContextMenu}, Mode=OneWay}"
                                                              Command="{Binding PlacementTarget.Tag.ToggleTagProminenceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- Leading marker shown only on background tags: a small
                                                     outline dot that reads as "secondary / incidental" rather
                                                     than the disabled look a dimmed chip gives. -->
                                                <TextBlock Text="&#x25CB;"
                                                        FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource App.Foreground.Secondary}"
                                                           Visibility="{Binding IsBackground, Converter={StaticResource BoolToVisibility}}" />
                                                <TextBlock Text="{Binding Name}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource App.TagChip.Text}">
                                                            <Style.Triggers>
                                                                <!-- Background tags read as a muted, italicised
                                                                     secondary subject; primary tags keep the bright
                                                                     accent. Full opacity either way so neither looks
                                                                     disabled. -->
                                                                <DataTrigger Binding="{Binding IsBackground}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource App.Foreground.Secondary}" />
                                                                    <Setter Property="FontStyle" Value="Italic" />
                                                                    <Setter Property="FontWeight" Value="Normal" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Button Style="{StaticResource App.Button.ChipClose}"
                                                        helpers:Theme.Icon="{StaticResource Icon.Cancel}"
                                                        Margin="6,0,-2,0"
                                                        ToolTip="{loc:Tr Main_Editor_Tag_Remove_Tip}"
                                                        Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <ui:AutoSuggestBox Width="140"
                                                   Text="{Binding NewTagName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   ItemsSource="{Binding TagSuggestions}"
                                                   PlaceholderText="{loc:Tr Main_Editor_Tag_New}"
                                                   QuerySubmitted="NewTagSuggest_QuerySubmitted" />
                                <ComboBox Width="110" Margin="6,0,0,0"
                                          ItemsSource="{Binding AvailableTagTypes}"
                                          SelectedItem="{Binding NewTagType}" />
                                <Button Content="{loc:Tr Main_Editor_Tag_Add}" Margin="6,0,0,0"
                                        Command="{Binding AddTagCommand}"
                                        Style="{StaticResource App.Button.Secondary}"
                                        helpers:Theme.Icon="{StaticResource Icon.Add}" />
                            </StackPanel>

                            <!-- Transient, colour-coded confirmation for tag add /
                                 remove (also fires for the review-mode pinned-tag
                                 hotkeys, since they route through the same VM
                                 paths). Auto-clears after 2s; severity drives the
                                 colour — green = saved, amber = saved but the
                                 sidecar write failed, red = the catalog write
                                 itself failed. The bottom status bar keeps the
                                 detailed, persistent record (LastSaveStatus). -->
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="{Binding TagFeedback}"
                                       Visibility="{Binding TagFeedback, Converter={StaticResource NullToVisibility}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource App.Success}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TagFeedbackSeverity}" Value="Warning">
                                                <Setter Property="Foreground" Value="{DynamicResource App.Warning}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TagFeedbackSeverity}" Value="Error">
                                                <Setter Property="Foreground" Value="{DynamicResource App.Destructive}" />
                                            </DataTrigger>
                                            <!-- Gentle fade-in each time the line
                                                 appears so the change registers
                                                 even though it's tucked in the
                                                 panel rather than a corner toast. -->
                                            <DataTrigger Binding="{Binding TagFeedback, Converter={StaticResource NullToVisibility}}" Value="Visible">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0" To="1" Duration="0:0:0.18" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                                </StackPanel>
                            </Expander>

                            <!-- ===== NOTES &amp; RATING panel ===== -->
                            <Expander Style="{StaticResource App.Expander}"
                                      IsExpanded="{Binding DataContext.IsDetailNotesPanelExpanded, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                <Expander.Header>
                                    <TextBlock Text="{loc:Tr Main_Editor_Notes_Header}" Style="{StaticResource App.Type.Section}" Margin="0" />
                                </Expander.Header>
                                <StackPanel>
                            <TextBlock Text="{loc:Tr Main_Editor_Notes}" Style="{StaticResource App.Type.Section}" />
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="80" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Tr Main_Editor_Status}" Style="{StaticResource App.Type.Section}" />
                                    <ComboBox ItemsSource="{Binding AvailableStatuses}"
                                              SelectedItem="{Binding Status}"
                                              HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Tr Main_Editor_Rating}" Style="{StaticResource App.Type.Section}" />
                                    <ComboBox Width="80"
                                              ItemsSource="{Binding RatingValues}"
                                              SelectedItem="{Binding Rating}" />
                                </StackPanel>
                            </Grid>

                            <Button Content="{loc:Tr Main_Editor_SaveChanges}"
                                    Command="{Binding SaveCommand}"
                                    HorizontalAlignment="Right"
                                    Margin="0,16,0,0"
                                    Style="{StaticResource App.Button.Primary}"
                                    helpers:Theme.Icon="{StaticResource Icon.Save}" />
                                </StackPanel>
                            </Expander>

                            <!-- ===== MOMENTS panel (timestamped sub-clips) ===== -->
                            <Expander Style="{StaticResource App.Expander}"
                                      IsExpanded="{Binding DataContext.IsDetailMomentsPanelExpanded, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                <Expander.Header>
                                    <TextBlock Text="{loc:Tr Main_Editor_Moments_Header}" Style="{StaticResource App.Type.Section}" Margin="0" />
                                </Expander.Header>
                                <Expander.Tag>
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{DynamicResource App.Foreground.Secondary}"
                                               Text="{Binding MomentCountText}"
                                               Visibility="{Binding HasMoments, Converter={StaticResource BoolToVisibility}}" />
                                </Expander.Tag>
                                <StackPanel>

                                    <!-- Hint when nothing's marked yet. -->
                                    <TextBlock Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{DynamicResource App.Foreground.Secondary}"
                                               Text="{loc:Tr Main_Editor_Moments_Hint}"
                                               Visibility="{Binding HasMoments, Converter={StaticResource BoolToVisibilityInverted}}" />

                                    <ListBox ItemsSource="{Binding Moments}"
                                             SelectedItem="{Binding SelectedMoment, Mode=TwoWay}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             MaxHeight="280"
                                             Margin="0,8,0,0"
                                             HorizontalContentAlignment="Stretch"
                                             ItemContainerStyle="{StaticResource App.ListBoxItem}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Width="96" Height="54"
                                                            CornerRadius="3"
                                                            Background="Black"
                                                            ClipToBounds="True">
                                                        <Image Source="{Binding Thumbnail}"
                                                               Stretch="UniformToFill" />
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                                                        <!-- Title row: the moment's label (falls back to its
                                                             in-point timecode when unnamed) takes the available
                                                             width on the left, with the time range pinned to the
                                                             right so both read at a glance across the full row. -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding DisplayLabel}"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center"
                                                                       ToolTip="{Binding DisplayLabel}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding TimeRangeText}"
                                                                       Margin="8,0,0,0"
                                                                       FontFamily="Consolas"
                                                                       FontSize="11"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource App.Accent}" />
                                                        </Grid>
                                                        <!-- Tags on their own full-width line so the extra room
                                                             is used; hidden entirely when the moment has none. -->
                                                        <TextBlock Text="{Binding TagSummary}"
                                                                   Margin="0,3,0,0"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource App.Foreground.Secondary}"
                                                                   ToolTip="{Binding TagSummary}"
                                                                   Visibility="{Binding TagSummary, Converter={StaticResource NotEmptyToVisibility}}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Style="{StaticResource App.Button.IconOnly}"
                                                                helpers:Theme.Icon="{StaticResource Icon.Play}"
                                                                ToolTip="{loc:Tr Main_Editor_Moment_Jump_Tip}"
                                                                Command="{Binding DataContext.PlayMomentCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Style="{StaticResource App.Button.IconOnly}"
                                                                helpers:Theme.Icon="{StaticResource Icon.Trash}"
                                                                Margin="4,0,0,0"
                                                                ToolTip="{loc:Tr Main_Editor_Moment_Delete_Tip}"
                                                                Command="{Binding DataContext.DeleteMomentCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Compact editor for the selected moment. -->
                                    <Border Margin="0,8,0,0"
                                            Padding="10"
                                            CornerRadius="4"
                                            Background="{DynamicResource App.Chrome.Background}"
                                            BorderBrush="{DynamicResource App.Border.Subtle}"
                                            BorderThickness="1"
                                            Visibility="{Binding HasSelectedMoment, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel DataContext="{Binding SelectedMoment}">
                                            <!-- Header makes it explicit this card edits the
                                                 moment the user just clicked (the moment itself
                                                 already exists from Mark out / O — this only
                                                 saves label + note changes). -->
                                            <TextBlock Margin="0,0,0,8"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding EditingHeader}"
                                                       Foreground="{DynamicResource App.Foreground.Secondary}" />

                                            <TextBlock Text="{loc:Tr Main_Editor_Moment_Label}" Style="{StaticResource App.Type.Section}" />
                                            <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                     ui:ControlHelper.PlaceholderText="{loc:Tr Main_Editor_Moment_Label_Placeholder}" />

                                            <TextBlock Text="{loc:Tr Main_Editor_Moment_Note}" Style="{StaticResource App.Type.Section}" Margin="0,8,0,0" />
                                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="44" />

                                            <!-- Save action + inline confirmation. Rating and
                                                 tags were intentionally dropped from the moment
                                                 editor — a moment carries just a label and a
                                                 note. The colour-coded line (auto-clears after
                                                 2s) is the at-a-glance "it saved" cue right
                                                 where you clicked; the bottom status bar /
                                                 review-mode marker line keep the fuller record. -->
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding DataContext.Detail.MomentFeedback, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Visibility="{Binding DataContext.Detail.MomentFeedback, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NullToVisibility}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource App.Success}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.Detail.MomentFeedbackSeverity, RelativeSource={RelativeSource AncestorType=Window}}" Value="Warning">
                                                                    <Setter Property="Foreground" Value="{DynamicResource App.Warning}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.Detail.MomentFeedbackSeverity, RelativeSource={RelativeSource AncestorType=Window}}" Value="Error">
                                                                    <Setter Property="Foreground" Value="{DynamicResource App.Destructive}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.Detail.MomentFeedback, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NullToVisibility}}" Value="Visible">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                 From="0" To="1" Duration="0:0:0.18" />
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Button Grid.Column="1"
                                                        Content="{loc:Tr Common_Save}"
                                                        HorizontalAlignment="Right"
                                                        Style="{StaticResource App.Button.Primary}"
                                                        helpers:Theme.Icon="{StaticResource Icon.Save}"
                                                        Command="{Binding DataContext.Detail.SaveMomentCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="12,6"
                Background="{DynamicResource App.Chrome.Background}"
                BorderBrush="{DynamicResource App.Border.Subtle}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status message (left). One line, ellipsised, secondary tier. -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           FontSize="12"
                           Foreground="{DynamicResource App.Foreground.Secondary}" />

                <!-- Scan pill (middle). Visible only while scanning; collapses
                     into a 24h pill with: rotating sync glyph, "Scanning"
                     label, X / Y count, mid-dot, mono-spaced elapsed time.
                     The thin 2px strip across the very top of the window
                     (rendered below this Grid) carries the determinate
                     progress fill. -->
                <Border Grid.Column="1"
                        Margin="12,0,0,0"
                        Padding="10,3"
                        CornerRadius="12"
                        Height="24"
                        Background="{DynamicResource App.Accent.Subtle}"
                        BorderBrush="{DynamicResource App.Accent}"
                        BorderThickness="1"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="{StaticResource App.Icon.FontFamily}"
                                   FontSize="11"
                                   Text="{StaticResource Icon.Sync}"
                                   Foreground="{DynamicResource App.Accent}"
                           VerticalAlignment="Center"
                                   Margin="0,0,6,0">
                            <TextBlock.RenderTransform>
                                <RotateTransform CenterX="5.5" CenterY="5.5" />
                            </TextBlock.RenderTransform>
                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             From="0" To="360"
                                                             Duration="0:0:1.6" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </TextBlock.Triggers>
                        </TextBlock>
                        <TextBlock Text="{loc:Tr Main_Status_Scanning}"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource App.Accent}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text=" · "
                                   FontSize="11"
                                   Foreground="{DynamicResource App.Accent}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ScanElapsedText}"
                                   FontSize="11"
                                   FontFamily="{StaticResource App.FontFamily.Mono}"
                                   Foreground="{DynamicResource App.Accent}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- AI tagging pill (running). Visible only while a CLIP scoring
                     pass is running (Generate / Re-score). Mirrors the scan
                     pill's accent chrome and rotating glyph; clicking opens the
                     review window so the user can triage clips already scored.
                     The X / Y count itself lives in the StatusMessage on the left. -->
                <Button Grid.Column="2"
                        Margin="8,0,0,0"
                        Padding="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Cursor="Hand"
                        Click="AiPill_Click"
                        Visibility="{Binding IsAiTagging, Converter={StaticResource BoolToVisibility}}"
                        ToolTip="{loc:Tr Main_Status_AiTagging_Tip}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Padding="10,3"
                                    CornerRadius="12"
                                    Height="24"
                                    Background="{DynamicResource App.Accent.Subtle}"
                                    BorderBrush="{DynamicResource App.Accent}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock FontFamily="{StaticResource App.Icon.FontFamily}"
                                               FontSize="11"
                                               Text="{StaticResource Icon.Sync}"
                                               Foreground="{DynamicResource App.Accent}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform CenterX="5.5" CenterY="5.5" />
                                        </TextBlock.RenderTransform>
                                        <TextBlock.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         From="0" To="360"
                                                                         Duration="0:0:1.6" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </TextBlock.Triggers>
                                    </TextBlock>
                                    <TextBlock Text="{loc:Tr Main_Status_AiTagging}"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource App.Accent}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- AI tagging pill (finished). Replaces the running pill once a
                     pass completes: a static check glyph + "Review N suggestions"
                     in success green. Clicking opens the review window and
                     dismisses the pill. Hidden while a pass is running. -->
                <Button Grid.Column="2"
                        Margin="8,0,0,0"
                        Padding="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Cursor="Hand"
                        Click="AiPill_Click"
                        Visibility="{Binding AiTaggingFinished, Converter={StaticResource BoolToVisibility}}"
                        ToolTip="{loc:Tr Main_Status_AiDone_Tip}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="DoneBd"
                                    Padding="10,3"
                                    CornerRadius="12"
                                    Height="24"
                                    Background="{DynamicResource App.Background.Highest}"
                                    BorderBrush="{DynamicResource App.Success}"
                                    BorderThickness="1"
                                    TextElement.Foreground="{DynamicResource App.Success}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock FontFamily="{StaticResource App.Icon.FontFamily}"
                                               FontSize="11"
                                               Text="{StaticResource Icon.Accept}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding AiTaggingResultText}"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="DoneBd" Property="Background" Value="{DynamicResource App.Accent.Subtle}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Update-available pill (middle-right). Visible only when
                     the silent startup update check (or a manual recheck via
                     Help → Check for updates…) has found a newer release on
                     GitHub. Clicking the pill re-invokes the explicit update
                     command, which opens the install confirmation dialog
                     and hands off to Velopack. Mirrors the scan pill's
                     accent-on-accent.subtle chrome — same visual family,
                     same 24h pill geometry — so the status bar reads as one
                     consistent affordance rail rather than three random
                     widgets. -->
                <Button Grid.Column="3"
                        Margin="12,0,0,0"
                        Padding="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Cursor="Hand"
                        Command="{Binding CheckForUpdatesCommand}"
                        Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibility}}"
                        ToolTip="{loc:Tr Main_Status_Update_Tip}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <!-- TextElement.Foreground on the Border drives the
                                 fill of every TextBlock inside, so the hover
                                 trigger can swap accent-amber -> on-accent
                                 (dark) in one place without per-TextBlock
                                 Foreground bindings that would otherwise win
                                 over inheritance. -->
                            <Border x:Name="Bd"
                                    Padding="10,3"
                                    CornerRadius="12"
                                    Height="24"
                                    Background="{DynamicResource App.Accent.Subtle}"
                                    BorderBrush="{DynamicResource App.Accent}"
                                    BorderThickness="1"
                                    TextElement.Foreground="{DynamicResource App.Accent}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock FontFamily="{StaticResource App.Icon.FontFamily}"
                                               FontSize="11"
                                               Text="{StaticResource Icon.Download}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="{loc:Tr Main_Status_UpdateAvailable}"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text=" · v"
                                               FontSize="11"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding AvailableUpdateVersion}"
                                               FontSize="11"
                                               FontFamily="{StaticResource App.FontFamily.Mono}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.Accent}" />
                                    <Setter TargetName="Bd" Property="TextElement.Foreground" Value="{DynamicResource App.Accent.OnAccent}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Sidecars pill (right). Always visible. Green dot when on,
                     tertiary dot when off. Two clean lines of state in 24h. -->
                <Border Grid.Column="4"
                        Margin="8,0,0,0"
                        Padding="10,3"
                        CornerRadius="12"
                        Height="24"
                        Background="{DynamicResource App.Background.Highest}"
                        BorderBrush="{DynamicResource App.Border.Subtle}"
                        BorderThickness="1"
                        ToolTip="{loc:Tr Main_Status_Sidecar_Tip}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource App.Foreground.Tertiary}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidecarEnabled}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource App.Success}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding SidecarStatusText}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource App.Foreground.Secondary}" />
                    </StackPanel>
                </Border>

                <!-- Map-selection pill (far right). Visible only while the grid
                     is scoped to a set of clips picked on the map browse view.
                     Clicking clears the map selection and re-runs the search;
                     any normal filter change clears it automatically too. -->
                <Button Grid.Column="5"
                        Margin="8,0,0,0"
                        Padding="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Cursor="Hand"
                        Command="{Binding ClearMapSelectionCommand}"
                        Visibility="{Binding HasMapSelection, Converter={StaticResource BoolToVisibility}}"
                        ToolTip="{loc:Tr Main_Status_MapScope_Tip}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="MapBd"
                                    Padding="10,3"
                                    CornerRadius="12"
                                    Height="24"
                                    Background="{DynamicResource App.Accent.Subtle}"
                                    BorderBrush="{DynamicResource App.Accent}"
                                    BorderThickness="1"
                                    TextElement.Foreground="{DynamicResource App.Accent}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock FontFamily="{StaticResource App.Icon.FontFamily}"
                                               FontSize="11"
                                               Text="{StaticResource Icon.Map}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding MapSelectionText}"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="  ✕"
                                               FontSize="11"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="MapBd" Property="Background" Value="{DynamicResource App.Accent}" />
                                    <Setter TargetName="MapBd" Property="TextElement.Foreground" Value="{DynamicResource App.Accent.OnAccent}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- 2px top progress strip. Sits across the full window width at the
             very top, ABOVE the chrome row. Spans all 3 grid rows but is
             pinned to VerticalAlignment="Top" with Height="2" so it stays
             out of the way of layout. Indeterminate while ProgressMaximum
             is unknown (enumeration phase) and determinate once the
             scanner switches to processing. Hidden when !IsScanning. -->
        <ProgressBar Grid.Row="0"
                     Grid.RowSpan="3"
                     VerticalAlignment="Top"
                     Height="2"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource App.Accent}"
                             Maximum="{Binding ProgressMaximum}"
                             Value="{Binding ProgressValue}"
                     Panel.ZIndex="100"
                     Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}">
            <ProgressBar.Style>
                <Style TargetType="ProgressBar">
                    <Style.Triggers>
                        <!-- Switch to indeterminate during the file-enumeration
                             phase (ProgressMaximum=0, count not yet known). -->
                        <DataTrigger Binding="{Binding ProgressMaximum}" Value="0">
                            <Setter Property="IsIndeterminate" Value="True" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ProgressBar.Style>
        </ProgressBar>
    </Grid>
</Window>
