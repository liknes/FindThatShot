<Window x:Class="VideoArchiveManager.App.Views.MomentSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls"
        xmlns:vm="clr-namespace:VideoArchiveManager.App.ViewModels"
        xmlns:loc="clr-namespace:VideoArchiveManager.App.Localization"
        Title="{loc:Tr MomentSearch_Title}"
        Width="760" Height="780"
        MinWidth="560" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        d:DataContext="{d:DesignInstance Type=vm:MomentSearchViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{loc:Tr MomentSearch_Title}" Style="{StaticResource App.Type.Display}" />
            <TextBlock Margin="0,4,0,0"
                       Text="{loc:Tr MomentSearch_Subtitle}"
                       TextWrapping="Wrap"
                       Style="{StaticResource App.Type.Caption}" />
        </StackPanel>

        <!-- Query row -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ui:ControlHelper.PlaceholderText="{loc:Tr MomentSearch_SearchPlaceholder}"
                     KeyDown="SearchBox_KeyDown" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{loc:Tr MomentSearch_MinRating}" VerticalAlignment="Center"
                           Foreground="{DynamicResource App.Foreground.Secondary}" />
                <ComboBox Width="64" Margin="6,0,0,0"
                          ItemsSource="{Binding RatingValues}"
                          SelectedItem="{Binding MinRating}" />
            </StackPanel>

            <CheckBox Grid.Column="2" Margin="12,0,0,0"
                      VerticalAlignment="Center"
                      Content="{loc:Tr MomentSearch_OnlineOnly}"
                      IsChecked="{Binding OnlyAvailable}"
                      ToolTip="{loc:Tr MomentSearch_OnlineOnlyToolTip}" />

            <Button Grid.Column="3" Margin="10,0,0,0"
                    Content="{loc:Tr MomentSearch_SearchButton}"
                    Command="{Binding SearchCommand}"
                    Style="{StaticResource App.Button.Primary}"
                    helpers:Theme.Icon="{StaticResource Icon.Search}" />
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="{Binding ResultSummary}"
                   Foreground="{DynamicResource App.Foreground.Secondary}" />

        <ListBox Grid.Row="3"
                 Margin="0,8,0,0"
                 ItemsSource="{Binding Results}"
                 Background="Transparent"
                 BorderThickness="0"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,3"
                            Padding="10,8"
                            CornerRadius="6"
                            Background="{DynamicResource App.Background.Inset}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="128" Height="72"
                                    CornerRadius="4"
                                    Margin="0,0,12,0"
                                    ClipToBounds="True"
                                    Background="{DynamicResource App.Background.Base}">
                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayLabel}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding TimeRangeText}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="{DynamicResource App.Accent}" />
                                    <TextBlock Text="{Binding RatingText}"
                                               Margin="8,0,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource App.Accent}" />
                                </StackPanel>
                                <TextBlock Text="{Binding FileName}"
                                           Margin="0,2,0,0"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource App.Foreground.Secondary}" />
                                <TextBlock Text="{Binding TagSummary}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource App.Foreground.Tertiary}" />
                            </StackPanel>

                            <Button Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Content="{loc:Tr MomentSearch_JumpTo}"
                                    Style="{StaticResource App.Button.Secondary}"
                                    helpers:Theme.Icon="{StaticResource Icon.Play}"
                                    Command="{Binding DataContext.JumpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
