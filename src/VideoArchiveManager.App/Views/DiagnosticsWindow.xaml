<Window x:Class="VideoArchiveManager.App.Views.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls"
        xmlns:loc="clr-namespace:VideoArchiveManager.App.Localization"
        Title="{loc:Tr Diagnostics_Title}"
        Width="940" Height="680"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png">
    <Grid Margin="20"
          TextElement.FontFamily="{StaticResource App.FontFamily}"
          TextElement.Foreground="{DynamicResource App.Foreground.Primary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Environment / paths card. Two columns of key:value rows, filled
             in code-behind, so a user can read off (or copy) everything a bug
             report needs without hunting through the OS. -->
        <Border Grid.Row="0"
                Padding="16,12"
                Background="{DynamicResource App.Background.Elevated}"
                BorderBrush="{DynamicResource App.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="{loc:Tr Diagnostics_Environment}" Style="{StaticResource App.Type.Section}" Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel x:Name="EnvLeftColumn" Grid.Column="0" Margin="0,0,12,0" />
                    <StackPanel x:Name="EnvRightColumn" Grid.Column="1" Margin="12,0,0,0" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Section label for the live log. -->
        <TextBlock Grid.Row="1"
                   Text="{loc:Tr Diagnostics_RecentLog}"
                   Style="{StaticResource App.Type.Section}"
                   Margin="0,18,0,8" />

        <!-- Log toolbar: level filter, free-text filter, auto-scroll, and the
             copy / clear / reveal actions. -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="LevelFilter"
                      Grid.Column="0"
                      Width="150"
                      VerticalAlignment="Center"
                      SelectionChanged="LevelFilter_OnSelectionChanged"
                      ToolTip="{loc:Tr Diagnostics_LevelFilter_Tip}">
                <ComboBoxItem Content="{loc:Tr Diagnostics_Level_All}" />
                <ComboBoxItem Content="{loc:Tr Diagnostics_Level_InfoUp}" IsSelected="True" />
                <ComboBoxItem Content="{loc:Tr Diagnostics_Level_WarnUp}" />
                <ComboBoxItem Content="{loc:Tr Diagnostics_Level_Errors}" />
            </ComboBox>

            <TextBox x:Name="SearchBox"
                     Grid.Column="1"
                     Width="220"
                     Margin="8,0,0,0"
                     VerticalAlignment="Center"
                     ui:ControlHelper.PlaceholderText="{loc:Tr Diagnostics_FilterPlaceholder}"
                     TextChanged="SearchBox_OnTextChanged" />

            <CheckBox x:Name="AutoScrollCheck"
                      Grid.Column="2"
                      Content="{loc:Tr Diagnostics_AutoScroll}"
                      IsChecked="True"
                      VerticalAlignment="Center"
                      Margin="12,0,0,0"
                      Foreground="{DynamicResource App.Foreground.Secondary}" />

            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Content="{loc:Tr Diagnostics_CopyLog}"
                        Style="{StaticResource App.Button.Secondary}"
                        helpers:Theme.Icon="{StaticResource Icon.Copy}"
                        Click="CopyLog_Click"
                        ToolTip="{loc:Tr Diagnostics_CopyLog_Tip}" />
                <Button Content="{loc:Tr Diagnostics_OpenLogFile}"
                        Margin="8,0,0,0"
                        Style="{StaticResource App.Button.Secondary}"
                        helpers:Theme.Icon="{StaticResource Icon.Document}"
                        Click="OpenLogFile_Click" />
                <Button Content="{loc:Tr Diagnostics_OpenFolder}"
                        Margin="8,0,0,0"
                        Style="{StaticResource App.Button.Secondary}"
                        helpers:Theme.Icon="{StaticResource Icon.Folder}"
                        Click="OpenLogFolder_Click" />
                <Button Content="{loc:Tr Diagnostics_Clear}"
                        Margin="8,0,0,0"
                        Style="{StaticResource App.Button.Ghost}"
                        helpers:Theme.Icon="{StaticResource Icon.Trash}"
                        Click="ClearLog_Click"
                        ToolTip="{loc:Tr Diagnostics_Clear_Tip}" />
            </StackPanel>
        </Grid>

        <!-- The log itself. ListBox keeps UI virtualization, which matters
             with thousands of buffered lines; each row is a monospace line
             with a level-coloured tag. -->
        <Border Grid.Row="3"
                Background="{DynamicResource App.Background.Inset}"
                BorderBrush="{DynamicResource App.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="6">
            <ListBox x:Name="LogList"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="6,1" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}"
                                           FontFamily="{StaticResource App.FontFamily.Mono}"
                                           FontSize="11"
                                           Foreground="{DynamicResource App.Foreground.Tertiary}"
                                           Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding LevelTag}"
                                           FontFamily="{StaticResource App.FontFamily.Mono}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="0,0,8,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource App.Foreground.Tertiary}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LevelTag}" Value="INFO">
                                                    <Setter Property="Foreground" Value="{DynamicResource App.Foreground.Secondary}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LevelTag}" Value="WARN">
                                                    <Setter Property="Foreground" Value="{DynamicResource App.Warning}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LevelTag}" Value="ERROR">
                                                    <Setter Property="Foreground" Value="{DynamicResource App.Destructive}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LevelTag}" Value="CRIT">
                                                    <Setter Property="Foreground" Value="{DynamicResource App.Destructive}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding ShortCategory}"
                                           FontFamily="{StaticResource App.FontFamily.Mono}"
                                           FontSize="11"
                                           Foreground="{DynamicResource App.Foreground.Tertiary}"
                                           Margin="0,0,10,0" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding Message}"
                                           FontFamily="{StaticResource App.FontFamily.Mono}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource App.Foreground.Primary}" />
                            </Grid>
                            <TextBlock Text="{Binding Exception}"
                                       FontFamily="{StaticResource App.FontFamily.Mono}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="56,2,0,4"
                                       Foreground="{DynamicResource App.Destructive}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Exception}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Footer: copy a full diagnostics report (environment + visible log)
             for pasting straight into a bug report, plus Close. -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="LogCountText"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Style="{StaticResource App.Type.Caption}" />

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="{loc:Tr Diagnostics_CopyReport}"
                        Style="{StaticResource App.Button.Secondary}"
                        helpers:Theme.Icon="{StaticResource Icon.Copy}"
                        Click="CopyReport_Click"
                        ToolTip="{loc:Tr Diagnostics_CopyReport_Tip}" />
                <Button Content="{loc:Tr Common_Close}"
                        Margin="8,0,0,0"
                        IsDefault="True" IsCancel="True"
                        Style="{StaticResource App.Button.Primary}"
                        Click="Close_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
