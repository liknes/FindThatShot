<Window x:Class="VideoArchiveManager.App.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find That Shot"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Width="480" Height="320"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        ResizeMode="NoResize">
    <!-- Splash window. Shown immediately at app startup while DI / DB / FFmpeg
         init runs in OnStartup. Fades out over ~400ms once MainWindow.Loaded
         fires. The accent strip on the left is the visual anchor for the
         brand; rest is centered icon + name + version + spinner. -->
    <Border CornerRadius="10"
            Background="{DynamicResource App.Background.Elevated}"
            BorderBrush="{DynamicResource App.Border.Subtle}"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.4" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Vertical accent strip on the left edge -->
            <Border Grid.Column="0"
                    Background="{DynamicResource App.Accent}" />

            <Grid Grid.Column="1" Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/AppIcon.png"
                           Width="64" Height="64"
                           HorizontalAlignment="Center" />
                    <TextBlock Text="Find That Shot"
                               Style="{StaticResource App.Type.Display}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,4" />
                    <TextBlock x:Name="VersionText"
                               Style="{StaticResource App.Type.Caption}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,4">
                    <TextBlock x:Name="SpinnerGlyph"
                               FontFamily="{StaticResource App.Icon.FontFamily}"
                               FontSize="12"
                               Text="{StaticResource Icon.Sync}"
                               Foreground="{DynamicResource App.Accent}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform />
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                         From="0" To="360"
                                                         Duration="0:0:1.4" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock Text="Loading"
                               Style="{StaticResource App.Type.Caption}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
