<Window x:Class="VideoArchiveManager.App.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find That Shot"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Width="600" Height="450"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        ResizeMode="NoResize">
    <!-- Splash window. Shown immediately at app startup while DI / DB / FFmpeg
         init runs in OnStartup. Fades out over ~400ms once MainWindow.Loaded
         fires. It's a full-bleed branded splash image (logo + tagline are baked
         into the artwork); the version label and loading spinner sit in a
         bottom scrim so they stay legible over the photo. -->
    <!-- NOTE: do NOT put a DropShadowEffect (or any Effect) on this Border.
         An Effect forces WPF to rasterise the whole subtree — including the
         splash artwork — into an intermediate bitmap at 1x layout resolution,
         which is then scaled to device pixels and makes the sharp PNG look
         blurry on high-DPI displays. (The shadow was also clipped by the
         window edge anyway, since the Border fills the window with no margin.) -->
    <Border CornerRadius="10"
            BorderBrush="#66808080"
            BorderThickness="1"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True"
            ClipToBounds="True">
        <Grid>
            <!-- Clip children to the rounded corners (Border.CornerRadius doesn't
                 clip its child). Rect is inset 1px for the border; radius 9 = 10 - 1. -->
            <Grid.Clip>
                <RectangleGeometry Rect="0,0,598,448" RadiusX="9" RadiusY="9" />
            </Grid.Clip>
            <!-- Branded artwork fills the window (4:3, matches the source PNG). -->
            <Image Source="pack://application:,,,/Resources/Images/SplashScreen.png"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <!-- Bottom-to-top dark scrim so the overlay text reads on any frame. -->
            <Border VerticalAlignment="Bottom" Height="96">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                        <GradientStop Offset="0" Color="#B0000000" />
                        <GradientStop Offset="1" Color="#00000000" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Version (left) + loading spinner (right) along the bottom edge. -->
            <Grid VerticalAlignment="Bottom" Margin="20,0,20,16">
                <TextBlock x:Name="VersionText"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#D0FFFFFF" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="SpinnerGlyph"
                               FontFamily="{StaticResource App.Icon.FontFamily}"
                               FontSize="12"
                               Text="{StaticResource Icon.Sync}"
                               Foreground="{DynamicResource App.Accent}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform />
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                         From="0" To="360"
                                                         Duration="0:0:1.4" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock Text="Loading"
                               FontSize="12"
                               Foreground="#D0FFFFFF"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
