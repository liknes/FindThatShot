<Window x:Class="VideoArchiveManager.App.Views.CalendarBrowseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls"
        xmlns:vm="clr-namespace:VideoArchiveManager.App.ViewModels"
        Title="Browse by date"
        Width="1100" Height="760"
        MinWidth="760" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        d:DataContext="{d:DesignInstance Type=vm:CalendarBrowseViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Window.Resources>
        <!-- A heatmap month cell: a clickable colored tile whose fill comes from
             the month's intensity. Minimal template so the bound Background shows
             and an accent hover ring appears; empty months are non-interactive. -->
        <Style x:Key="HeatCellButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource App.Border.Subtle}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource App.Accent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Browse by date" Style="{StaticResource App.Type.Display}" />
            <TextBlock Margin="0,4,0,0"
                       Text="A year-by-month heatmap of when you shot. Brighter cells hold more clips; click a month to list its clips, preview one, and jump to it in the grid or player."
                       TextWrapping="Wrap"
                       Style="{StaticResource App.Type.Caption}" />
        </StackPanel>

        <!-- Toolbar: scope toggle, summary, filter-to-month -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0"
                      VerticalAlignment="Center"
                      Content="Whole archive"
                      IsChecked="{Binding ScopeWholeArchive}"
                      ToolTip="On: count every clip in the catalog. Off: count only the clips matching the current grid filters." />

            <TextBlock Grid.Column="1"
                       Margin="16,0,16,0"
                       VerticalAlignment="Center"
                       Text="{Binding ResultSummary}"
                       Foreground="{DynamicResource App.Foreground.Secondary}" />

            <Button Grid.Column="2"
                    Content="Filter grid to this month"
                    Command="{Binding FilterMonthToGridCommand}"
                    Style="{StaticResource App.Button.Secondary}"
                    helpers:Theme.Icon="{StaticResource Icon.Filter}"
                    ToolTip="Scope the catalog grid to the selected month's date range." />
        </Grid>

        <!-- Heatmap + side panel -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    CornerRadius="6"
                    Padding="12"
                    Background="{DynamicResource App.Background.Inset}">
                <Grid>
                    <!-- Empty state -->
                    <TextBlock VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="No dated clips to chart yet. Scan some footage first."
                               Foreground="{DynamicResource App.Foreground.Tertiary}"
                               Visibility="{Binding HasYears, Converter={StaticResource BoolToVisibilityInverted}}" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasYears, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl ItemsSource="{Binding Years}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <!-- Year label + total -->
                                        <StackPanel Width="60" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Year}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14" />
                                            <TextBlock Text="{Binding TotalLabel}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource App.Foreground.Tertiary}" />
                                        </StackPanel>

                                        <!-- 12 month cells -->
                                        <ItemsControl ItemsSource="{Binding Months}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource HeatCellButton}"
                                                            Background="{Binding Intensity, Converter={StaticResource HeatIntensityToBrush}}"
                                                            IsEnabled="{Binding HasClips}"
                                                            ToolTip="{Binding Tooltip}"
                                                            Command="{Binding DataContext.SelectMonthCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding MonthShort}"
                                                                       HorizontalAlignment="Center"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource App.Foreground.Secondary}" />
                                                            <TextBlock Text="{Binding CountLabel}"
                                                                       HorizontalAlignment="Center"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource App.Foreground.Primary}" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Side panel: month clip list + selected-clip preview -->
            <Border Grid.Column="1"
                    Width="320"
                    Margin="12,0,0,0"
                    Padding="14"
                    CornerRadius="6"
                    Background="{DynamicResource App.Background.Inset}">
                <Grid>
                    <!-- Placeholder when no month selected -->
                    <TextBlock VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="Click a month in the heatmap to list its clips here."
                               Foreground="{DynamicResource App.Foreground.Tertiary}"
                               Visibility="{Binding HasMonthSelection, Converter={StaticResource BoolToVisibilityInverted}}" />

                    <Grid Visibility="{Binding HasMonthSelection, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding MonthClipsHeader}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding MonthClips}"
                                 SelectedItem="{Binding SelectedClip}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="80" Height="45"
                                                CornerRadius="3"
                                                ClipToBounds="True"
                                                Background="{DynamicResource App.Background.Base}">
                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="12" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding DateText}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource App.Foreground.Tertiary}" />
                                                <TextBlock Text="{Binding AvailabilityText}"
                                                           Margin="8,0,0,0"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource App.Foreground.Secondary}" />
                                                <TextBlock Text="{Binding RatingText}"
                                                           Margin="8,0,0,0"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource App.Accent}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Selected-clip preview -->
                        <StackPanel Grid.Row="2"
                                    Margin="0,10,0,0"
                                    Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                            <Border CornerRadius="4"
                                    ClipToBounds="True"
                                    Height="158"
                                    Background="{DynamicResource App.Background.Base}">
                                <Image Source="{Binding SelectedClip.PreviewThumbnail}" Stretch="UniformToFill" />
                            </Border>

                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding SelectedClip.FileName}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="{Binding SelectedClip.FolderPath}"
                                       TextWrapping="Wrap"
                                       FontSize="11"
                                       Foreground="{DynamicResource App.Foreground.Tertiary}" />

                            <Button Margin="0,12,0,0"
                                    HorizontalAlignment="Stretch"
                                    Content="Show in grid"
                                    Command="{Binding ShowInGridCommand}"
                                    Style="{StaticResource App.Button.Primary}"
                                    helpers:Theme.Icon="{StaticResource Icon.Calendar}" />
                            <Button Margin="0,8,0,0"
                                    HorizontalAlignment="Stretch"
                                    Content="Play in app"
                                    Command="{Binding PlayCommand}"
                                    Style="{StaticResource App.Button.Secondary}"
                                    helpers:Theme.Icon="{StaticResource Icon.Play}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
