<Window x:Class="VideoArchiveManager.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls"
        xmlns:loc="clr-namespace:VideoArchiveManager.App.Localization"
        Title="{loc:Tr Settings_Title}"
        Width="760" Height="800"
        MinWidth="640" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png">
    <Grid TextElement.FontFamily="{StaticResource App.FontFamily}"
          TextElement.Foreground="{DynamicResource App.Foreground.Primary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--
            Categories sit in a left navigation rail (Win11-Settings style).
            Each NavigationViewItem's Tag matches a content pane below; the
            code-behind SelectionChanged toggles the matching pane's
            visibility. The Save / Cancel footer (last row) is global across
            all panes since they all bind the one SettingsViewModel. The window
            title bar already reads "Settings", so there's no in-window heading.
        -->
        <ui:NavigationView x:Name="SettingsNav" Grid.Row="0"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsSettingsVisible="False"
                           IsPaneToggleButtonVisible="False"
                           OpenPaneLength="200"
                           Background="Transparent"
                           SelectionChanged="SettingsNav_SelectionChanged">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="{loc:Tr Settings_Nav_General}" Tag="general" IsSelected="True">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{StaticResource App.Icon.FontFamily}" Glyph="{StaticResource Icon.Filter}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="{loc:Tr Settings_Nav_Storage}" Tag="storage">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{StaticResource App.Icon.FontFamily}" Glyph="{StaticResource Icon.Folder}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="{loc:Tr Settings_Nav_Playback}" Tag="playback">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{StaticResource App.Icon.FontFamily}" Glyph="{StaticResource Icon.Movie}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="{loc:Tr Settings_Nav_Review}" Tag="review">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{StaticResource App.Icon.FontFamily}" Glyph="{StaticResource Icon.Tag}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="{loc:Tr Settings_Nav_Ai}" Tag="ai">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="{StaticResource App.Icon.FontFamily}" Glyph="{StaticResource Icon.Tag}" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <Grid>

                <!-- ============================ GENERAL ============================ -->
                <ScrollViewer x:Name="PageGeneral"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,16,20,16">

                        <TextBlock Text="{loc:Tr Settings_Language_Header}" Style="{StaticResource App.Type.Section}" />

                        <TextBlock Text="{loc:Tr Settings_Language_Label}" Style="{StaticResource App.Type.Caption}" />
                        <ComboBox ItemsSource="{Binding Languages}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  DisplayMemberPath="DisplayName"
                                  HorizontalAlignment="Left"
                                  MinWidth="240"
                                  Margin="0,4,0,4" />
                        <TextBlock Text="{loc:Tr Settings_Language_Hint}"
                                   Style="{StaticResource App.Type.Caption}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16" />

                        <TextBlock Text="{loc:Tr Settings_Scanning_Header}" Style="{StaticResource App.Type.Section}" />

                        <TextBlock Text="{loc:Tr Settings_MaxParallelism}" Style="{StaticResource App.Type.Caption}" />
                        <ui:NumberBox Value="{Binding MaxScanParallelism}" Minimum="1" Maximum="16" Margin="0,4,0,12" />

                        <TextBlock Text="{loc:Tr Settings_ExcludedFolders}"
                                   Style="{StaticResource App.Type.Caption}" TextWrapping="Wrap" />
                        <TextBox Text="{Binding ExcludedFolderNames, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="60"
                                 Margin="0,4,0,12" />

                        <TextBlock Text="{loc:Tr Settings_ExcludedPatterns}"
                                   Style="{StaticResource App.Type.Caption}" TextWrapping="Wrap" />
                        <TextBox Text="{Binding ExcludedFileNamePatterns, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="40"
                                 Margin="0,4,0,16" />

                        <TextBlock TextWrapping="Wrap"
                                   Style="{StaticResource App.Type.Caption}"
                                   Text="{loc:Tr Settings_SavedTo}" />
                    </StackPanel>
                </ScrollViewer>

                <!-- ======================= LIBRARY &amp; STORAGE ======================= -->
                <ScrollViewer x:Name="PageStorage" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,16,20,16">

                        <TextBlock Text="{loc:Tr Settings_Storage_Header}" Style="{StaticResource App.Type.Section}" />

                        <TextBlock Text="{loc:Tr Settings_ThumbnailDir}" Style="{StaticResource App.Type.Caption}" />
                        <TextBox Text="{Binding ThumbnailDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,12" />

                        <TextBlock Text="{loc:Tr Settings_DatabaseFile}" Style="{StaticResource App.Type.Caption}" />
                        <TextBox Text="{Binding DatabasePath, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,4" />
                        <TextBlock TextWrapping="Wrap"
                                   Style="{StaticResource App.Type.Caption}"
                                   Margin="0,0,0,16"
                                   Text="{loc:Tr Settings_DbRestart}" />

                        <TextBlock Text="{loc:Tr Settings_Sidecar_Header}" Style="{StaticResource App.Type.Section}" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource App.Type.BodyMuted}" Margin="0,0,0,12"
                                   Text="{loc:Tr Settings_Sidecar_Desc}" />
                        <CheckBox IsChecked="{Binding WriteSidecarFiles}"
                                  Content="{loc:Tr Settings_Sidecar_Check}"
                                  Margin="0,0,0,16" />

                        <TextBlock Text="{loc:Tr Settings_Backup_Header}" Style="{StaticResource App.Type.Section}" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource App.Type.BodyMuted}" Margin="0,0,0,12"
                                   Text="{loc:Tr Settings_Backup_Desc}" />

                        <TextBlock Text="{loc:Tr Settings_Backup_Dir}" Style="{StaticResource App.Type.Caption}" />
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding BackupDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Margin="8,0,0,0"
                                    Content="{loc:Tr Common_Browse}"
                                    Style="{StaticResource App.Button.Secondary}"
                                    helpers:Theme.Icon="{StaticResource Icon.Folder}"
                                    Command="{Binding BrowseBackupDirectoryCommand}" />
                        </Grid>

                        <CheckBox IsChecked="{Binding AutoBackupOnStartup}"
                                  Content="{loc:Tr Settings_Backup_Auto}"
                                  Margin="0,0,0,8" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Tr Settings_Backup_KeepLast}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ui:NumberBox Width="100"
                                          Minimum="1" Maximum="365"
                                          Value="{Binding BackupRetentionCount}" />
                            <TextBlock Text="{loc:Tr Settings_Backup_KeepSuffix}" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="{loc:Tr Settings_Backup_Now}"
                                    Style="{StaticResource App.Button.Secondary}"
                                    helpers:Theme.Icon="{StaticResource Icon.Cloud}"
                                    Command="{Binding BackupNowCommand}"
                                    IsEnabled="{Binding IsBackingUp, Converter={StaticResource InverseBool}}" />
                            <Button Content="{loc:Tr Settings_Backup_RefreshList}"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource App.Button.Ghost}"
                                    helpers:Theme.Icon="{StaticResource Icon.Refresh}"
                                    Command="{Binding RefreshBackupsCommand}" />
                        </StackPanel>
                        <TextBlock Text="{Binding BackupStatusMessage}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource App.Type.Caption}"
                                   Margin="0,4,0,12" />

                        <TextBlock Text="{loc:Tr Settings_Backup_Available}"
                                   Style="{StaticResource App.Type.Caption}" />
                        <ListBox ItemsSource="{Binding Backups}"
                                 SelectedItem="{Binding SelectedBackup}"
                                 Height="160"
                                 Margin="0,4,0,8">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource App.Foreground.Primary}" />
                                            <TextBlock Text="{Binding Path}"
                                                       Foreground="{DynamicResource App.Foreground.Tertiary}"
                                                       FontSize="11" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource App.Foreground.Secondary}"
                                                   FontFamily="{StaticResource App.FontFamily.Mono}"
                                                   FontSize="11"
                                                   Margin="12,0,0,0">
                                            <Run Text="{Binding CreatedAtUtc, Mode=OneWay, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="{loc:Tr Settings_Backup_Restore}"
                                    Style="{StaticResource App.Button.Secondary}"
                                    helpers:Theme.Icon="{StaticResource Icon.Refresh}"
                                    Command="{Binding RestoreCommand}"
                                    ToolTip="{loc:Tr Settings_Backup_Restore_Tip}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- ======================= PLAYBACK &amp; MAP ======================= -->
                <ScrollViewer x:Name="PagePlayback" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,16,20,16">

                        <TextBlock Text="{loc:Tr Settings_Ffmpeg_Header}" Style="{StaticResource App.Type.Section}" />

                        <TextBlock Text="{loc:Tr Settings_FfmpegPath}"
                                   Style="{StaticResource App.Type.Caption}" />
                        <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Margin="8,0,0,0"
                                    Content="{loc:Tr Common_Browse}"
                                    Style="{StaticResource App.Button.Secondary}"
                                    helpers:Theme.Icon="{StaticResource Icon.Folder}"
                                    Command="{Binding BrowseFfmpegCommand}" />
            </Grid>

                        <TextBlock Text="{loc:Tr Settings_FfprobePath}"
                                   Style="{StaticResource App.Type.Caption}" />
                        <Grid Margin="0,4,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding FfprobePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Margin="8,0,0,0"
                                    Content="{loc:Tr Common_Browse}"
                                    Style="{StaticResource App.Button.Secondary}"
                                    helpers:Theme.Icon="{StaticResource Icon.Folder}"
                                    Command="{Binding BrowseFfprobeCommand}" />
            </Grid>

                        <TextBlock Text="{loc:Tr Settings_Playback_Header}" Style="{StaticResource App.Type.Section}" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource App.Type.BodyMuted}" Margin="0,0,0,12"
                                   Text="{loc:Tr Settings_Proxy_Desc}" />
                        <CheckBox IsChecked="{Binding PreferProxyForPlayback}"
                                  Content="{loc:Tr Settings_Proxy_Check}"
                                  Margin="0,0,0,12" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource App.Type.BodyMuted}" Margin="0,0,0,12"
                                   Text="{loc:Tr Settings_Telemetry_Desc}" />
                        <CheckBox IsChecked="{Binding ShowPlayerTelemetry}"
                                  Content="{loc:Tr Settings_Telemetry_Check}"
                                  Margin="0,0,0,16" />

                        <TextBlock Text="{loc:Tr Settings_Map_Header}" Style="{StaticResource App.Type.Section}" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource App.Type.BodyMuted}" Margin="0,0,0,12"
                                   Text="{loc:Tr Settings_FlightPath_Desc}" />
                        <CheckBox IsChecked="{Binding ShowDroneFlightPaths}"
                                  Content="{loc:Tr Settings_FlightPath_Check}"
                                  Margin="0,0,0,16" />

                        <TextBlock Text="{loc:Tr Settings_Grid_Header}" Style="{StaticResource App.Type.Section}" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource App.Type.BodyMuted}" Margin="0,0,0,12"
                                   Text="{loc:Tr Settings_HoverScrub_Desc}" />
                        <CheckBox IsChecked="{Binding EnableHoverScrubPreview}"
                                  Content="{loc:Tr Settings_HoverScrub_Check}"
                                  Margin="0,0,0,16" />
                    </StackPanel>
                </ScrollViewer>

                <!-- ============================= REVIEW ============================= -->
                <ScrollViewer x:Name="PageReview" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,16,20,16">

                        <TextBlock Text="{loc:Tr Settings_Review_Header}" Style="{StaticResource App.Type.Section}" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource App.Type.BodyMuted}" Margin="0,0,0,12"
                                   Text="{loc:Tr Settings_Review_Desc}" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="{loc:Tr Settings_Review_Fill}"
                                    Style="{StaticResource App.Button.Secondary}"
                                    helpers:Theme.Icon="{StaticResource Icon.Tag}"
                                    Command="{Binding FillFromMostUsedCommand}"
                                    ToolTip="{loc:Tr Settings_Review_Fill_Tip}" />
                            <Button Content="{loc:Tr Settings_Review_ClearAll}"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource App.Button.Ghost}"
                                    Command="{Binding ClearAllPinnedTagsCommand}" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding PinnedTagSlots}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="28" Height="28"
                                                CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource App.Background.Elevated}"
                                                BorderBrush="{DynamicResource App.Border.Subtle}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding KeyLabel}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="{StaticResource App.FontFamily.Mono}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource App.Foreground.Secondary}" />
                                        </Border>
                                        <ComboBox Grid.Column="1"
                                                  Margin="8,0,0,0"
                                                  VerticalAlignment="Center"
                                                  ui:ControlHelper.PlaceholderText="{loc:Tr Settings_Review_NotBound}"
                                                  ItemsSource="{Binding DataContext.AvailableTags, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding SelectedTag, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <Run Text="{Binding Name, Mode=OneWay}" />
                                                        <Run Text="{Binding Type, Mode=OneWay}"
                                                             Foreground="{DynamicResource App.Foreground.Tertiary}" />
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button Grid.Column="2"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource App.Button.Ghost}"
                                                helpers:Theme.Icon="{StaticResource Icon.Close}"
                                                Command="{Binding ClearCommand}"
                                                ToolTip="{loc:Tr Settings_Review_Unbind_Tip}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- ============================== AI =============================== -->
                <ScrollViewer x:Name="PageAi" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,16,20,16">

                        <TextBlock Text="{loc:Tr Settings_Ai_Header}" Style="{StaticResource App.Type.Section}" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource App.Type.BodyMuted}" Margin="0,0,0,12"
                                   Text="{loc:Tr Settings_Ai_Desc}" />
                        <CheckBox IsChecked="{Binding EnableAiTagging}"
                                  Content="{loc:Tr Settings_Ai_Check}"
                                  Margin="0,0,0,16" />

                        <TextBlock Text="{loc:Tr Settings_Ai_Model_Header}" Style="{StaticResource App.Type.Section}" />
                        <TextBlock Text="{Binding AiModelStatus}"
                     TextWrapping="Wrap"
                                   Style="{StaticResource App.Type.Caption}"
                                   Margin="0,0,0,8" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                    IsEnabled="{Binding EnableAiTagging}">
                            <Button Content="{loc:Tr Settings_Ai_Download}"
                                    Style="{StaticResource App.Button.Secondary}"
                                    helpers:Theme.Icon="{StaticResource Icon.Cloud}"
                                    Command="{Binding DownloadModelCommand}"
                                    IsEnabled="{Binding CanDownloadModel}" />
                            <Button Content="{loc:Tr Settings_Ai_ClearData}"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource App.Button.Ghost}"
                                    Command="{Binding ClearAiDataCommand}"
                                    ToolTip="{loc:Tr Settings_Ai_ClearData_Tip}" />
        </StackPanel>

                        <ProgressBar Minimum="0" Maximum="1" Height="4"
                                     Value="{Binding AiDownloadProgress}"
                                     Margin="0,0,0,12"
                                     Visibility="{Binding IsDownloadingModel, Converter={StaticResource BoolToVisibility}}" />

                        <TextBlock Text="{loc:Tr Settings_Ai_ModelFolder}"
                                   Style="{StaticResource App.Type.Caption}" TextWrapping="Wrap" />
                        <Grid Margin="0,4,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding AiModelDirectory, UpdateSourceTrigger=LostFocus}" />
                            <Button Grid.Column="1" Margin="8,0,0,0"
                                    Content="{loc:Tr Common_Browse}"
                                    Style="{StaticResource App.Button.Secondary}"
                                    helpers:Theme.Icon="{StaticResource Icon.Folder}"
                                    Command="{Binding BrowseAiModelDirectoryCommand}" />
                        </Grid>

                        <TextBlock Text="{loc:Tr Settings_Ai_Tuning_Header}" Style="{StaticResource App.Type.Section}" />

                        <TextBlock Text="{loc:Tr Settings_Ai_SecondsPerFrame}"
                                   Style="{StaticResource App.Type.Caption}" TextWrapping="Wrap" />
                        <ui:NumberBox Value="{Binding AiSecondsPerFrame}" Minimum="2" Maximum="120"
                                      SmallChange="1" LargeChange="5" Margin="0,4,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Tr Settings_Ai_MinFrames}"
                                           Style="{StaticResource App.Type.Caption}" TextWrapping="Wrap" />
                                <ui:NumberBox Value="{Binding AiMinFramesPerClip}" Minimum="1" Maximum="64" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{loc:Tr Settings_Ai_MaxFrames}"
                                           Style="{StaticResource App.Type.Caption}" TextWrapping="Wrap" />
                                <ui:NumberBox Value="{Binding AiMaxFramesPerClip}" Minimum="1" Maximum="128" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{loc:Tr Settings_Ai_Threshold}"
                                   Style="{StaticResource App.Type.Caption}" TextWrapping="Wrap" />
                        <ui:NumberBox Value="{Binding AiSuggestionThreshold}"
                                      Minimum="0.10" Maximum="0.90"
                                      SmallChange="0.01" LargeChange="0.05"
                                      Margin="0,4,0,12" />

                        <CheckBox Content="{loc:Tr Settings_Ai_Adaptive}"
                                  IsChecked="{Binding AiAdaptiveThresholds}" Margin="0,0,0,4" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource App.Type.Caption}"
                                   Text="{loc:Tr Settings_Ai_Adaptive_Desc}" />

                        <TextBlock TextWrapping="Wrap" Style="{StaticResource App.Type.Caption}"
                                   Text="{loc:Tr Settings_Ai_Footer}" />
                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </ui:NavigationView>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,12,24,24">
            <Button Content="{loc:Tr Common_Cancel}"
                    Style="{StaticResource App.Button.Ghost}"
                    Command="{Binding CancelCommand}" />
            <Button Content="{loc:Tr Common_Save}"
                    Margin="8,0,0,0"
                    Style="{StaticResource App.Button.Primary}"
                    helpers:Theme.Icon="{StaticResource Icon.Save}"
                    Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
