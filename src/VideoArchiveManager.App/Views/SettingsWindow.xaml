<Window x:Class="VideoArchiveManager.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Settings"
        Width="680" Height="780"
        MinWidth="560" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ui:WindowHelper.UseModernWindowStyle="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Application settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,12,0">
                <TextBlock Text="FFmpeg" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4" />

                <TextBlock Text="ffmpeg.exe path (leave blank to use PATH)" Opacity="0.7" />
                <Grid Margin="0,2,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1" Margin="6,0,0,0" Content="Browse..." Command="{Binding BrowseFfmpegCommand}" />
                </Grid>

                <TextBlock Text="ffprobe.exe path (leave blank to use PATH)" Opacity="0.7" />
                <Grid Margin="0,2,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding FfprobePath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1" Margin="6,0,0,0" Content="Browse..." Command="{Binding BrowseFfprobeCommand}" />
                </Grid>

                <TextBlock Text="Storage" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4" />

                <TextBlock Text="Thumbnail directory" Opacity="0.7" />
                <TextBox Text="{Binding ThumbnailDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,2,0,12" />

                <TextBlock Text="Database file" Opacity="0.7" />
                <TextBox Text="{Binding DatabasePath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,2,0,16" />

                <TextBlock Text="Catalog backup" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4" />
                <TextBlock TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,8"
                           Text="The app can back up the catalog database (your tags, ratings, notes, status) to a folder you choose. Source video files are never touched." />

                <TextBlock Text="Backup directory" Opacity="0.7" />
                <Grid Margin="0,2,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding BackupDirectory, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1" Margin="6,0,0,0" Content="Browse..." Command="{Binding BrowseBackupDirectoryCommand}" />
                </Grid>

                <CheckBox IsChecked="{Binding AutoBackupOnStartup}"
                          Content="Back up automatically on app startup"
                          Margin="0,0,0,8" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                    <TextBlock Text="Keep last" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ui:NumberBox Width="100"
                                  Minimum="1" Maximum="365"
                                  Value="{Binding BackupRetentionCount}" />
                    <TextBlock Text="backup(s); older backups are deleted." VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Button Content="Back up now"
                            Command="{Binding BackupNowCommand}"
                            IsEnabled="{Binding IsBackingUp, Converter={StaticResource InverseBool}}" />
                    <Button Content="Refresh list" Margin="6,0,0,0"
                            Command="{Binding RefreshBackupsCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding BackupStatusMessage}"
                           TextWrapping="Wrap"
                           Opacity="0.75"
                           FontSize="12"
                           Margin="0,4,0,8" />

                <TextBlock Text="Available backups (select one to restore)" Opacity="0.7" />
                <ListBox ItemsSource="{Binding Backups}"
                         SelectedItem="{Binding SelectedBackup}"
                         Height="140"
                         Margin="0,2,0,6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Path}" Opacity="0.6" FontSize="11" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.7" Margin="12,0,0,0">
                                    <Run Text="{Binding CreatedAtUtc, Mode=OneWay, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Content="Restore selected..."
                            Command="{Binding RestoreCommand}"
                            ToolTip="Stage a restore from the selected backup. The app will restart to safely swap the database file." />
                </StackPanel>

                <TextBlock Text="Sidecar files" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4" />
                <TextBlock TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,8"
                           Text="When enabled, a small &quot;&lt;filename&gt;.findthatshot.json&quot; file is written next to each video on save, containing its tags, rating, status and notes. Other tools (DaVinci Resolve, Premiere, Lightroom, FCP, etc.) ignore these files. Source video files are never modified. Failures on read-only / offline drives are skipped silently." />
                <CheckBox IsChecked="{Binding WriteSidecarFiles}"
                          Content="Write sidecar JSON files next to videos"
                          Margin="0,0,0,16" />

                <TextBlock Text="Scanning" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4" />

                <TextBlock Text="Max scan parallelism" Opacity="0.7" />
                <ui:NumberBox Value="{Binding MaxScanParallelism}" Minimum="1" Maximum="16" Margin="0,2,0,12" />

                <TextBlock Text="Excluded folder names (comma-separated, matched on any path segment, case-insensitive)" Opacity="0.7" TextWrapping="Wrap" />
                <TextBox Text="{Binding ExcludedFolderNames, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="60"
                         Margin="0,2,0,12" />

                <TextBlock Text="Excluded file name patterns (comma-separated globs, e.g. *_proxy.mp4, *.LRV)" Opacity="0.7" TextWrapping="Wrap" />
                <TextBox Text="{Binding ExcludedFileNamePatterns, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="40"
                         Margin="0,2,0,12" />

                <TextBlock TextWrapping="Wrap"
                           Opacity="0.6"
                           Text="Settings are saved to %APPDATA%\VideoArchiveManager\settings.json. Changes to the database path require an app restart." />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" />
            <Button Content="Save" Margin="6,0,0,0"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
