<Window x:Class="VideoArchiveManager.App.Views.AiReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:VideoArchiveManager.App.ViewModels"
        Title="Review AI suggestions"
        Width="820" Height="820"
        MinWidth="620" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        d:DataContext="{d:DesignInstance Type=vm:AiReviewViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Window.Resources>

        <!-- One accept/reject chip for a suggested tag. -->
        <DataTemplate x:Key="AiChipTemplate" DataType="{x:Type vm:AiReviewChipViewModel}">
            <Border Margin="0,0,8,8"
                    Padding="4,2,4,2"
                    CornerRadius="14"
                    Background="{DynamicResource App.Background.Inset}"
                    BorderBrush="{DynamicResource App.Border.Subtle}"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Width="22" Height="22" Padding="0" Margin="2,0,2,0"
                            Style="{StaticResource App.Button.Ghost}"
                            Command="{Binding AcceptCommand}"
                            ToolTip="Accept — add this tag to the clip">
                        <TextBlock Text="&#x2713;" FontWeight="Bold"
                                   Foreground="{DynamicResource App.Accent}" />
                    </Button>
                    <TextBlock Text="{Binding TagName}"
                               VerticalAlignment="Center"
                               Margin="2,0,4,0"
                               Style="{StaticResource App.Type.Body}" />
                    <TextBlock Text="{Binding ConfidenceText}"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Style="{StaticResource App.Type.Caption}" />
                    <Button Width="22" Height="22" Padding="0" Margin="0,0,2,0"
                            Style="{StaticResource App.Button.Ghost}"
                            Command="{Binding RejectCommand}"
                            ToolTip="Reject — dismiss this suggestion">
                        <TextBlock Text="&#x2715;"
                                   Foreground="{DynamicResource App.Foreground.Tertiary}" />
                    </Button>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- One clip card: thumbnail + header + chips + accept-all / reject-all. -->
        <DataTemplate x:Key="AiGroupTemplate" DataType="{x:Type vm:AiReviewGroupViewModel}">
            <Border Margin="0,0,0,14"
                    Padding="16,14"
                    Background="{DynamicResource App.Background.Elevated}"
                    BorderBrush="{DynamicResource App.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="132" Height="74"
                            CornerRadius="4"
                            Margin="0,0,14,0"
                            VerticalAlignment="Top"
                            ClipToBounds="True"
                            Background="{DynamicResource App.Background.Base}">
                        <Image Source="{Binding Thumbnail}"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch" />
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding FileName}"
                                   Style="{StaticResource App.Type.Body}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FileName}" />
                        <TextBlock Text="{Binding FolderPath}"
                                   Style="{StaticResource App.Type.Caption}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FolderPath}"
                                   Margin="0,2,0,8" />

                        <ItemsControl ItemsSource="{Binding Chips}"
                                      ItemTemplate="{StaticResource AiChipTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="Accept all"
                                    Style="{StaticResource App.Button.Ghost}"
                                    Command="{Binding AcceptAllCommand}" />
                            <Button Content="Reject all"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource App.Button.Ghost}"
                                    Command="{Binding RejectAllCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid TextElement.FontFamily="{StaticResource App.FontFamily}"
          TextElement.Foreground="{DynamicResource App.Foreground.Primary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="24,20,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Review AI suggestions" Style="{StaticResource App.Type.Display}" />
                <TextBlock Text="{Binding SummaryText}"
                           Style="{StaticResource App.Type.Caption}"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Refresh"
                    VerticalAlignment="Top"
                    Style="{StaticResource App.Button.Secondary}"
                    Command="{Binding LoadCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <ui:ProgressRing IsActive="{Binding IsLoading}" Width="40" Height="40" />
                <TextBlock Text="Loading suggestions…"
                           Style="{StaticResource App.Type.BodyMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="420"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="No suggestions to review"
                           Style="{StaticResource App.Type.H1}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Run Catalog → Generate AI tags… to score your clips, then come back here to accept or reject the proposals."
                           Style="{StaticResource App.Type.BodyMuted}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="24,4,24,16"
                          Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl ItemsSource="{Binding Groups}"
                              ItemTemplate="{StaticResource AiGroupTemplate}" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
