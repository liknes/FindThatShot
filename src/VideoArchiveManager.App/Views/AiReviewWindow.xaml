<Window x:Class="VideoArchiveManager.App.Views.AiReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:VideoArchiveManager.App.ViewModels"
        xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers"
        xmlns:loc="clr-namespace:VideoArchiveManager.App.Localization"
        Title="{loc:Tr AiReview_Title}"
        Width="820" Height="820"
        MinWidth="620" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        d:DataContext="{d:DesignInstance Type=vm:AiReviewViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Window.Resources>

        <ControlTemplate x:Key="AiPreviewTip" TargetType="ToolTip">
            <Border Background="{DynamicResource App.Background.Elevated}"
                    BorderBrush="{DynamicResource App.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="6">
                <StackPanel Width="360">
                    <Grid Height="203">
                        <Border Background="{DynamicResource App.Background.Base}" CornerRadius="4" />
                        <ui:ProgressRing IsActive="{Binding IsPreviewLoading}"
                                         Width="28" Height="28"
                                         Visibility="{Binding IsPreviewLoading, Converter={StaticResource BoolToVisibility}}" />
                        <Image Source="{Binding PreviewImage}"
                               Stretch="Uniform"
                               Visibility="{Binding PreviewImage, Converter={StaticResource NullToVisibility}}" />
                        <TextBlock Text="{loc:Tr AiReview_OfflinePreview}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="16"
                                   Style="{StaticResource App.Type.BodyMuted}"
                                   Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>
                    <TextBlock Margin="2,6,2,2" Style="{StaticResource App.Type.Caption}">
                        <Run Text="{loc:Tr AiReview_BestFramePrefix}" />
                        <Run Text="{Binding TagName, Mode=OneWay}" FontWeight="SemiBold" />
                        <Run Text=" · " />
                        <Run Text="{Binding ConfidenceText, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </ControlTemplate>

        <Style x:Key="AiChipIconHover" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="4,0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource App.Accent.Subtle}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="AiChipTemplate" DataType="{x:Type vm:AiReviewChipViewModel}">
            <Border Margin="0,0,8,8"
                    Padding="4,2,4,2"
                    CornerRadius="14"
                    Background="{DynamicResource App.Background.Inset}"
                    BorderBrush="{DynamicResource App.Border.Subtle}"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Width="22" Height="22" Padding="0" Margin="2,0,2,0"
                            Style="{StaticResource App.Button.Ghost}"
                            Command="{Binding AcceptCommand}"
                            ToolTip="{loc:Tr AiReview_Accept_Tip}">
                        <TextBlock Text="&#x2713;" FontWeight="Bold"
                                   Foreground="{DynamicResource App.Accent}" />
                    </Button>
                    <TextBlock Text="{Binding TagName}"
                               VerticalAlignment="Center"
                               Margin="2,0,4,0"
                               Style="{StaticResource App.Type.Body}" />
                    <TextBlock Text="{Binding ConfidenceText}"
                               VerticalAlignment="Center"
                               Margin="0,0,2,0"
                               Style="{StaticResource App.Type.Caption}" />

                    <Border Style="{StaticResource AiChipIconHover}"
                            Margin="2,0,0,0"
                            Cursor="Hand"
                            Visibility="{Binding CanPreview, Converter={StaticResource BoolToVisibility}}"
                            ToolTipService.InitialShowDelay="200"
                            ToolTipService.BetweenShowDelay="0"
                            ToolTipOpening="Chip_ToolTipOpening">
                        <Border.ToolTip>
                            <ToolTip Background="Transparent" BorderThickness="0" Padding="0"
                                     HasDropShadow="False" Placement="Top"
                                     Template="{StaticResource AiPreviewTip}" />
                        </Border.ToolTip>
                        <TextBlock FontFamily="{StaticResource App.Icon.FontFamily}"
                                   FontSize="12"
                                   Text="{StaticResource Icon.Image}"
                                   Foreground="{DynamicResource App.Foreground.Secondary}"
                                   VerticalAlignment="Center" />
                    </Border>

                    <Button Width="24" Height="22" Padding="0" Margin="2,0,2,0"
                            Style="{StaticResource App.Button.Ghost}"
                            Cursor="Hand"
                            Command="{Binding JumpCommand}"
                            Visibility="{Binding CanPreview, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="{loc:Tr AiReview_Play_Tip}">
                        <TextBlock FontFamily="{StaticResource App.Icon.FontFamily}"
                                   FontSize="12"
                                   Text="{StaticResource Icon.Movie}"
                                   Foreground="{DynamicResource App.Foreground.Secondary}"
                                   VerticalAlignment="Center" />
                    </Button>

                    <Button Width="22" Height="22" Padding="0" Margin="0,0,2,0"
                            Style="{StaticResource App.Button.Ghost}"
                            Command="{Binding RejectCommand}"
                            ToolTip="{loc:Tr AiReview_Reject_Tip}">
                        <TextBlock Text="&#x2715;"
                                   Foreground="{DynamicResource App.Foreground.Tertiary}" />
                    </Button>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="AiGroupTemplate" DataType="{x:Type vm:AiReviewGroupViewModel}">
            <Border Margin="0,0,0,14"
                    Padding="16,14"
                    Background="{DynamicResource App.Background.Elevated}"
                    BorderBrush="{DynamicResource App.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="132" Height="74"
                            CornerRadius="4"
                            Margin="0,0,14,0"
                            VerticalAlignment="Top"
                            ClipToBounds="True"
                            Background="{DynamicResource App.Background.Base}">
                        <Image helpers:AsyncImage.SourcePath="{Binding ThumbnailPath}"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch" />
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding FileName}"
                                   Style="{StaticResource App.Type.Body}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FileName}" />
                        <TextBlock Text="{Binding FolderPath}"
                                   Style="{StaticResource App.Type.Caption}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FolderPath}"
                                   Margin="0,2,0,8" />

                        <ItemsControl ItemsSource="{Binding Chips}"
                                      ItemTemplate="{StaticResource AiChipTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="{loc:Tr Common_AcceptAll}"
                                    Style="{StaticResource App.Button.Ghost}"
                                    Command="{Binding AcceptAllCommand}" />
                            <Button Content="{loc:Tr Common_RejectAll}"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource App.Button.Ghost}"
                                    Command="{Binding RejectAllCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid TextElement.FontFamily="{StaticResource App.FontFamily}"
          TextElement.Foreground="{DynamicResource App.Foreground.Primary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="24,20,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{loc:Tr AiReview_Title}" Style="{StaticResource App.Type.Display}" />
                <TextBlock Text="{Binding SummaryText}"
                           Style="{StaticResource App.Type.Caption}"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="{loc:Tr Common_Refresh}"
                    VerticalAlignment="Top"
                    Style="{StaticResource App.Button.Secondary}"
                    Command="{Binding LoadCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />
        </Grid>

        <Grid Grid.Row="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <ui:ProgressRing IsActive="{Binding IsLoading}" Width="40" Height="40" />
                <TextBlock Text="{loc:Tr AiReview_Loading}"
                           Style="{StaticResource App.Type.BodyMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="420"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{loc:Tr AiReview_Empty_Headline}"
                           Style="{StaticResource App.Type.H1}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Tr AiReview_Empty_Subtext}"
                           Style="{StaticResource App.Type.BodyMuted}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>

            <ListBox ItemsSource="{Binding Groups}"
                     ItemTemplate="{StaticResource AiGroupTemplate}"
                     Padding="24,4,24,16"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     KeyboardNavigation.TabNavigation="Continue"
                     Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>
    </Grid>
</Window>
