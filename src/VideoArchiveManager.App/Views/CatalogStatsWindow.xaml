<Window x:Class="VideoArchiveManager.App.Views.CatalogStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:VideoArchiveManager.App.ViewModels"
        Title="Catalog statistics"
        Width="760" Height="780"
        MinWidth="560" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        d:DataContext="{d:DesignInstance Type=vm:CatalogStatsViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Window.Resources>

        <!-- A single breakdown row: label · proportional bar · count + share. -->
        <DataTemplate x:Key="StatBarTemplate" DataType="{x:Type vm:StatBarItem}">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="118" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Label}"
                           Style="{StaticResource App.Type.Body}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Label}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />

                <Border Grid.Column="1"
                        Height="8"
                        VerticalAlignment="Center"
                        CornerRadius="4"
                        Background="{DynamicResource App.Background.Inset}">
                    <Border HorizontalAlignment="Left"
                            CornerRadius="4"
                            Background="{DynamicResource App.Accent}">
                        <Border.Width>
                            <MultiBinding Converter="{StaticResource RatioToWidth}">
                                <Binding Path="Count" />
                                <Binding Path="Max" />
                                <Binding Path="ActualWidth"
                                         RelativeSource="{RelativeSource AncestorType=Border}" />
                            </MultiBinding>
                        </Border.Width>
                    </Border>
                </Border>

                <TextBlock Grid.Column="2"
                           Text="{Binding CountText}"
                           Style="{StaticResource App.Type.BodySmall}"
                           VerticalAlignment="Center"
                           MinWidth="92"
                           TextAlignment="Right"
                           Margin="12,0,0,0" />
            </Grid>
        </DataTemplate>

        <!-- One titled breakdown card (status / rating / cameras / …). -->
        <DataTemplate x:Key="StatSectionTemplate" DataType="{x:Type vm:StatSection}">
            <Border Width="336"
                    Margin="0,0,16,16"
                    Padding="18,16"
                    VerticalAlignment="Top"
                    Background="{DynamicResource App.Background.Elevated}"
                    BorderBrush="{DynamicResource App.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               Style="{StaticResource App.Type.H2}"
                               Margin="0,0,0,10" />
                    <ItemsControl ItemsSource="{Binding Items}"
                                  ItemTemplate="{StaticResource StatBarTemplate}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- A headline-number overview card. -->
        <DataTemplate x:Key="OverviewMetricTemplate" DataType="{x:Type vm:OverviewMetric}">
            <Border Width="168"
                    Margin="0,0,12,12"
                    Padding="16,14"
                    VerticalAlignment="Top"
                    Background="{DynamicResource App.Background.Elevated}"
                    BorderBrush="{DynamicResource App.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="{Binding Value}"
                               FontFamily="{StaticResource App.FontFamily.Display}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource App.Foreground.Primary}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Label}"
                               Style="{StaticResource App.Type.Body}"
                               Margin="0,4,0,0" />
                    <TextBlock Text="{Binding Detail}"
                               Style="{StaticResource App.Type.Caption}"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid TextElement.FontFamily="{StaticResource App.FontFamily}"
          TextElement.Foreground="{DynamicResource App.Foreground.Primary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="24,20,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Catalog statistics" Style="{StaticResource App.Type.Display}" />
                <TextBlock Text="A live snapshot of your catalog. Read-only — your source video files are never touched."
                           Style="{StaticResource App.Type.Caption}"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Refresh"
                    VerticalAlignment="Top"
                    Style="{StaticResource App.Button.Secondary}"
                    Command="{Binding LoadCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1">

            <!-- Loading -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <ui:ProgressRing IsActive="{Binding IsLoading}" Width="40" Height="40" />
                <TextBlock Text="Computing statistics…"
                           Style="{StaticResource App.Type.BodyMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
            </StackPanel>

            <!-- Empty catalog -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="380"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Nothing to summarise yet"
                           Style="{StaticResource App.Type.H1}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Add a root folder and run a scan, then reopen this window to see your catalog at a glance."
                           Style="{StaticResource App.Type.BodyMuted}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       MaxWidth="420"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="{DynamicResource App.Destructive}"
                       Style="{StaticResource App.Type.Body}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}" />

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="24,0,24,20"
                          Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="OVERVIEW" Style="{StaticResource App.Type.Section}" Margin="0,0,0,10" />
                    <ItemsControl ItemsSource="{Binding Overview}"
                                  ItemTemplate="{StaticResource OverviewMetricTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <TextBlock Text="BREAKDOWNS" Style="{StaticResource App.Type.Section}" Margin="0,16,0,10" />
                    <ItemsControl ItemsSource="{Binding Sections}"
                                  ItemTemplate="{StaticResource StatSectionTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
