<Window x:Class="VideoArchiveManager.App.Views.BulkEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls"
        xmlns:loc="clr-namespace:VideoArchiveManager.App.Localization"
        Title="{loc:Tr BulkEdit_Title}"
        Width="540" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        ResizeMode="NoResize">
    <Grid Margin="24"
          TextElement.FontFamily="{StaticResource App.FontFamily}"
          TextElement.Foreground="{DynamicResource App.Foreground.Primary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{loc:Tr BulkEdit_Header}" Style="{StaticResource App.Type.H1}" />
            <TextBlock Text="{loc:Tr BulkEdit_Desc}"
                       Style="{StaticResource App.Type.BodyMuted}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1">
            <CheckBox Content="{loc:Tr BulkEdit_SetStatus}" IsChecked="{Binding ApplyStatus}" />
            <ComboBox Margin="24,4,0,16"
                      ItemsSource="{Binding AvailableStatuses}"
                      SelectedItem="{Binding Status}"
                      IsEnabled="{Binding ApplyStatus}" />

            <CheckBox Content="{loc:Tr BulkEdit_SetRating}" IsChecked="{Binding ApplyRating}" />
            <ui:NumberBox Margin="24,4,0,16" Minimum="0" Maximum="5"
                          Value="{Binding Rating}"
                          IsEnabled="{Binding ApplyRating}" />

            <CheckBox Content="{loc:Tr BulkEdit_AppendNotes}" IsChecked="{Binding ApplyNotesAppend}" />
            <TextBox Margin="24,4,0,16"
                     Text="{Binding NotesToAppend, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="80"
                     IsEnabled="{Binding ApplyNotesAppend}" />

            <CheckBox Content="{loc:Tr BulkEdit_AddTag}" IsChecked="{Binding ApplyTag}" />
            <StackPanel Orientation="Horizontal" Margin="24,4,0,12" IsEnabled="{Binding ApplyTag}">
                <ui:AutoSuggestBox Width="180"
                                   Text="{Binding NewTagName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   ItemsSource="{Binding TagSuggestions}"
                                   PlaceholderText="{loc:Tr BulkEdit_TagNamePlaceholder}" />
                <ComboBox Width="140" Margin="6,0,0,0"
                          ItemsSource="{Binding AvailableTagTypes}"
                          SelectedItem="{Binding NewTagType}" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{loc:Tr Common_Cancel}"
                    Style="{StaticResource App.Button.Ghost}"
                    Command="{Binding CancelCommand}" />
            <Button Content="{loc:Tr Common_Apply}"
                    Margin="8,0,0,0"
                    Style="{StaticResource App.Button.Primary}"
                    helpers:Theme.Icon="{StaticResource Icon.Save}"
                    Command="{Binding ApplyCommand}" />
        </StackPanel>
    </Grid>
</Window>
