<Window x:Class="VideoArchiveManager.App.Views.VideoInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls"
        Title="Clip info"
        Width="560" Height="640"
        MinWidth="420" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="ApplicationCommands.Close" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Close" Executed="Close_Executed" />
    </Window.CommandBindings>

    <Window.Resources>
        <!-- Visibility helpers used to hide optional sections / rows. We
             don't want to leak StringNotEmptyToVisibility into the global
             converter dictionary just for this dialog, so the converter
             is local. -->
        <Style x:Key="OptionalRowStyle" TargetType="helpers:InfoRow">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <Trigger Property="Value" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Value" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid TextElement.FontFamily="{StaticResource App.FontFamily}"
          TextElement.Foreground="{DynamicResource App.Foreground.Primary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: thumbnail + filename + path. Stays pinned while the
             body scrolls so you always see which clip you're looking at. -->
        <Border Grid.Row="0"
                Background="{DynamicResource App.Background.Elevated}"
                BorderBrush="{DynamicResource App.Border.Subtle}"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="120" Height="68"
                        Background="Black"
                        CornerRadius="4"
                        Margin="0,0,16,0">
                    <Image Source="{Binding Thumbnail}"
                           Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FileName}"
                               Style="{StaticResource App.Type.H1}"
                               FontSize="18"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />
                    <TextBlock Text="{Binding FilePath}"
                               Style="{StaticResource App.Type.Caption}"
                               FontFamily="{StaticResource App.FontFamily.Mono}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>
                <!-- FILE -->
                <TextBlock Text="FILE" Style="{StaticResource App.Type.Section}" />
                <helpers:InfoRow Label="Filename" Value="{Binding FileName}" />
                <helpers:InfoRow Label="Full path" Value="{Binding FilePath}" IsMono="True" />
                <helpers:InfoRow Label="Folder" Value="{Binding FolderPath}" IsMono="True" />
                <helpers:InfoRow Label="Extension" Value="{Binding Extension}" />
                <helpers:InfoRow Label="Size"
                                 Value="{Binding FileSizeText}"
                                 SubValue="{Binding FileSizeBytesText}" />
                <helpers:InfoRow Label="Modified" Value="{Binding ModifiedAtText}" />
                <helpers:InfoRow Label="Created" Value="{Binding CreatedAtFileText}" />
                <helpers:InfoRow Label="On disk" Value="{Binding FileExistsText}" />

                <!-- VIDEO -->
                <TextBlock Text="VIDEO" Style="{StaticResource App.Type.Section}" Margin="0,16,0,0" />
                <helpers:InfoRow Label="Duration" Value="{Binding DurationText}" IsMono="True" />
                <helpers:InfoRow Label="Resolution" Value="{Binding Resolution}" />
                <helpers:InfoRow Label="Aspect ratio"
                                 Style="{StaticResource OptionalRowStyle}"
                                 Value="{Binding AspectRatioText}" />
                <helpers:InfoRow Label="Frame rate"
                                 Style="{StaticResource OptionalRowStyle}"
                                 Value="{Binding FrameRateText}" />
                <helpers:InfoRow Label="Codec"
                                 Style="{StaticResource OptionalRowStyle}"
                                 Value="{Binding Codec}" />

                <!-- CAMERA (only if Camera is set) -->
                <StackPanel Visibility="{Binding HasCamera, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="CAMERA" Style="{StaticResource App.Type.Section}" Margin="0,16,0,0" />
                    <helpers:InfoRow Label="Make / model" Value="{Binding Camera}" />
                </StackPanel>

                <!-- LOCATION (only if any location field is set) -->
                <StackPanel Visibility="{Binding HasAnyLocation, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="LOCATION" Style="{StaticResource App.Type.Section}" Margin="0,16,0,0" />
                    <helpers:InfoRow Label="Folder location"
                                     Style="{StaticResource OptionalRowStyle}"
                                     Value="{Binding LocationText}" />
                    <Grid Visibility="{Binding HasGps, Converter={StaticResource BoolToVisibility}}"
                          Margin="0,3,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="GPS"
                                   Foreground="{DynamicResource App.Foreground.Tertiary}"
                                   FontSize="11"
                                   VerticalAlignment="Top"
                                   Margin="0,2,12,0" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding GpsText}"
                                       FontFamily="{StaticResource App.FontFamily.Mono}"
                                       FontSize="13" />
                            <TextBlock Margin="10,0,0,0" FontSize="13">
                                <Hyperlink NavigateUri="{Binding GpsMapUrl}"
                                           RequestNavigate="Hyperlink_RequestNavigate"
                                           Foreground="{DynamicResource App.Accent}">
                                    Open in map
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <helpers:InfoRow Label="Folder date"
                                     Style="{StaticResource OptionalRowStyle}"
                                     Value="{Binding FolderDateText}" />
                </StackPanel>

                <!-- CATALOG -->
                <TextBlock Text="CATALOG" Style="{StaticResource App.Type.Section}" Margin="0,16,0,0" />
                <helpers:InfoRow Label="Status" Value="{Binding StatusText}" />
                <helpers:InfoRow Label="Rating" Value="{Binding RatingText}" />

                <!-- Tags row: rendered as inline chip list, not a copyable string. -->
                <Grid Margin="0,3,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Tags"
                               Foreground="{DynamicResource App.Foreground.Tertiary}"
                               FontSize="11"
                               VerticalAlignment="Top"
                               Margin="0,4,12,0" />
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Tags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource App.TagChip.ReadOnly}">
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource App.TagChip.Text}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Grid.Column="1"
                               Text="No tags"
                               Foreground="{DynamicResource App.Foreground.Tertiary}"
                               FontStyle="Italic"
                               FontSize="13"
                               Margin="0,2,0,0"
                               Visibility="{Binding HasTags, Converter={StaticResource BoolToVisibilityInverted}}" />
                </Grid>

                <helpers:InfoRow Label="Notes"
                                 Style="{StaticResource OptionalRowStyle}"
                                 Value="{Binding NotesPreview}" />
                <helpers:InfoRow Label="Sidecar"
                                 Value="{Binding SidecarStatusText}"
                                 SubValue="{Binding SidecarPathText}" />
                <helpers:InfoRow Label="Added to catalog" Value="{Binding CreatedAtText}" />
                <helpers:InfoRow Label="Last updated" Value="{Binding UpdatedAtText}" />

                <!-- INTERNAL -->
                <TextBlock Text="INTERNAL" Style="{StaticResource App.Type.Section}" Margin="0,16,0,0" />
                <helpers:InfoRow Label="Catalog ID" Value="{Binding CatalogIdText}" IsMono="True" />
                <helpers:InfoRow Label="Thumbnail"
                                 Style="{StaticResource OptionalRowStyle}"
                                 Value="{Binding ThumbnailPath}"
                                 IsMono="True" />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer with a single Close button. The window is non-modal so
             the caller doesn't await a result; we just dismiss. -->
        <Border Grid.Row="2"
                Background="{DynamicResource App.Background.Elevated}"
                BorderBrush="{DynamicResource App.Border.Subtle}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Close"
                        Style="{StaticResource App.Button.Ghost}"
                        Click="Close_Click"
                        IsCancel="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
