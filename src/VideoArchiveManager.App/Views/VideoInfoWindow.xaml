<Window x:Class="VideoArchiveManager.App.Views.VideoInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls"
        xmlns:loc="clr-namespace:VideoArchiveManager.App.Localization"
        Title="{loc:Tr VideoInfo_Title}"
        Width="560" Height="640"
        MinWidth="420" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="ApplicationCommands.Close" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Close" Executed="Close_Executed" />
    </Window.CommandBindings>

    <Window.Resources>
        <!-- Visibility helpers used to hide optional sections / rows. We
             don't want to leak StringNotEmptyToVisibility into the global
             converter dictionary just for this dialog, so the converter
             is local. -->
        <Style x:Key="OptionalRowStyle" TargetType="helpers:InfoRow">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <Trigger Property="Value" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Value" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid TextElement.FontFamily="{StaticResource App.FontFamily}"
          TextElement.Foreground="{DynamicResource App.Foreground.Primary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: thumbnail + filename + path. Stays pinned while the
             body scrolls so you always see which clip you're looking at. -->
        <Border Grid.Row="0"
                Background="{DynamicResource App.Background.Elevated}"
                BorderBrush="{DynamicResource App.Border.Subtle}"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="120" Height="68"
                        Background="Black"
                        CornerRadius="4"
                        Margin="0,0,16,0">
                    <Image Source="{Binding Thumbnail}"
                           Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FileName}"
                               Style="{StaticResource App.Type.H1}"
                               FontSize="18"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />
                    <TextBlock Text="{Binding FilePath}"
                               Style="{StaticResource App.Type.Caption}"
                               FontFamily="{StaticResource App.FontFamily.Mono}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>
                <!-- FILE -->
                <TextBlock Text="{loc:Tr VideoInfo_Section_File}" Style="{StaticResource App.Type.Section}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Filename}" Value="{Binding FileName}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_FullPath}" Value="{Binding FilePath}" IsMono="True" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Folder}" Value="{Binding FolderPath}" IsMono="True" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Extension}" Value="{Binding Extension}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Size}"
                                 Value="{Binding FileSizeText}"
                                 SubValue="{Binding FileSizeBytesText}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Modified}" Value="{Binding ModifiedAtText}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Created}" Value="{Binding CreatedAtFileText}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_OnDisk}" Value="{Binding FileExistsText}" />

                <!-- VIDEO -->
                <TextBlock Text="{loc:Tr VideoInfo_Section_Video}" Style="{StaticResource App.Type.Section}" Margin="0,16,0,0" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Duration}" Value="{Binding DurationText}" IsMono="True" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Resolution}" Value="{Binding Resolution}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_AspectRatio}"
                                 Style="{StaticResource OptionalRowStyle}"
                                 Value="{Binding AspectRatioText}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_FrameRate}"
                                 Style="{StaticResource OptionalRowStyle}"
                                 Value="{Binding FrameRateText}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Codec}"
                                 Style="{StaticResource OptionalRowStyle}"
                                 Value="{Binding Codec}" />

                <!-- CAMERA (only if Camera is set) -->
                <StackPanel Visibility="{Binding HasCamera, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{loc:Tr VideoInfo_Section_Camera}" Style="{StaticResource App.Type.Section}" Margin="0,16,0,0" />
                    <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Camera}" Value="{Binding Camera}" />
                </StackPanel>

                <!-- LOCATION (only if any location field is set) -->
                <StackPanel Visibility="{Binding HasAnyLocation, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{loc:Tr VideoInfo_Section_Location}" Style="{StaticResource App.Type.Section}" Margin="0,16,0,0" />
                    <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_FolderLocation}"
                                     Style="{StaticResource OptionalRowStyle}"
                                     Value="{Binding LocationText}" />
                    <Grid Visibility="{Binding HasGps, Converter={StaticResource BoolToVisibility}}"
                          Margin="0,3,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Tr VideoInfo_Label_Gps}"
                                   Foreground="{DynamicResource App.Foreground.Tertiary}"
                                   FontSize="11"
                                   VerticalAlignment="Top"
                                   Margin="0,2,12,0" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding GpsText}"
                                       FontFamily="{StaticResource App.FontFamily.Mono}"
                                       FontSize="13" />
                            <TextBlock Margin="10,0,0,0" FontSize="13">
                                <Hyperlink NavigateUri="{Binding GpsMapUrl}"
                                           RequestNavigate="Hyperlink_RequestNavigate"
                                           Foreground="{DynamicResource App.Accent}">
                                    <Run Text="{loc:Tr Common_OpenInMap}" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_FolderDate}"
                                     Style="{StaticResource OptionalRowStyle}"
                                     Value="{Binding FolderDateText}" />
                </StackPanel>

                <!-- CATALOG -->
                <TextBlock Text="{loc:Tr VideoInfo_Section_Catalog}" Style="{StaticResource App.Type.Section}" Margin="0,16,0,0" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Status}" Value="{Binding StatusText}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Rating}" Value="{Binding RatingText}" />

                <!-- Tags row: rendered as inline chip list, not a copyable string. -->
                <Grid Margin="0,3,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Tr VideoInfo_Label_Tags}"
                               Foreground="{DynamicResource App.Foreground.Tertiary}"
                               FontSize="11"
                               VerticalAlignment="Top"
                               Margin="0,4,12,0" />
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Tags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource App.TagChip.ReadOnly}">
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource App.TagChip.Text}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Grid.Column="1"
                               Text="{loc:Tr Common_NoTags}"
                               Foreground="{DynamicResource App.Foreground.Tertiary}"
                               FontStyle="Italic"
                               FontSize="13"
                               Margin="0,2,0,0"
                               Visibility="{Binding HasTags, Converter={StaticResource BoolToVisibilityInverted}}" />
                </Grid>

                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Notes}"
                                 Style="{StaticResource OptionalRowStyle}"
                                 Value="{Binding NotesPreview}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Sidecar}"
                                 Value="{Binding SidecarStatusText}"
                                 SubValue="{Binding SidecarPathText}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_AddedToCatalog}" Value="{Binding CreatedAtText}" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_LastUpdated}" Value="{Binding UpdatedAtText}" />

                <!-- INTERNAL -->
                <TextBlock Text="{loc:Tr VideoInfo_Section_Internal}" Style="{StaticResource App.Type.Section}" Margin="0,16,0,0" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_CatalogId}" Value="{Binding CatalogIdText}" IsMono="True" />
                <helpers:InfoRow Label="{loc:Tr VideoInfo_Label_Thumbnail}"
                                 Style="{StaticResource OptionalRowStyle}"
                                 Value="{Binding ThumbnailPath}"
                                 IsMono="True" />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer with a single Close button. The window is non-modal so
             the caller doesn't await a result; we just dismiss. -->
        <Border Grid.Row="2"
                Background="{DynamicResource App.Background.Elevated}"
                BorderBrush="{DynamicResource App.Border.Subtle}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{loc:Tr Common_Close}"
                        Style="{StaticResource App.Button.Ghost}"
                        Click="Close_Click"
                        IsCancel="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
