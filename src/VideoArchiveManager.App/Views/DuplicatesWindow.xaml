<Window x:Class="VideoArchiveManager.App.Views.DuplicatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:VideoArchiveManager.App.ViewModels"
        xmlns:loc="clr-namespace:VideoArchiveManager.App.Localization"
        Title="{loc:Tr Dup_Title}"
        Width="820" Height="820"
        MinWidth="620" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        d:DataContext="{d:DesignInstance Type=vm:DuplicatesViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Window.Resources>

        <!-- One member row inside a duplicate set. -->
        <DataTemplate x:Key="DuplicateItemTemplate" DataType="{x:Type vm:DuplicateItemViewModel}">
            <Border Margin="0,3"
                    Padding="10,8"
                    CornerRadius="6"
                    Background="{DynamicResource App.Background.Inset}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              VerticalAlignment="Center"
                              Margin="0,0,10,0"
                              IsChecked="{Binding MarkedForRemoval, Mode=TwoWay}"
                              ToolTip="{loc:Tr Dup_MarkTip}" />

                    <Border Grid.Column="1"
                            Width="104" Height="59"
                            CornerRadius="4"
                            Margin="0,0,12,0"
                            ClipToBounds="True"
                            Background="{DynamicResource App.Background.Base}">
                        <Image Source="{Binding Thumbnail}"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch" />
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding FileName}"
                                       Style="{StaticResource App.Type.Body}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding FileName}" />
                            <Border Margin="8,0,0,0"
                                    Padding="6,1"
                                    CornerRadius="4"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource App.Accent}"
                                    Visibility="{Binding IsSuggestedKeep, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{loc:Tr Dup_SuggestedKeep}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource App.Accent.OnAccent}" />
                            </Border>
                            <Border Margin="8,0,0,0"
                                    Padding="6,1"
                                    CornerRadius="4"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource App.Background.Elevated}"
                                    BorderBrush="{DynamicResource App.Border.Subtle}"
                                    BorderThickness="1"
                                    Visibility="{Binding FileExists, Converter={StaticResource BoolToVisibilityInverted}}">
                                <TextBlock Text="{loc:Tr Dup_Offline}"
                                           FontSize="10"
                                           Foreground="{DynamicResource App.Foreground.Tertiary}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding FolderPath}"
                                   Style="{StaticResource App.Type.Caption}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FolderPath}"
                                   Margin="0,2,0,0" />
                        <TextBlock Text="{Binding DetailText}"
                                   Style="{StaticResource App.Type.BodySmall}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- One duplicate set card: fingerprint header + member rows. -->
        <DataTemplate x:Key="DuplicateGroupTemplate" DataType="{x:Type vm:DuplicateGroupViewModel}">
            <Border Margin="0,0,0,14"
                    Padding="16,14"
                    Background="{DynamicResource App.Background.Elevated}"
                    BorderBrush="{DynamicResource App.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding HeaderText}"
                                   Style="{StaticResource App.Type.H2}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ReclaimText}"
                                   Style="{StaticResource App.Type.Caption}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Items}"
                                  ItemTemplate="{StaticResource DuplicateItemTemplate}" />
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid TextElement.FontFamily="{StaticResource App.FontFamily}"
          TextElement.Foreground="{DynamicResource App.Foreground.Primary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="24,20,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{loc:Tr Dup_Title}" Style="{StaticResource App.Type.Display}" />
                <TextBlock Text="{loc:Tr Dup_Desc}"
                           Style="{StaticResource App.Type.Caption}"
                           TextWrapping="Wrap"
                           MaxWidth="560"
                           HorizontalAlignment="Left"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="{loc:Tr Dup_Rescan}"
                    VerticalAlignment="Top"
                    Style="{StaticResource App.Button.Secondary}"
                    Command="{Binding LoadCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />
        </Grid>

        <!-- Toolbar: summary + bulk selection helpers -->
        <Grid Grid.Row="1" Margin="24,4,24,8"
              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding SummaryText}"
                       Style="{StaticResource App.Type.BodyMuted}"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="{loc:Tr Dup_SelectRedundant}"
                        Style="{StaticResource App.Button.Ghost}"
                        Command="{Binding SelectRedundantCommand}"
                        ToolTip="{loc:Tr Dup_SelectRedundant_Tip}" />
                <Button Content="{loc:Tr Dup_Clear}"
                        Margin="8,0,0,0"
                        Style="{StaticResource App.Button.Ghost}"
                        Command="{Binding ClearSelectionCommand}" />
            </StackPanel>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="2">

            <!-- Loading -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <ui:ProgressRing IsActive="{Binding IsLoading}" Width="40" Height="40" />
                <TextBlock Text="{loc:Tr Dup_Scanning}"
                           Style="{StaticResource App.Type.BodyMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
            </StackPanel>

            <!-- No duplicates -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="400"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{loc:Tr Dup_EmptyTitle}"
                           Style="{StaticResource App.Type.H1}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Tr Dup_EmptyDesc}"
                           Style="{StaticResource App.Type.BodyMuted}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       MaxWidth="440"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="{DynamicResource App.Destructive}"
                       Style="{StaticResource App.Type.Body}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}" />

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="24,4,24,12"
                          Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl ItemsSource="{Binding Groups}"
                              ItemTemplate="{StaticResource DuplicateGroupTemplate}" />
            </ScrollViewer>
        </Grid>

        <!-- Action bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource App.Background.Elevated}"
                BorderBrush="{DynamicResource App.Border.Subtle}"
                BorderThickness="0,1,0,0"
                Padding="24,12"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding SelectionText}"
                           Style="{StaticResource App.Type.Body}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="{loc:Tr Dup_RemoveSelected}"
                        Style="{StaticResource App.Button.Destructive}"
                        Command="{Binding RemoveSelectedCommand}"
                        IsEnabled="{Binding CanRemove}" />
            </Grid>
        </Border>
    </Grid>
</Window>
