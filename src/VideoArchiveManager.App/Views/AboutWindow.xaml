<Window x:Class="VideoArchiveManager.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls"
        Title="About Find That Shot"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        ResizeMode="NoResize">
    <Grid Margin="24"
          TextElement.FontFamily="{StaticResource App.FontFamily}"
          TextElement.Foreground="{DynamicResource App.Foreground.Primary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Image Source="pack://application:,,,/Assets/LogoWordmark.png"
                   Width="300"
                   HorizontalAlignment="Left"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <TextBlock x:Name="VersionText"
                       Style="{StaticResource App.Type.Caption}"
                       Margin="0,8,0,0" />
        </StackPanel>

        <TextBlock Grid.Row="1" Margin="0,16,0,0" TextWrapping="Wrap"
                   Style="{StaticResource App.Type.Body}">
            A local-first catalog for browsing, tagging, and searching your video archive.
        </TextBlock>

        <Border Grid.Row="2" Margin="0,20,0,0" Padding="16"
                Background="{DynamicResource App.Background.Elevated}"
                BorderBrush="{DynamicResource App.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="LICENSE" Style="{StaticResource App.Type.Section}" Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap" Style="{StaticResource App.Type.Body}">
                    <Run Text="This application is distributed under the " />
                    <Hyperlink NavigateUri="https://www.gnu.org/licenses/gpl-3.0.html"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource App.Accent}">
                        GNU General Public License v3
                    </Hyperlink>
                    <Run Text="." />
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,8,0,0" Style="{StaticResource App.Type.Body}">
                    <Run Text="Source code: " />
                    <Hyperlink NavigateUri="https://github.com/liknes/FindThatShot"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource App.Accent}">
                        github.com/liknes/FindThatShot
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Margin="0,12,0,0" Padding="16"
                Background="{DynamicResource App.Background.Elevated}"
                BorderBrush="{DynamicResource App.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="THIRD-PARTY COMPONENTS" Style="{StaticResource App.Type.Section}" Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap" Style="{StaticResource App.Type.Body}">
                    This product uses
                    <Hyperlink NavigateUri="https://ffmpeg.org/"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource App.Accent}">FFmpeg</Hyperlink>
                    (GPLv3),
                    <Hyperlink NavigateUri="https://github.com/sinaxxr/ffmediaelement"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource App.Accent}">FFME (Sinaxxr fork)</Hyperlink>
                    (Ms-PL),
                    <Hyperlink NavigateUri="https://github.com/Ruslan-B/FFmpeg.AutoGen"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource App.Accent}">FFmpeg.AutoGen</Hyperlink>
                    (LGPLv3),
                    <Hyperlink NavigateUri="https://developer.microsoft.com/microsoft-edge/webview2/"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource App.Accent}">Microsoft WebView2</Hyperlink>,
                    <Hyperlink NavigateUri="https://leafletjs.com/"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource App.Accent}">Leaflet</Hyperlink>
                    (BSD-2), and other open-source software.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,8,0,0" Style="{StaticResource App.Type.Body}">
                    Map data
                    <LineBreak />
                    <Run Text="© " />
                    <Hyperlink NavigateUri="https://www.openstreetmap.org/copyright"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource App.Accent}">OpenStreetMap contributors</Hyperlink>
                    <Run Text=", reverse-geocoded via " />
                    <Hyperlink NavigateUri="https://nominatim.org/"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource App.Accent}">Nominatim</Hyperlink>
                    <Run Text="." />
                </TextBlock>
                <TextBlock x:Name="NoticesPathText"
                           Style="{StaticResource App.Type.Caption}"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="View third-party notices"
                    Style="{StaticResource App.Button.Secondary}"
                    helpers:Theme.Icon="{StaticResource Icon.Document}"
                    Click="ViewNotices_Click" />
            <Button Content="OK"
                    Margin="8,0,0,0"
                    IsDefault="True" IsCancel="True"
                    Style="{StaticResource App.Button.Primary}"
                    Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>
