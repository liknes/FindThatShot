<Window x:Class="VideoArchiveManager.App.Views.MapBrowseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls"
        xmlns:vm="clr-namespace:VideoArchiveManager.App.ViewModels"
        xmlns:loc="clr-namespace:VideoArchiveManager.App.Localization"
        Title="{loc:Tr MapBrowse_Title}"
        Width="1100" Height="760"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        d:DataContext="{d:DesignInstance Type=vm:MapBrowseViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{loc:Tr MapBrowse_Title}" Style="{StaticResource App.Type.Display}" />
            <TextBlock Margin="0,4,0,0"
                       Text="{loc:Tr MapBrowse_Description}"
                       TextWrapping="Wrap"
                       Style="{StaticResource App.Type.Caption}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0"
                      VerticalAlignment="Center"
                      Content="{loc:Tr Common_WholeArchive}"
                      IsChecked="{Binding ScopeWholeArchive}"
                      ToolTip="{loc:Tr MapBrowse_WholeArchive_Tip}" />

            <TextBlock Grid.Column="2"
                       Margin="16,0,16,0"
                       VerticalAlignment="Center"
                       Text="{Binding ResultSummary}"
                       Foreground="{DynamicResource App.Foreground.Secondary}" />

            <Button Grid.Column="3"
                    Content="{loc:Tr Common_FilterGridToView}"
                    Click="FilterToView_Click"
                    Style="{StaticResource App.Button.Secondary}"
                    helpers:Theme.Icon="{StaticResource Icon.Filter}"
                    ToolTip="{loc:Tr MapBrowse_FilterGrid_Tip}" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    CornerRadius="6"
                    ClipToBounds="True"
                    Background="{DynamicResource App.Background.Inset}">
                <helpers:GlobalMapView x:Name="MapView" />
            </Border>

            <Border Grid.Column="1"
                    Width="300"
                    Margin="12,0,0,0"
                    Padding="14"
                    CornerRadius="6"
                    Background="{DynamicResource App.Background.Inset}">
                <Grid>
                    <TextBlock VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="{loc:Tr MapBrowse_ClickMarker}"
                               Foreground="{DynamicResource App.Foreground.Tertiary}"
                               Visibility="{Binding SelectedClip, Converter={StaticResource NullToVisibilityInverted}}" />

                    <StackPanel Visibility="{Binding SelectedClip, Converter={StaticResource NullToVisibility}}">
                        <Border CornerRadius="4"
                                ClipToBounds="True"
                                Height="158"
                                Background="{DynamicResource App.Background.Base}">
                            <Image Source="{Binding SelectedClip.Thumbnail}" Stretch="UniformToFill" />
                        </Border>

                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding SelectedClip.FileName}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding SelectedClip.AvailabilityText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource App.Foreground.Secondary}" />
                            <TextBlock Text="{Binding SelectedClip.RatingText}"
                                       Margin="8,0,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource App.Accent}" />
                        </StackPanel>

                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding SelectedClip.LocationText}"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{DynamicResource App.Foreground.Secondary}" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding SelectedClip.CoordinatesText}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="{DynamicResource App.Foreground.Tertiary}" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding SelectedClip.FolderPath}"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{DynamicResource App.Foreground.Tertiary}" />

                        <Button Margin="0,14,0,0"
                                HorizontalAlignment="Stretch"
                                Content="{loc:Tr Common_ShowInGrid}"
                                Command="{Binding ShowInGridCommand}"
                                Style="{StaticResource App.Button.Primary}"
                                helpers:Theme.Icon="{StaticResource Icon.Map}" />
                        <Button Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                Content="{loc:Tr Common_PlayInApp}"
                                Command="{Binding PlayCommand}"
                                Style="{StaticResource App.Button.Secondary}"
                                helpers:Theme.Icon="{StaticResource Icon.Play}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
