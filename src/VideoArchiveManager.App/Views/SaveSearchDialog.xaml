<Window x:Class="VideoArchiveManager.App.Views.SaveSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:helpers="clr-namespace:VideoArchiveManager.App.Helpers.Controls"
        xmlns:loc="clr-namespace:VideoArchiveManager.App.Localization"
        Title="{loc:Tr SaveSearch_Title}"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.Background.Base}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Background="{DynamicResource App.Background.Base}"
        ui:TitleBar.InactiveBackground="{DynamicResource App.Background.Base}"
        ui:TitleBar.Foreground="{DynamicResource App.Foreground.Primary}"
        ui:TitleBar.InactiveForeground="{DynamicResource App.Foreground.Tertiary}"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        ResizeMode="NoResize">
    <Grid Margin="24"
          TextElement.FontFamily="{StaticResource App.FontFamily}"
          TextElement.Foreground="{DynamicResource App.Foreground.Primary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{loc:Tr SaveSearch_Header}" Style="{StaticResource App.Type.H1}" />
            <TextBlock Text="{loc:Tr SaveSearch_Desc}"
                       Style="{StaticResource App.Type.BodyMuted}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
        </StackPanel>

        <TextBox x:Name="NameBox"
                 Grid.Row="1"
                 ui:ControlHelper.PlaceholderText="{loc:Tr SaveSearch_Placeholder}"
                 MaxLength="256" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="{loc:Tr Common_Cancel}"
                    IsCancel="True"
                    Style="{StaticResource App.Button.Ghost}"
                    Click="Cancel_OnClick" />
            <Button Content="{loc:Tr Common_Save}"
                    Margin="8,0,0,0"
                    IsDefault="True"
                    Style="{StaticResource App.Button.Primary}"
                    helpers:Theme.Icon="{StaticResource Icon.Save}"
                    Click="Save_OnClick" />
        </StackPanel>
    </Grid>
</Window>
