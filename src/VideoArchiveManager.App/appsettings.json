{
  "AppSettings": {
    "FfmpegPath": "tools\\ffmpeg\\ffmpeg.exe",
    "FfprobePath": "tools\\ffmpeg\\ffprobe.exe",
    "ThumbnailDirectory": "",
    "DatabasePath": "",
    "BackupDirectory": "",
    "AutoBackupOnStartup": true,
    "BackupRetentionCount": 7,
    "WriteSidecarFiles": false,
    "MaxScanParallelism": 4,
    "PageSize": 200,
    "SupportedExtensions": [ ".mp4", ".mov", ".mxf", ".avi", ".mkv" ],
    "ExcludedFolderNames": [
      "proxy",
      "proxies",
      "edits",
      "_proxy",
      "_edits",
      "_originals",
      "@eaDir",
      "@Recycle",
      ".Trash",
      "$RECYCLE.BIN",
      "System Volume Information"
    ],
    "ExcludedFileNamePatterns": [ "*.LRV", "*.THM" ]
  }
}
